ass="cardContainer" ng-if="!$ctrl.showRafProgress">\r\n            <h5 mee-heading="heading5" class="lastOrder">{{$ctrl.cmsData.strings[\'your-last-order\']}}</h5>\r\n            <mee-card display-type="double">\r\n                <card-content>            \r\n                    <mee-rewards-redeem-order-card user-status="$ctrl.userStatus" cms-data="$ctrl.cmsData" />\r\n                </card-content>\r\n            </mee-card>\r\n        </div>\r\n\r\n        <div id="dashboard-raf-progress" class="cardContainer" ng-if="$ctrl.showRafProgress">\r\n            <div class="progressheader">\r\n                <h5 mee-heading="heading5">\r\n                    {{ $ctrl.cmsData.strings["refer-a-friend-progress-desc"] }}\r\n                </h5>\r\n\r\n                <a mee-call-to-action="lightweight"\r\n                   id="{{$ctrl.cmsData.links[\'raf-go-to-community\'].id}}"\r\n                   ng-href="{{$ctrl.cmsData.links[\'raf-go-to-community\'].url}}"\r\n                   ng-attr-aria-label="{{$ctrl.cmsData.links[\'raf-go-to-community\'].ariaLabel}}"\r\n                   data-bi-id="{{$ctrl.cmsData.links[\'raf-go-to-community\'].id}}"\r\n                   class="cta-trim"\r\n                   target="{{$ctrl.cmsData.links[\'raf-go-to-community\'].target}}">\r\n                    {{$ctrl.cmsData.links[\'raf-go-to-community\'].text}}\r\n                </a>\r\n\r\n            </div>\r\n            <mee-card display-type="double">\r\n                <card-content>\r\n                    <mee-rewards-raf-dashboard-progress progress-info="$ctrl.userStatus.referrerProgressInfo"></mee-rewards-raf-dashboard-progress>\r\n                </card-content>\r\n            </mee-card>\r\n        </div>\r\n    </mee-card-group>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/RedeemInfo/redeem-info-goal-card.html",'<div aria-label="{{item.title}}, {{item.subtitle | stripHtmlTag}}" mee-rewardable class="redeem-info-card">\r\n    <div class="imageContainer">\r\n        <mee-rewards-animation data="item.icon" ng-if="item.icon" />\r\n    </div>\r\n        \r\n    <div class="contentContainer" data-m=\'{{item.biContentString}}\'>\r\n        <h2 mee-heading="heading" class="ellipsis">{{item.title}}</h2>\r\n        <mee-progress-determinate progress-value="item.progress" mee-aria-label="{{item.subtitle | stripHtmlTag}}" ng-if="item.progress !== undefined"></mee-progress-determinate>\r\n        <p mee-heading="subheading4" class="font-weight-normal ellipsis" ng-bind-html="item.subtitle" ng-if="item.subtitle"></p>        \r\n\r\n        <div class="actionLink">\r\n            <a mee-call-to-action="lightweight"\r\n               ng-if="item.primaryCallToAction.text && (item.complete || !item.points)"\r\n               id="{{item.primaryCallToAction.id}}"\r\n               ng-href="{{item.primaryCallToAction.url}}">\r\n                {{item.primaryCallToAction.text}}\r\n            </a>\r\n            <a mee-call-to-action="lightweight"\r\n               class="secondary-call-to-action mandatory-link"\r\n               ng-if="item.secondaryCallToAction.text"\r\n               id="{{item.secondaryCallToAction.id}}"\r\n               ng-href="{{item.secondaryCallToAction.url}}"\r\n               ng-click="$ctrl.removeGoal($event)">\r\n                {{item.secondaryCallToAction.text}}\r\n            </a>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/RedeemInfo/redeem-info-order-card.html",'<div aria-label="{{item.title}}, {{item.priceText}}" mee-rewardable class="redeem-info-card">\r\n    <div class="imageContainer">\r\n        <mee-rewards-animation data="item.icon" ng-if="item.icon" />    \r\n    </div>\r\n    \r\n    <div class="contentContainer" data-m=\'{{item.biContentString}}\'>\r\n        <h2 mee-heading="heading" class="ellipsis">{{item.title}}</h2>\r\n        <p mee-heading="subheading4" class="font-weight-normal ellipsis" ng-if="item.priceText">{{item.priceText}}</p>\r\n        <p mee-heading="subheading" class="ellipsis" ng-if="item.timeStampText">{{item.timeStampText}}</p>        \r\n        <div class="actionLink">\r\n            <a mee-call-to-action="lightweight"\r\n               id="{{item.callToAction.id}}"\r\n               ng-href="{{item.callToAction.url}}">\r\n               {{item.callToAction.text}}\r\n            </a>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/Streak/streak.html",'<div id="streak"\r\n     data-grid="container"\r\n     class="clearfix"\r\n     aria-label="{{$ctrl.streakCounter.progress}}, {{$ctrl.streakCounter.title}}, {{$ctrl.streakBonusCounter.title | stripHtmlTag}}">\r\n    <div data-grid="col-3" ng-class="{\'complete\' : !$ctrl.isComplete}">\r\n        <div data-coachmark-tag="streakStart"></div>\r\n        <mee-rewards-animation data="$ctrl.streakCounter.image"\r\n                               start-frame="$ctrl.streakCounter.animationStartFrame"\r\n                               end-frame="$ctrl.streakCounter.animationEndFrame"\r\n                               ng-if="$ctrl.streakCounter.image.source">\r\n        </mee-rewards-animation>\r\n        <mee-rich-paragraph mee-paragraph-style="para2Lean" text="$ctrl.streakCounter.title" class="text"></mee-rich-paragraph>\r\n    </div>\r\n    <div data-grid="col-6" ng-class="{\'complete\' : $ctrl.isComplete}">\r\n        <div data-coachmark-tag="streakProgress"></div>\r\n        <mee-rewards-animation data="$ctrl.streakBonusCounter.image"\r\n                               start-frame="$ctrl.streakBonusCounter.animationStartFrame"\r\n                               end-frame="$ctrl.streakBonusCounter.animationEndFrame"\r\n                               speed="$ctrl.streakBonusCounter.animationSpeed"\r\n                               ng-if="$ctrl.streakBonusCounter.image.source">\r\n        </mee-rewards-animation>\r\n        <mee-rich-paragraph mee-paragraph-style="para2Lean" text="$ctrl.streakBonusCounter.title" class="text description"></mee-rich-paragraph>\r\n    </div>\r\n    <div data-grid="col-3" ng-class="{\'complete\' : $ctrl.isComplete}">\r\n        <div data-coachmark-tag="streakComplete"></div>\r\n        <mee-rewards-animation data="$ctrl.streakBonusUnlock.image"\r\n                               start-frame="$ctrl.streakBonusUnlock.animationStartFrame"\r\n                               end-frame="$ctrl.streakBonusUnlock.animationEndFrame"\r\n                               ng-if="$ctrl.streakBonusUnlock.image.source">\r\n        </mee-rewards-animation>\r\n        <mee-rich-paragraph mee-paragraph-style="para2Lean" text="$ctrl.streakBonusUnlock.title" class="text"></mee-rich-paragraph>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/SuggestedRewards/suggested-rewards-card-item.html",'<div class="text-align-center rewards-card-container" mee-rewardable>\r\n    <a ng-if="item.callToAction.text && !item.comingSoonFlag" ng-href="{{item.callToAction.url}}" class="actionableCard">\r\n        <div class="imageContainer">\r\n            <picture>\r\n                <img mee-image ng-src="{{item.icon.source}}" alt="{{item.icon.alternateText}}" ng-if="item.icon.source" />\r\n            </picture>\r\n        </div>\r\n\r\n        <div class="contentContaine padding-10">\r\n            <h3 mee-heading="heading">{{item.title}}</h3>\r\n        </div>\r\n\r\n        <div class="actionLink">\r\n            <span ng-if="item.callToAction.text" class="redeemAction">\r\n                {{item.callToAction.text}} <i class="mee-icon pull-left icon mee-icon-ChevronRightSmall"></i>\r\n            </span>\r\n        </div>\r\n        <mee-rewards-debug-info item="item"></mee-rewards-debug-info>\r\n    </a>\r\n    <div class="nonclickable-card" ng-if="item.comingSoonFlag">\r\n        <div class="imageContainer">\r\n            <picture>\r\n                <img mee-image ng-src="{{item.icon.source}}" alt="{{item.icon.alternateText}}" ng-if="item.icon.source" />\r\n            </picture>\r\n        </div>\r\n        <div class="contentContaine padding-10">\r\n            <h3 mee-heading="heading">{{item.title}}</h3>\r\n        </div>\r\n        <div class="actionLink">\r\n            <span class="redeemAction comingsoon">{{item.comingSoonText}}</span>\r\n        </div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/SuggestedRewards/suggested-rewards-card.html",'<div id="suggested-rewards" ng-if="!$ctrl.componentAvailabilityMap[\'outageRoaming\'] && $ctrl.isEnabled">\r\n    <div class="card-header">\r\n        <h2 mee-heading="heading5" ng-if="!$ctrl.componentAvailabilityMap[\'outageRoaming\']">{{$ctrl.cmsData.strings["suggested-rewards"]}}</h2>\r\n        <a mee-call-to-action="lightweight" ng-href="{{$ctrl.headerLink.url}}" class="module-info cta-trim" target="_self">\r\n            {{$ctrl.headerLink.text}}\r\n        </a>\r\n    </div>\r\n    <mee-card-group>\r\n        <mee-card ng-repeat="item in $ctrl.suggestedRewardsItems"\r\n                  display-type="{{item.displayType}}"\r\n                  data-bi-id="{{item.biId}}"\r\n                  data-m=\'{{item.biContentString}}\'\r\n                  aria-label="{{item.title}}">\r\n            <card-content>\r\n                <mee-rewards-suggested-rewards-card-item item="item" />\r\n            </card-content>\r\n        </mee-card>\r\n    </mee-card-group>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/SuggestedSearches/suggested-searches.html",'<div class="suggestedSearches-container" data-bi-id="{{$ctrl.biId}}">\r\n    <h3 mee-heading="heading" ng-class="{\'f-lean\': $ctrl.isDenseDashboard()}">{{$ctrl.cmsData.strings["suggested-search-title"]}}</h3>\r\n    <p ng-if="$ctrl.enableSearchBox && $ctrl.description"\r\n        mee-paragraph="para4" class="rewards-suggestedSearches-searchbox-title" ng-class="{\'f-lean\': $ctrl.isDenseDashboard()}">{{$ctrl.description}}</p>\r\n    <div ng-if="$ctrl.enableSearchBox"\r\n        id="rewards-suggestedSearch-searchbox-form">\r\n        <div class="rewards_searchboxForm" role="search">\r\n            \x3c!-- Auto-generated by AI: Added role="link" and aria-label for screen reader accessibility --\x3e\r\n            <div class="icon" ng-click="$ctrl.onSearchClick()" ng-keydown="$ctrl.onSearchIconKeyDown($event)" role="link" ng-attr-aria-label="{{$ctrl.cmsData.strings[\'search-box-placeholder\']}}" tabindex="0">\r\n                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">\r\n                    <path d="M8.5 4C11.5376 4 14 6.46243 14 9.5C14 10.8388 13.5217 12.0659 12.7266 13.0196L16.8536 17.1464C17.0488 17.3417 17.0488 17.6583 16.8536 17.8536C16.68 18.0271 16.4106 18.0464 16.2157 17.9114L16.1464 17.8536L12.0196 13.7266C11.0659 14.5217 9.83879 15 8.5 15C5.46243 15 3 12.5376 3 9.5C3 6.46243 5.46243 4 8.5 4ZM8.5 5C6.01472 5 4 7.01472 4 9.5C4 11.9853 6.01472 14 8.5 14C10.9853 14 13 11.9853 13 9.5C13 7.01472 10.9853 5 8.5 5Z" fill="#767676" />\r\n                </svg>\r\n            </div>\r\n\r\n            <input type="text" ng-attr-aria-label="{{$ctrl.cmsData.strings[\'search-box-placeholder\']}}" aria-autocomplete="list"\r\n                   ng-class="{highlighted: $ctrl.isSearchBoxHighlighted}"\r\n                   aria-controls="autocomplete-item-list" aria-required="true" role="combobox"\r\n                   aria-expanded="{{$ctrl.hasVisibleSuggestions}}" id="rewards-suggestedSearch-searchbox" \r\n                   placeholder="{{$ctrl.cmsData.strings[\'search-box-placeholder\']}}" ng-model="searchText" />\r\n            \x3c!-- Screen reader announcement region for search suggestions --\x3e\r\n            <div id="search-suggestions-status" class="sr-announcements" aria-live="assertive" aria-atomic="true" aria-relevant="additions text" ng-if="searchText"></div>\r\n            <ul id="autocomplete-item-list" class="suggestedSearchResults" role="listbox">\r\n                \x3c!-- Suggestions added from component dynamically--\x3e\r\n            </ul>\r\n            <mee-rewards-tooltip\r\n                tooltip-id="$ctrl.searchBoxTooltipId"\r\n                tooltip-description="$ctrl.searchBoxTooltipText"\r\n                beak-direction="$ctrl.searchBoxTooltipBeakDirection"\r\n                cms-data="$ctrl.cmsData">\r\n            </mee-rewards-tooltip>\r\n        </div>\r\n        <p class="hint-text" data-bi-id="search-explore-on-bing-hint" ng-bind-html="$ctrl.searchBoxHintText" ng-if="$ctrl.searchBoxHintText" ng-click="$ctrl.onHintClick($event)"></p>\r\n    </div>\r\n    <p ng-if="$ctrl.enableSuggestions"\r\n        mee-paragraph="para4" ng-class="{\'f-lean\': $ctrl.isDenseDashboard()}">{{$ctrl.cmsData.strings["trending-search-queries-title"]}}</p>\r\n    <div ng-if="$ctrl.enableSuggestions"\r\n        class="rewards_searchSuggestions" data-bm="2">\r\n        <div class="rewards_searchSuggestionDiv" ng-repeat="searchSuggestion in $ctrl.suggestedSearchItems">\r\n            <a class="rewards_searchSuggestionItem" href="{{searchSuggestion.url}}" target="_blank" aria-disabled="false" aria-label="{{searchSuggestion.query}}" title="{{searchSuggestion.query}}" role="link"\r\n                id="trending-search-item">\r\n                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">\r\n                    <path d="M8.60001 4.80005L12.2386 4.8012L12.3246 4.8128L12.4152 4.83934L12.4965 4.87755L12.5273 4.89633L12.5663 4.92388L12.6272 4.97748L12.6946 5.05843L12.7413 5.13821L12.7745 5.22254L12.793 5.30043L12.8012 5.40005V9.00316C12.8012 9.33453 12.5326 9.60316 12.2012 9.60316C11.8975 9.60316 11.6464 9.37744 11.6067 9.08458L11.6012 9.00316L11.6008 6.84885L8.22437 10.2273C8.01127 10.4405 7.67769 10.4598 7.44276 10.2853L7.37546 10.2271L6.19885 9.04895L4.22436 11.0242C3.99009 11.2586 3.61019 11.2587 3.37583 11.0244C3.16278 10.8114 3.14335 10.4781 3.31758 10.2432L3.37566 10.1759L5.7747 7.77587C5.98781 7.56268 6.32138 7.54338 6.5563 7.7179L6.6236 7.77607L7.80021 8.95426L10.7528 6.00005H8.60001C8.29626 6.00005 8.04522 5.77433 8.00549 5.48147L8.00001 5.40005C8.00001 5.06868 8.26864 4.80005 8.60001 4.80005Z" fill="#424242"></path>\r\n                </svg>\r\n                <span>{{searchSuggestion.query}} </span>\r\n            </a>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/WelcomeTour/welcome-tour.html",'<div id="welcome-tour" tabindex="-1" ng-if="(!$ctrl.freNewDesign)">\r\n    <mee-rewards-slide id="welcome-tour-slide" ng-repeat="slide in $ctrl.welcomeTour.slides" ng-class="{\'ng-hide\' : $index != 0}">\r\n        <div>\r\n            <mee-rewards-animation data="slide.backgroundImage" preserve-aspect-ratio="xMidYMin slice" />\r\n        </div>\r\n        <section>\r\n            <h2 class="point-counter" mee-heading="subheading5">\r\n                <mee-rewards-counter-animation class="welcome-tour-avaliable-counter"\r\n                                               from="0" to="$ctrl.welcomeTour.promotion.pointProgress"\r\n                                               format="$ctrl.counterFormat">\r\n                </mee-rewards-counter-animation>\r\n                <span mee-heading="subheading5">{{$ctrl.cmsData.strings[\'welcome-tour-points\']}}</span>\r\n            </h2>\r\n            <h2 class="welcome-tour-header" mee-heading="heading" tabindex="0">{{slide.title}}</h2>\r\n            <mee-rich-paragraph text="slide.description" class="welcome-tour-description" mee-heading="subheading5" tabindex="0"></mee-rich-paragraph>\r\n            <div ng-if="slide.quizLinks" ng-repeat="link in slide.quizLinks" class="linkContainer">\r\n                <mee-rewards-check-mark ng-class="{\'ng-hide\' : $ctrl.hideCheckMark(link)}" complete="$ctrl.checkMarkInput" ng-if="link.isCorrectAnswer" tabindex="0" ng-attr-aria-label="{{$ctrl.cmsData.strings[\'check-mark\']}}"></mee-rewards-check-mark>\r\n                <a mee-call-to-action="lightweight"\r\n                   class="quiz-link gray-button"\r\n                   ng-class="{\'gray-out-button\' : $ctrl.welcomeTour.promotion.complete && link.isOfferAnswer}"\r\n                   role="button"\r\n                   ng-click="$ctrl.onClickAnswer($event, $index, slide)"\r\n                   href="#">\r\n                    {{link.text}}\r\n                </a>\r\n            </div>\r\n            <div class="actionLink" mee-auto-focus ng-class="{\'lastpg\' : (slide.quizLinks && slide.quizLinks.length > 0) || slide.id == $ctrl.welcomeTour.slides.length}">\r\n                <a mee-call-to-action\r\n                   ng-click="$ctrl.onClickNextButton($event)"\r\n                   class="welcome-tour-next-button"\r\n                   ng-class="{\'ng-hide\' : slide.id == $ctrl.welcomeTour.slides.length || (slide.quizLinks && slide.quizLinks.length > 0)}"\r\n                   role="button"\r\n                   href="#">\r\n                    {{slide.nextLink.text}}\r\n                </a>\r\n                <a mee-call-to-action\r\n                   ng-click="$ctrl.onClickCloseLink($event)"\r\n                   class="welcome-tour-close-link"\r\n                   ng-class="{\'ng-hide\' : slide.id < $ctrl.welcomeTour.slides.length || (slide.quizLinks && slide.quizLinks.length > 0)}"\r\n                   role="button"\r\n                   href="#">\r\n                    {{slide.nextLink.text}}\r\n                </a>\r\n            </div>\r\n        </section>\r\n    </mee-rewards-slide>\r\n</div>\r\n\r\n<div id="welcome-tour" class="welcome-tour-modal" tabindex="-1" ng-if="($ctrl.freNewDesign) && !($ctrl.isMobile)" >\r\n    <mee-rewards-slide id="welcome-tour-slide" ng-repeat="slide in $ctrl.welcomeTour.slides" ng-class="{\'ng-hide\' : $index != 0}">\r\n        <section class="welcome-tour-section">\r\n            <div id="welcome-tour-body" class="text-align-center">\r\n                <div id="welcome-tour-body-content">\r\n                    <div id="welcome-tour-body-content-header">\r\n                        <h2 class="welcome-tour-header" mee-heading="heading" tabindex="0" ng-if="(slide.layout == \'titlefirst\')">{{slide.title}}</h2>\r\n                        <div ng-if="(slide.backgroundImages.length == 0)" class="background-image">\r\n                            <mee-rewards-animation data="slide.backgroundImage" preserve-aspect-ratio="xMidYMin slice" />\r\n                        </div>\r\n                        <div id="welcome-tour-images" ng-if="(slide.backgroundImages.length > 0)">\r\n                            <div ng-repeat="image in slide.backgroundImages">\r\n                                <div ng-style="{\'width\':slide.imageSize, \'padding\':\'1px\'}">\r\n                                    <mee-rewards-animation data="image" preserve-aspect-ratio="xMidYMin slice" />\r\n                                </div>\r\n                                <h2 class="welcome-tour-image-header" mee-heading="heading" tabindex="0">{{image.title}}</h2>\r\n                                <mee-rich-paragraph text="image.description" class="welcome-tour-image-description" mee-heading="subheading5" tabindex="0"></mee-rich-paragraph>\r\n                            </div>\r\n                        </div>\r\n                        <div class="welcome-tour-carousel" class="text-align-center">\r\n                            <ol class="carousel-slide-indicators">\r\n                                <li ng-repeat="sld in $ctrl.welcomeTour.slides" class="carousel-slide-marker" ng-class="{\'active\' : slide.id == sld.id}"></li>\r\n                            </ol>\r\n                        </div>\r\n                        <div class="welcome-tour-text-content">\r\n                            <h2 class="welcome-tour-title" mee-heading="subheading4" tabindex="0">{{$ctrl.cmsData.strings[slide.title]}}</h2>\r\n                            <mee-rich-paragraph text="$ctrl.cmsData.strings[slide.description]" class="welcome-tour-description" tabindex="0"></mee-rich-paragraph>\r\n                            <mee-rich-paragraph ng-class="{\'hideFootnote\': slide.footnote === \'\', \'deleteFootnote\': slide.footnote === \'\' && !$ctrl.isWindows}" text=\'$ctrl.cmsData.strings["slide-footnote"]\' class="welcome-tour-footnote"></mee-rich-paragraph>\r\n                            <div class="welcome-tour-disclaimer-div" ng-if="slide.id == 1 && $ctrl.isCodexAutoJoinUser">\r\n                                <p class="welcome-tour-consent">{{$ctrl.cmsData.strings["consent-text"]}}\r\n                                    <a class="welcome-tour-consent-link" ng-href="{{$ctrl.cmsData.links[\'consent-terms-link\'].url}}">{{$ctrl.cmsData.strings["consent-terms-text"]}}</a> |\r\n                                    <a class="welcome-tour-consent-link" ng-href="{{$ctrl.cmsData.links[\'consent-privacy-link\'].url}}">{{$ctrl.cmsData.strings["consent-privacy-text"]}}</a>\r\n                                </p> \r\n                            </div>\r\n                            <div class="interest-buttons" ng-if="!$ctrl.isWindowsUser && $ctrl.userInterestOptions && !$ctrl.isRafFre" ng-class="{\'ng-hide\' : slide.id != 3}">\r\n                                <label class="interest-button" ng-repeat="(key, value) in $ctrl.userInterestOptions track by key" ng-click="$ctrl.optionClicked(this)">\r\n                                    <input type="checkbox" class="options" value="{{key}}"><span>{{value}}</span> \r\n                                </label>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <div ng-if="slide.quizLinks" ng-repeat="link in slide.quizLinks" class="linkContainer">\r\n                        <mee-rewards-check-mark ng-class="{\'ng-hide\' : $ctrl.hideCheckMark(link)}" complete="$ctrl.checkMarkInput" ng-if="link.isCorrectAnswer" tabindex="0"  ng-attr-aria-label="{{$ctrl.cmsData.strings[\'check-mark\']}}"></mee-rewards-check-mark>\r\n                        <a mee-call-to-action="lightweight"\r\n                           class="quiz-link gray-button"\r\n                           ng-class="{\'gray-out-button\' : $ctrl.welcomeTour.promotion.complete && link.isOfferAnswer}"\r\n                           role="button"\r\n                           ng-click="$ctrl.onClickAnswer($event, $index, slide)"\r\n                           href="#">\r\n                            {{link.text}}\r\n                        </a>\r\n                    </div>\r\n                </div>\r\n                <div class="actionLink" mee-auto-focus>\r\n                    <a mee-call-to-action ng-if="slide.actionButtonText && slide.actionButtonUrl"\r\n                       class="welcome-tour-later-button"\r\n                       role="button"\r\n                       ng-click="$ctrl.onClickCloseLink($event)"\r\n                       href="{{$ctrl.cmsData.strings[slide.actionButtonUrl]}}">\r\n                        {{$ctrl.cmsData.strings[slide.actionButtonText]}}\r\n                    </a>\r\n                    <a mee-call-to-action\r\n                       ng-click="$ctrl.onNewClickBackButton($event)"\r\n                       class="welcome-tour-button back-button"\r\n                       id="fre-back-button"\r\n                       ng-class="{\'ng-hide\' : 1 > $ctrl.currentIndex}"\r\n                       role="button"\r\n                       href="#">\r\n                        {{$ctrl.cmsData.strings[\'back-text\']}}\r\n                    </a>\r\n                    <a mee-call-to-action\r\n                       ng-click="$ctrl.onNewClickNextButton($event)"\r\n                       class="welcome-tour-button next-button"\r\n                       id="fre-next-button"\r\n                       ng-class="{\'ng-hide\' : $ctrl.currentIndex + 1 == $ctrl.welcomeTour.slides.length}"\r\n                       role="button"\r\n                       href="#"> \r\n                        {{$ctrl.cmsData.strings[slide.nextLink.text]}}\r\n                    </a>\r\n                    <a mee-call-to-action\r\n                       ng-click="$ctrl.onClickRafNav($event)"\r\n                       class="welcome-tour-button next-button"\r\n                       id="fre-next-button"\r\n                       ng-if="slide.id === $ctrl.welcomeTour.slides.length && $ctrl.isRafFre"\r\n                       role="button"\r\n                       href="{{$ctrl.createRAFRedirectUrl()}}"\r\n                       ng-attr-target="{{$ctrl.getRafTarget()}}"> \r\n                        {{$ctrl.cmsData.strings[slide.nextLink.text]}}\r\n                    </a>\r\n                    <div id="disabled-wrapper">\r\n                        <a mee-call-to-action\r\n                           ng-click="$ctrl.interestClaimPoints($event)"\r\n                           id="claim-button"\r\n                           class="welcome-tour-button next-button claim-points-button"\r\n                           role="button"\r\n                           ng-if="slide.id == 3 && !$ctrl.isWindowsUser && !$ctrl.isRafFre"\r\n                           disabled="true"> \r\n                            {{$ctrl.cmsData.strings[slide.nextLink.text]}}\r\n                        </a>\r\n                    </div>\r\n                    <a mee-call-to-action\r\n                       ng-click="$ctrl.pinClaimPoints()"\r\n                       href="{{slide.nextLink.url}}"\r\n                       id="claim-button"\r\n                       class="welcome-tour-button next-button"\r\n                       role="button"\r\n                       ng-if="slide.id == 3 && $ctrl.isWindowsUser"\r\n                       target="_self"> \r\n                        {{$ctrl.cmsData.strings[slide.nextLink.text]}}\r\n                    </a>\r\n                </div>\r\n            </div>\r\n        </section>\r\n    </mee-rewards-slide>\r\n</div>\r\n\r\n<div id="welcome-tour" class="welcome-tour-modal" ng-class="{\'isMobile\': $ctrl.isMobile}" tabindex="-1" ng-if="($ctrl.freNewDesign) && ($ctrl.isMobile)" >\r\n    <mee-rewards-slide id="welcome-tour-slide" ng-repeat="slide in $ctrl.welcomeTour.slides" ng-class="{\'ng-hide\' : $index != 0}">\r\n        <section class="welcome-tour-section">\r\n            <div id="welcome-tour-body" class="text-align-center">\r\n                <div id="welcome-tour-body-content">\r\n                    <div ng-if="(slide.backgroundImages.length == 0)" class="background-image">\r\n                        <mee-rewards-animation class="imported-image" data="slide.backgroundImage" preserve-aspect-ratio="xMidYMin slice" />\r\n                    </div>\r\n                    <div id="welcome-tour-images" ng-if="(slide.backgroundImages.length > 0)">\r\n                        <div ng-repeat="image in slide.backgroundImages">\r\n                            <div ng-style="{\'width\':slide.imageSize, \'padding\':\'1px\'}">\r\n                                <mee-rewards-animation data="image" preserve-aspect-ratio="xMidYMin slice" />\r\n                            </div>\r\n                            <h2 class="welcome-tour-image-header" mee-heading="heading" tabindex="0">{{image.title}}</h2>\r\n                            <mee-rich-paragraph text="image.description" class="welcome-tour-image-description" mee-heading="subheading5" tabindex="0"></mee-rich-paragraph>\r\n                        </div>\r\n                    </div>\r\n                    <div class="non-image">\r\n                        <div class="welcome-tour-carousel vertical" class="text-align-center">\r\n                            <ol class="carousel-slide-indicators">\r\n                                <li ng-repeat="sld in $ctrl.welcomeTour.slides" class="carousel-slide-marker" ng-class="{\'active\' : slide.id == sld.id}"></li>\r\n                            </ol>\r\n                        </div>\r\n                        <div id="welcome-tour-body-content-header">\r\n                            <h2 class="welcome-tour-header" mee-heading="heading" tabindex="0" ng-if="(slide.layout == \'titlefirst\')">{{slide.title}}</h2>\r\n                            <div class="welcome-tour-text-content" ng-class="{\'dec-padding\' : slide.id > 2}">\r\n                                <h2 class="welcome-tour-title" mee-heading="subheading4">{{$ctrl.cmsData.strings[slide.title]}}</h2>\r\n                                <mee-rich-paragraph text="$ctrl.cmsData.strings[slide.description]" class="welcome-tour-description"></mee-rich-paragraph>\r\n                                <mee-rich-paragraph ng-class="{\'hideFootnote\': slide.footnote === \'\', \'deleteFootnote\': slide.footnote === \'\' && !$ctrl.isWindows}" text=\'$ctrl.cmsData.strings["slide-footnote"]\' class="welcome-tour-footnote"></mee-rich-paragraph>\r\n                                <div class="welcome-tour-disclaimer-div" ng-if="slide.id == 1 && $ctrl.isCodexAutoJoinUser">\r\n                                    <p class="welcome-tour-consent">{{$ctrl.cmsData.strings["consent-text"]}}\r\n                                        <a class="welcome-tour-consent-link" ng-href="{{$ctrl.cmsData.links[\'consent-terms-link\'].url}}">{{$ctrl.cmsData.strings["consent-terms-text"]}}</a> |\r\n                                        <a class="welcome-tour-consent-link" ng-href="{{$ctrl.cmsData.links[\'consent-privacy-link\'].url}}">{{$ctrl.cmsData.strings["consent-privacy-text"]}}</a>\r\n                                    </p> \r\n                                </div>\r\n                                <div class="interest-buttons" ng-if="!$ctrl.isWindowsUser && $ctrl.userInterestOptions" ng-class="{\'ng-hide\' : slide.id != 3}">\r\n                                    <label class="interest-button" ng-repeat="(key, value) in $ctrl.userInterestOptions track by key" ng-click="$ctrl.optionClicked(this)">\r\n                                        <input type="checkbox" class="options" value="{{key}}"><span>{{value}}</span> \r\n                                    </label>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <div ng-if="slide.quizLinks" ng-repeat="link in slide.quizLinks" class="linkContainer">\r\n                            <mee-rewards-check-mark ng-class="{\'ng-hide\' : $ctrl.hideCheckMark(link)}" complete="$ctrl.checkMarkInput" ng-if="link.isCorrectAnswer" tabindex="0"  ng-attr-aria-label="{{$ctrl.cmsData.strings[\'check-mark\']}}"></mee-rewards-check-mark>\r\n                            <a mee-call-to-action="lightweight"\r\n                               class="quiz-link gray-button"\r\n                               ng-class="{\'gray-out-button\' : $ctrl.welcomeTour.promotion.complete && link.isOfferAnswer}"\r\n                               role="button"\r\n                               ng-click="$ctrl.onClickAnswer($event, $index, slide)"\r\n                               href="#">\r\n                                {{link.text}}\r\n                            </a>\r\n                        </div>\r\n                        <div class="bottom-row">\r\n                            <div class="welcome-tour-carousel horizontal" class="text-align-center">\r\n                                <ol class="carousel-slide-indicators">\r\n                                    <li ng-repeat="sld in $ctrl.welcomeTour.slides" class="carousel-slide-marker" ng-class="{\'active\' : slide.id == sld.id}"></li>\r\n                                </ol>\r\n                            </div>\r\n                            <div class="actionLink" mee-auto-focus>                            \r\n                                <a mee-call-to-action ng-if="slide.actionButtonText && slide.actionButtonUrl"\r\n                                   class="welcome-tour-later-button"\r\n                                   ng-click="$ctrl.onClickCloseLink($event)"\r\n                                   role="button"\r\n                                   href="{{$ctrl.cmsData.strings[slide.actionButtonUrl]}}">\r\n                                    {{$ctrl.cmsData.strings[slide.actionButtonText]}}\r\n                                </a>\r\n                                <a mee-call-to-action\r\n                                   ng-click="$ctrl.onNewClickBackButton($event)"\r\n                                   class="welcome-tour-button back-button"\r\n                                   id="fre-back-button"\r\n                                   ng-class="{\'ng-hide\' : 1 > $ctrl.currentIndex}"\r\n                                   role="button"\r\n                                   href="#">\r\n                                    {{$ctrl.cmsData.strings[\'back-text\']}}\r\n                                </a>\r\n                                <a mee-call-to-action\r\n                                   ng-click="$ctrl.onNewClickNextButton($event)"\r\n                                   class="welcome-tour-button next-button"\r\n                                   id="fre-next-button"\r\n                                   ng-class="{\'ng-hide\' : $ctrl.currentIndex + 1 == $ctrl.welcomeTour.slides.length}"\r\n                                   ng-if="slide.id < $ctrl.welcomeTour.slides.length"\r\n                                   role="button"\r\n                                   href="#"> \r\n                                    {{$ctrl.cmsData.strings[slide.nextLink.text]}}\r\n                                </a>\r\n                                <div id="disabled-wrapper">\r\n                                    <a mee-call-to-action\r\n                                       ng-click="$ctrl.interestClaimPoints($event)"\r\n                                       id="claim-button"\r\n                                       class="welcome-tour-button next-button claim-points-button"\r\n                                       role="button"\r\n                                       ng-if="slide.id == 3 && !$ctrl.isWindowsUser"\r\n                                       disabled="true"> \r\n                                        {{$ctrl.cmsData.strings[slide.nextLink.text]}}\r\n                                    </a>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>                    \r\n                </div>\r\n            </div>\r\n        </section>\r\n    </mee-rewards-slide>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Family/CommunityInfo/community-banner.html",'<div id="rewards-community-banner">\r\n    <div class="upsell-text">\r\n        <h1 mee-heading="heading5" class="f-lean">\r\n            {{ $ctrl.cmsData.strings["community-banner-title"] }}\r\n        </h1>\r\n        <p mee-paragraph="para2Lean">\r\n            {{ $ctrl.cmsData.strings["community-banner-description-line1"] }}\r\n        </p>\r\n        <p class="margin-top-12" mee-paragraph ng-if="$ctrl.cmsData.strings[\'community-banner-description-line2\']">\r\n            {{ $ctrl.cmsData.strings["community-banner-description-line2"] }}\r\n        </p>\r\n        <div class="annoucement">\r\n            <div class="left">\r\n                <mee-safe-image class="icon" alt="$ctrl.cmsData.strings[\'community-banner-warning-image-alt-text\']"\r\n                                src="$ctrl.cmsData.strings[\'community-banner-warning-image\']">\r\n                    <p></p>\r\n                </mee-safe-image>\r\n            </div>\r\n            <div class="right">\r\n                <div class="annoucement-desp">\r\n                    {{ $ctrl.cmsData.strings["community-banner-announcement-line1"] }}\r\n                </div>\r\n                <a class="redirect-link" cms-link="$ctrl.cmsData.links[\'community-banner-manage-family-link\']">\r\n                    {{$ctrl.cmsData.links[\'community-banner-manage-family-link\'].text}}\r\n                </a>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <div class="upsell-image">\r\n        <mee-safe-image alt="$ctrl.cmsData.strings[\'community-banner-alt-text\']"\r\n                        src="$ctrl.cmsData.strings[\'community-banner-image\']">\r\n            <p></p>\r\n        </mee-safe-image>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Family/CommunityInfo/community-list.html",'<div id="rewards-community-list">\r\n    <div class="control">\r\n        <div class="actioncontainer">\r\n            <a mee-call-to-action="lightweight" ui-sref="family.GiftPoint" data-bi-id="rx-gift-points">{{$ctrl.cmsData.strings["give-points"]}}</a>\r\n            <a ng-if="$ctrl.isRequestPointEnabled" mee-call-to-action="lightweight" ui-sref="family.RequestPoint" data-bi-id="rx-request-point">{{$ctrl.cmsData.strings["ask-for-points"]}}</a>\r\n        </div>\r\n        <div class="optioncontainer">\r\n            <mee-select ng-model="$ctrl.selectedOption" menu-style="accent" ng-change="$ctrl.onSelectChange()">\r\n                <select>\r\n                    <option value="{{opt.val}}" ng-repeat="opt in $ctrl.selectOptions">{{opt.text}}</option>\r\n                </select>\r\n            </mee-select>\r\n        </div>\r\n    </div>\r\n    <div class="community-member" ng-repeat="member in $ctrl.sortedMembers" ng-if="member.isRewardsUser !== undefined">\r\n        <div class="community-member-info">\r\n            <div class="image-section">\r\n                <mee-persona size="persona1" picture-aria-label="{{member.displayName}}">\r\n                    <persona-image>\r\n                        <mee-safe-image img-class="round" src="member.profileImageUrl"></mee-safe-image>\r\n                    </persona-image>\r\n                </mee-persona>\r\n            </div>\r\n            <div class="info-section">\r\n                <div>\r\n                    <h2 class="displayName ellipsis">{{member.rankName}}</h2>\r\n                    <div ng-if="member.isActiveUser" class="content">\r\n                        <div>\r\n                            <p>\r\n                                <i class="mee-icon icon mee-icon-AddMedium SmallFont" />\r\n                                {{member.pointsEarnedCurrentMonth | toLocalString}}\r\n                                &nbsp;\r\n                            </p>\r\n                        </div>\r\n                        <div>\r\n                            <p mee-paragraph="para2Lean">{{$ctrl.cmsData.strings["points-earned-this-month"]}}</p>\r\n                        </div>\r\n                    </div>\r\n                    <div class="message" ng-if="!member.isActiveUser">\r\n                        <p mee-paragraph="para2Lean">{{member.errorMessage}}</p>\r\n                        <a ng-if="member.callToAction && member.isRewardsUser === false && member.hasValidEmail && !member.isInvited"\r\n                           mee-call-to-action="lightweight"\r\n                           id=\'{{member.callToAction.id}}\'\r\n                           ng-click="member.callToAction.callFunction()"\r\n                           ng-attr-aria-label=\'{{member.callToAction.ariaLabel}}\'\r\n                           data-bi-id=\'{{member.callToAction.id}}\'>\r\n                            {{member.callToAction.text}}\r\n                        </a>\r\n                        <p mee-paragraph="para2" class="margin-top-12 font-italic" ng-if="member.isInvited">{{member.invitationMessage}}</p>\r\n                    </div>\r\n                </div>\r\n                <div ng-if="member.isActiveUser">\r\n                    <div class="content">\r\n                        <div>\r\n                            <i class="mee-icon icon mee-icon-RewardsLogo top-icon"></i>\r\n                        </div>\r\n                        <div class="sub-content">\r\n                            <p mee-paragraph="para2Lean">{{member.availableBalance | toLocalString}} &nbsp;</p>\r\n                            <p mee-paragraph="para2Lean" class="opacity-60">{{$ctrl.cmsData.strings["available-points"]}}</p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div ng-if="member.isActiveUser">\r\n                    <div class="content">\r\n                        <div>\r\n                            <i class="mee-icon icon mee-icon-Silver top-icon"></i>\r\n                        </div>\r\n                        <div class="sub-content">\r\n                            <p mee-paragraph="para2Lean">{{member.lifetimeBalance | toLocalString}} &nbsp;</p>\r\n                            <p mee-paragraph="para2Lean" class="opacity-60">{{$ctrl.cmsData.strings["lifetime-points"]}}</p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <div class="point-request-container" ng-if="member.hasExistingPointsRequest">\r\n            <div class="first">\r\n                <mee-safe-image src="$ctrl.cmsData.images[\'coin\'].src">\r\n                    <span></span>\r\n                </mee-safe-image>\r\n            </div>\r\n            <div class="second">\r\n                <p mee-paragraph="para2Lean" class="margin-right-10">{{ member.pointsRequestMessage }}</p>\r\n                <a ng-if="!member.isCurrentUser" mee-call-to-action ui-sref="family.GiftPoint({beneficiaryId: {{ member.puid }} })" data-bi-id="rx-gift-points">{{$ctrl.cmsData.strings["rp-give-points-button-text"]}}</a>\r\n                <a ng-if="member.isCurrentUser" mee-call-to-action ui-sref="family.RequestPoint" data-bi-id="rx-cancel-ask-points">{{$ctrl.cmsData.strings["cancel-ask-points"]}}</a>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <div class="addfamilysection">\r\n        <a tabindex="0"\r\n           ng-href=\'{{$ctrl.cmsData.links["add-family-url"].url}}\'\r\n           data-bi-id="rx-add-member-link"\r\n           id="rx-add-member-link"\r\n           class="width-match-parent link">\r\n            <span class="iconContainer">\r\n                <i class="mee-icon bigIcon icon mee-icon-AddCircle"></i>\r\n            </span>\r\n            <span class="addMemberContainer">{{$ctrl.cmsData.strings["add-a-family-member"]}}</span>\r\n        </a>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Family/FamilyInfoList/family-list.html",'<section id="familyMembers">\r\n    <div data-grid="col-12">\r\n        <mee-alert>\r\n            <alert-content>\r\n                <mee-select class="float-left" id="rewards-family-sortby" ng-model="$ctrl.selectedOption" menu-style="accent" ng-change="$ctrl.onSelectChange()">                    \r\n                    <select>\r\n                        <option value="{{opt.val}}" ng-repeat="opt in $ctrl.selectOptions">{{opt.text}}</option>\r\n                    </select>\r\n                </mee-select>\r\n                <p mee-paragraph="para2" class="float-right padding-top-10" id="rewards-family-daysleft" ng-if=" $ctrl.selectedOption === $ctrl.pointsEarnedCurrentMonth">{{$ctrl.howManyDaysLeft}}</p>\r\n            </alert-content>\r\n        </mee-alert>\r\n\r\n        <div class="familyContainer">\r\n            <div ng-repeat="member in $ctrl.sortedMembers" class="familyList clear" ng-class="{\'lastChild\': $last}" id="familyList_{{member.firstName}}_{{$index}}">\r\n                <div class="fl-part-one">\r\n                    <div data-grid="col-3" class="x-hidden-vp2 x-hidden-vp3 x-hidden-vp4 x-hidden-vp5 pointContainer" ng-class="{\'nonRewardsUserImage\' : member.isRewardsUser === false}">\r\n                        <div class="avataContainer text-align-center">\r\n                            <mee-persona size="persona1" picture-aria-label="{{member.displayName}}">\r\n                                <persona-image>\r\n                                    <img mee-image="round"\r\n                                         alt="{{member.displayName}}"\r\n                                         aria-label="{{member.displayName}}"\r\n                                         ng-src="{{member.profileImageUrl}}"\r\n                                         role="img"\r\n                                         ng-if="!!member.profileImageUrl && !member.isProfilePictureLoadingError"\r\n                                         data-mee-onerror\r\n                                         data-error-callback="$ctrl.onProfilePictureLoadingError(member)" />\r\n                                </persona-image>\r\n                            </mee-persona>\r\n                        </div>\r\n                        <div class="contentContainer">\r\n                            <h2 mee-heading="heading" class="displayName ellipsis">{{member.rankName}}</h2>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div data-grid="col-3"\r\n                         class="x-hidden-vp2 x-hidden-vp3 x-hidden-vp4 x-hidden-vp5 pointContainer"\r\n                         ng-class="{\'font-weight-bold\' : $ctrl.selectedOption === $ctrl.pointsEarnedCurrentMonth && member.isActiveUser, \'nonRewardsUserContent\' : member.isRewardsUser === false}">\r\n                        <div class="trophyContainer">\r\n                            <img mee-image\r\n                                 ng-if="member.iconUrl"\r\n                                 ng-src="{{member.iconUrl}}"\r\n                                 alt="{{$ctrl.cmsData.strings[\'trophy\']}}"\r\n                                 aria-label="{{$ctrl.cmsData.strings[\'trophy\']}}"\r\n                                 role="img" />\r\n                        </div>\r\n\r\n                        <div class="contentContainer">\r\n                            <h2 mee-heading="heading4" ng-if="member.isActiveUser">\r\n                                <i class="mee-icon icon mee-icon-AddMedium SmallFont" />\r\n                                {{member.pointsEarnedCurrentMonth | toLocalString}}\r\n                            </h2>\r\n                            <p mee-paragraph="para2" ng-if="member.isActiveUser">{{$ctrl.cmsData.strings["points-earned-this-month"]}}</p>\r\n                            <p mee-paragraph="para2" ng-if="!member.isActiveUser">{{member.errorMessage}}</p>\r\n                            <button mee-button="lightweight"\r\n                                    ng-if="member.callToAction && member.isRewardsUser === false && member.hasValidEmail && !member.isInvited"\r\n                                    id="{{member.callToAction.id}}"\r\n                                    ng-click="member.callToAction.callFunction()">\r\n                                {{member.callToAction.text}}\r\n                            </button>\r\n                            <p mee-paragraph="para2" class="margin-top-12 font-italic" ng-if="member.isInvited">{{member.invitationMessage}}</p>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class="x-hidden-vp1 personaContainer">\r\n                        <mee-persona size="persona1" picture-aria-label="{{member.displayName}}">\r\n                            <persona-image>\r\n                                <img mee-image="round"\r\n                                     alt="{{member.displayName}}"\r\n                                     aria-label="{{member.displayName}}" \r\n                                     ng-src="{{member.profileImageUrl}}"\r\n                                     ng-if="!!member.profileImageUrl && !member.isProfilePictureLoadingError"\r\n                                     data-mee-onerror\r\n                                     data-error-callback="$ctrl.onProfilePictureLoadingError(member)" />\r\n                            </persona-image>\r\n                        </mee-persona>\r\n                    </div>\r\n                </div>\r\n                <div class="trophyContainer x-hidden-vp1 x-hidden-vp2 fl-part-two">\r\n                    <img mee-image\r\n                         ng-if="member.iconUrl"\r\n                         ng-src="{{member.iconUrl}}"\r\n                         alt="{{$ctrl.cmsData.strings[\'trophy\']}}"\r\n                         aria-label="{{$ctrl.cmsData.strings[\'trophy\']}}"\r\n                         role="img" />\r\n                </div>\r\n\r\n                <div class="x-hidden-vp1 fl-part-grow-1">\r\n                    <div ng-class="{\'font-weight-bold\' : $ctrl.selectedOption === $ctrl.pointsEarnedCurrentMonth && member.isActiveUser}"\r\n                         class="margin-top-24 pointContainer margin-right-24">\r\n                        <p mee-paragraph="para2" class="name font-weight-bold">{{member.rankName}}</p>\r\n                        <h2 mee-heading="heading4" ng-if="member.isActiveUser">\r\n                            <i class="mee-icon icon mee-icon-AddMedium" />\r\n                            {{member.pointsEarnedCurrentMonth | toLocalString}}\r\n                        </h2>\r\n                        <p mee-paragraph="para2" ng-if="member.isActiveUser">{{$ctrl.cmsData.strings["points-earned-this-month"]}}</p>\r\n                        <p mee-paragraph="para2" ng-if="!member.isActiveUser">{{member.errorMessage}}</p>\r\n                        <button mee-button="lightweight"\r\n                                ng-if="member.callToAction && member.isRewardsUser === false && !member.isInvited"\r\n                                id="{{member.callToAction.id}}"\r\n                                ng-click="member.callToAction.callFunction()">\r\n                            {{member.callToAction.text}}\r\n                        </button>\r\n                        <p mee-paragraph="para2" class="margin-top-12 font-italic" ng-if="member.isInvited">{{member.invitationMessage}}</p>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=" fl-part-grow-1">\r\n                    <div ng-if="member.isActiveUser" ng-class="{\'font-weight-bold\' : $ctrl.selectedOption === $ctrl.availableBalance}" class="margin-top-24 pointContainer margin-right-24">\r\n                        <i class="mee-icon icon mee-icon-RewardsLogo"></i>\r\n                        <div class="contentContainer">\r\n                            <p mee-paragraph="para2">{{member.availableBalance | toLocalString}}</p>\r\n                            <p mee-paragraph="para2" class="opacity-60">{{$ctrl.cmsData.strings["available-points"]}}</p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class="fl-part-grow-1">\r\n                    <div ng-if="member.isActiveUser" ng-class="{\'font-weight-bold\' : $ctrl.selectedOption === $ctrl.lifetimeBalance}" class="margin-top-24 pointContainer margin-right-24">\r\n                        <i class="mee-icon icon mee-icon-Silver"></i>\r\n                        <div class="contentContainer">\r\n                            <p mee-paragraph="para2">{{member.lifetimeBalance | toLocalString}}</p>\r\n                            <p mee-paragraph="para2" class="opacity-60">{{$ctrl.cmsData.strings["lifetime-points"]}}</p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div data-grid="col-12" class="activePointsRequest" ng-if="member.hasExistingPointsRequest">\r\n                    <mee-card-group data-grid="col-12">\r\n                        <mee-card data-grid="col-12" ng-class="{\'f-noninteractive\': member.isCurrentUser}">\r\n                            <card-content data-grid="col-12" class="fl-cardContent">\r\n                                <div class="fl-part-one">\r\n                                    <mee-safe-image src="$ctrl.coinImageSource"></mee-safe-image>\r\n                                </div>\r\n                                <div class="fl-part-two x-hidden-vp1 x-hidden-vp2"></div>\r\n                                <div class="fl-part-grow-2">\r\n                                    <p data-grid="col-12">{{ member.pointsRequestMessage }}</p>\r\n                                </div>\r\n                                <div class="fl-part-grow-1" ng-if="!member.isCurrentUser">\r\n                                    <a ui-sref="family.GiftPoint({beneficiaryId: {{ member.puid }} })" data-bi-id="rx-gift-points" mee-button="primary">{{$ctrl.cmsData.strings["rp-give-points-button-text"]}}</a>\r\n                                </div>\r\n                            </card-content>\r\n                        </mee-card>\r\n                    </mee-card-group>\r\n                </div>\r\n                \r\n            </div>\r\n\r\n            <div class="familyList addMember margin-bottom-36 x-hidden-vp1" ng-if="$ctrl.isAddMemberEnabled">\r\n                <div data-grid="col-2" class="personaContainer">\r\n                    <div class="contentContainer">\r\n                        <a tabindex="0"\r\n                           ng-href={{$ctrl.cmsData.links["add-family-url"].url}}\r\n                           data-bi-id="rx-add-member-link"\r\n                           id="rx-add-member-link"\r\n                           class="width-match-parent link">\r\n                            <div class="iconContainer margin-bottom-18">\r\n                                <i class="mee-icon bigIcon icon mee-icon-AddCircle"></i>\r\n                            </div>\r\n                            <span class="addMemberContainer">{{$ctrl.cmsData.strings["add-a-family-member"]}}</span>\r\n                        </a>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class="familyList addMember margin-top-36 margin-bottom-36 x-hidden-vp2 x-hidden-vp3 x-hidden-vp4 x-hidden-vp5" ng-if="$ctrl.isAddMemberEnabled">\r\n                <div data-grid="col-2" class="personaContainer">\r\n                    <div>\r\n                        <i class="mee-icon bigIcon icon mee-icon-AddCircle"></i>\r\n                    </div>\r\n                    <div class="margin-top-15">\r\n                        <a mee-call-to-action="lightweight"\r\n                           tabindex="0"\r\n                           ng-href={{$ctrl.cmsData.links["add-family-url"].url}}\r\n                           data-bi-id="rx-add-member-link"\r\n                           id="rx-add-member-link"\r\n                           class="width-match-parent">\r\n                            {{$ctrl.cmsData.strings["add-a-family-member"]}}\r\n                        </a>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <p mee-caption="caption1" ng-class="{\'margin-top-36\': !$ctrl.isAddMemberEnabled}" class="margin-bottom-36">{{$ctrl.cmsData.strings["legal-limit-disclosure"]}}</p>\r\n    </div>\r\n</section>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Family/GiftPoint/gift-point.html",'<div id="gift-point" data-grid="col-12" role="alertdialog" aria-labelledby="title" class="text-align-center" tabindex="-1">\r\n    <h4 mee-heading="heading" class="text-left-align mainTitle">{{$ctrl.currentState.title}}</h4>\r\n    <p mee-caption="caption1" class="text-left-align description">{{$ctrl.currentState.description}}</p>\r\n    <div class="dialog-content" ng-class="{\'no-content\': !$ctrl.currentState.familyMembers && !$ctrl.currentState.beneficiary}">\r\n        <div ng-if="$ctrl.currentState.familyMembers" class="childrenContainer">\r\n            <div class="overLay"></div>\r\n            <mee-card-group mee-auto-focus>\r\n                <mee-card ng-repeat="member in $ctrl.currentState.familyMembers"\r\n                          data-grid="col-{{$ctrl.currentState.familyMembers.length === 3 ? \'6\' : \'12\'}}"\r\n                          class="margin-bottom-36"\r\n                          ng-class="{\'singleChild\': $ctrl.currentState.familyMembers.length === 1}">\r\n                    <card-content>\r\n                        <div>\r\n                            <mee-persona size="persona1">\r\n                                <persona-image>\r\n                                    <img mee-image="round"\r\n                                         ng-src="{{member.profileImageUrl}}"\r\n                                         ng-if="!!member.profileImageUrl && !member.isProfilePictureLoadingError"\r\n                                         data-mee-onerror\r\n                                         data-error-callback="$ctrl.onProfilePictureLoadingError(member)" />\r\n                                </persona-image>\r\n                            </mee-persona>\r\n                            <div class="contentContainer">\r\n                                <h4 mee-heading="subheading" class="margin-top-15 x-hidden-vp1">{{member.displayName}}</h4>\r\n                                <h4 mee-heading="heading" class="margin-top-15">{{member.availableBalance | toLocalString}}</h4>\r\n                                <p mee-paragraph="para4">{{$ctrl.cmsData.strings["available-points"]}}</p>\r\n                                <button mee-button="lightweight"\r\n                                        class="ellipsis width-match-parent"\r\n                                        id="giftPoints_{{member.firstName}}"\r\n                                        ng-click="$ctrl.onSelectBeneficiary(member)"\r\n                                        ng-if="member.callToAction">\r\n                                    {{member.callToAction.text}}\r\n                                </button>\r\n                                <p mee-caption="caption1" class="margin-top-12 margin-right-10 margin-left-10" ng-if="member.errorMessage">{{member.errorMessage}}</p>\r\n                            </div>\r\n                        </div>\r\n                    </card-content>\r\n                </mee-card>\r\n            </mee-card-group>\r\n        </div>\r\n        <div ng-if="$ctrl.currentState.beneficiary" data-grid="col-12" class="twinChildren margin-top-48">\r\n            <div data-grid="col-5" ng-if="$ctrl.currentState.sender" class="margin-bottom-24 sender">\r\n                <mee-persona size="persona1">\r\n                    <persona-image>\r\n                        <img mee-image="round"\r\n                             ng-src="{{$ctrl.currentState.sender.profileImageUrl}}"\r\n                             ng-if="!!$ctrl.currentState.sender.profileImageUrl && !$ctrl.currentState.sender.isProfilePictureLoadingError"\r\n                             data-mee-onerror\r\n                             data-error-callback="$ctrl.onProfilePictureLoadingError($ctrl.currentState.sender)" />\r\n                    </persona-image>\r\n                </mee-persona>\r\n                <div class="contentContainer">\r\n                    <h4 mee-heading="heading" class="margin-top-24" ng-if="!$ctrl.currentState.giftedPoints">\r\n                        {{$ctrl.currentState.sender.availableBalance | toLocalString}}\r\n                    </h4>\r\n                    <h4 mee-heading="heading" class="margin-top-24" ng-if="$ctrl.currentState.giftedPoints">\r\n                        <mee-rewards-counter-animation from="$ctrl.currentState.sender.availableBalance"\r\n                                                       to="$ctrl.currentState.sender.availableBalance - $ctrl.currentState.giftedPoints" />\r\n                    </h4>\r\n                    <p mee-paragraph="para4">{{$ctrl.cmsData.strings["available-points"]}}</p>\r\n                </div>\r\n            </div>\r\n            <div data-grid="col-2" class="text-align-center x-hidden-vp1" ng-if="$ctrl.currentState.animation && $ctrl.currentState.animationStartFrame">\r\n                <mee-rewards-animation data="$ctrl.currentState.animation"\r\n                                       class="transferPointIcon"\r\n                                       start-frame="$ctrl.currentState.animationStartFrame"\r\n                                       end-frame="$ctrl.currentState.animationEndFrame" />\r\n            </div>\r\n            <div data-grid="col-5" class="margin-bottom-36 margin-right-15 beneficiary" ng-class="{\'singleChildren\': !$ctrl.currentState.sender}">\r\n                <mee-persona size="persona1">\r\n                    <persona-image>\r\n                        <img mee-image="round"\r\n                             ng-src="{{$ctrl.currentState.beneficiary.profileImageUrl}}"\r\n                             ng-if="!!$ctrl.currentState.beneficiary.profileImageUrl && !$ctrl.currentState.beneficiary.isProfilePictureLoadingError"\r\n                             data-mee-onerror\r\n                             data-error-callback="$ctrl.onProfilePictureLoadingError($ctrl.currentState.beneficiary)" />\r\n                    </persona-image>\r\n                </mee-persona>\r\n                <div class="contentContainer">\r\n                    <h4 mee-heading="heading" class="margin-top-24" ng-if="!$ctrl.currentState.giftedPoints">\r\n                        {{$ctrl.currentState.beneficiary.availableBalance | toLocalString}}\r\n                    </h4>\r\n                    <h4 mee-heading="heading" class="margin-top-24" ng-if="$ctrl.currentState.giftedPoints">\r\n                        <mee-rewards-counter-animation from="$ctrl.currentState.beneficiary.availableBalance"\r\n                                                       to="$ctrl.currentState.beneficiary.availableBalance + $ctrl.currentState.giftedPoints" />\r\n                    </h4>\r\n                    <p mee-paragraph="para4">{{$ctrl.cmsData.strings["available-points"]}} </p>\r\n                </div>\r\n                <mee-rewards-animation data="$ctrl.currentState.animation" ng-if="$ctrl.currentState.animation && !$ctrl.currentState.animationStartFrame" />\r\n            </div>\r\n            <div ng-if="$ctrl.currentState.inputTitle" class="display-inline-block">\r\n                <label mee-label for="giftedPoints">{{$ctrl.currentState.inputTitle}}</label>\r\n                <input mee-text-input\r\n                       type="number"\r\n                       ng-model="$ctrl.giftedPoints"\r\n                       name="giftedPoints"\r\n                       ng-change="$ctrl.onInputChange()"\r\n                       ng-keypress="$ctrl.onKeyPress($event)"\r\n                       ng-class="{\'input-error\': $ctrl.currentState.errorMessage}"\r\n                       aria-label="giftedPoints"\r\n                       required\r\n                       mee-auto-focus />\r\n            </div>\r\n        </div>\r\n        <div data-grid="col-12" class="margin-top-5" ng-if="$ctrl.currentState.errorMessage">\r\n            <mee-error-message-mwf data-error-text="{{$ctrl.currentState.errorMessage}}" />\r\n        </div>\r\n        <div data-grid="col-12" class="margin-top-5" ng-if="$ctrl.isGiftInProgress">\r\n            <mee-progress-ants-mwf kind="local large" class="margin-horizontal-auto"></mee-progress-ants-mwf>\r\n        </div>\r\n        <div data-grid="col-12" class="actionLink" ng-if="$ctrl.currentState.nextButton">\r\n            <button data-grid="col-5"\r\n                    class="float-left"\r\n                    id="backButton"\r\n                    ng-disabled="$ctrl.isGiftInProgress"\r\n                    mee-button\r\n                    ng-if="$ctrl.currentState.backButton"\r\n                    ng-click="$ctrl.currentState.backButton.callFunction()">\r\n                {{$ctrl.currentState.backButton.text}}\r\n            </button>\r\n            <button data-grid="col-5"\r\n                    ng-class="{\'float-right\': $ctrl.currentState.backButton, \'singleButton\': !$ctrl.currentState.backButton}"\r\n                    id="nextButton"\r\n                    ng-disabled="!$ctrl.canGoToNextState || $ctrl.isGiftInProgress"\r\n                    mee-button="primary"\r\n                    ng-click="$ctrl.currentState.nextButton.callFunction()">\r\n                {{$ctrl.currentState.nextButton.text}}\r\n            </button>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Family/RAF/raf-banner.html",'<div id="rewards-raf-banner">\r\n    <div class="large" ng-if="!$ctrl.small">\r\n        <div class="upsell-text">\r\n            <h1 mee-heading="heading5" class="f-lean" ng-if="$ctrl.hasPoints">\r\n                {{ $ctrl.largeTitle }}\r\n            </h1>\r\n            <p mee-paragraph="para2Lean" ng-if="$ctrl.hasPoints">\r\n                {{ $ctrl.cmsData.strings["community-refer-a-friend-banner-description-line1"] }}\r\n            </p>\r\n            <h1 mee-heading="heading5" class="f-lean" ng-if="!$ctrl.hasPoints">\r\n                {{ $ctrl.cmsData.strings["community-refer-a-friend-banner-title-zero-points"] }}\r\n            </h1>\r\n            <p mee-paragraph="para2Lean" ng-if="!$ctrl.hasPoints">\r\n                {{ $ctrl.cmsData.strings["community-refer-a-friend-banner-desc-zero-points"] }}\r\n            </p>\r\n            <p class="margin-top-12" mee-paragraph ng-if="$ctrl.hasPoints" ng-bind-html="$ctrl.line2Text">\r\n            </p>\r\n            <div>\r\n                <a mee-call-to-action="lightweight" ng-if="$ctrl.hasPoints"\r\n                   id=\'{{$ctrl.cmsData.links["community-refer-a-friend-how-to-earn"].id}}\'\r\n                   ui-sref=\'{{$ctrl.cmsData.links["community-refer-a-friend-how-to-earn"].url}}\'\r\n                   ng-attr-aria-label=\'{{$ctrl.cmsData.links["community-refer-a-friend-how-to-earn"].ariaLabel}}\'\r\n                   data-bi-id=\'{{$ctrl.cmsData.links["community-refer-a-friend-how-to-earn"].id}}\' c