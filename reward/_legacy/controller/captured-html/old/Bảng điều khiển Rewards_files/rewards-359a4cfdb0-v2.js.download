dynamic-img-description">{{item.extBannerDescription ? item.extBannerDescription : item.subtitle}}</p>\r\n                <div ng-if="item.hasCta" class="actionLink">\r\n                    <span class="callToAction-override">{{item.callToAction.text}}</span>\r\n                </div>\r\n            </action-area>\r\n        </mee-hero-item>\r\n        <mee-rewards-debug-info item="item"></mee-rewards-debug-info>\r\n    </a>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/Promotion/promotional-items.html",'<div id="promotional-items">\r\n    <mee-carousel autoplay="{{!$ctrl.dashboardResult.isVisualParityTest}}"\r\n                  interval="6000"\r\n                  toggled-label="{{$ctrl.cmsData.strings[\'pause\']}}"\r\n                  ng-attr-aria-label="{{$ctrl.cmsData.strings[\'play\']}}"\r\n                  ng-if="$ctrl.promotionalItems.length > 1">\r\n        <li ng-repeat="item in $ctrl.promotionalItems track by $index">\r\n            <mee-rewards-promotional-item promotion="item"\r\n                                          cms-data="$ctrl.cmsData"\r\n                                          index="$index">\r\n            </mee-rewards-promotional-item>\r\n        </li>\r\n    </mee-carousel>\r\n    <mee-rewards-promotional-item promotion="$ctrl.promotionalItems[0]"\r\n                                  cms-data="$ctrl.cmsData"\r\n                                  index="0"\r\n                                  ng-if="$ctrl.promotionalItems.length === 1">\r\n    </mee-rewards-promotional-item>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/Promotion/rewards-mbing-banner.html",'<div class="rewards-banner {{bannerStyle.bannerType}}"\r\n     ng-class="{\'ng-hide\': !showBanner}"\r\n     ng-style="{\'top\': bannerStyle.top, \'bottom\': bannerStyle.bottom, \'background-image\': \'url(\' + \'{{bannerStyle.bgLink}}\' + \')\'}"\r\n     ng-click="$ctrl.handleGetNowClick($event)">\r\n    <div class="text-section">\r\n        <div class="text {{bannerStyle.bannerType}}">{{bannerStyle.descText}}</div>\r\n    </div>\r\n    <div class="btn-section">\r\n        <div class="get-now {{bannerStyle.bannerType}}"\r\n             role="button">\r\n            {{bannerStyle.buttonText}}\r\n        </div>\r\n    </div>\r\n    <div class="dismiss-button" \r\n         ng-if="bannerStyle.dismissIconUrl"\r\n         ng-click="$ctrl.handleDismissClick($event)"\r\n    >\r\n        <img ng-src="{{bannerStyle.dismissIconUrl}}" alt="icon" class="dismiss">\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/PunchCards/punch-cards.html",'<h3 mee-heading="heading5" ng-if="$ctrl.punchcardItems.length > 1">{{$ctrl.cmsData.strings[\'punch-cards\']}}</h3>\r\n<div id="punch-cards" class="margin-top-12">\r\n    <mee-carousel autoplay="{{!$ctrl.dashboardResult.isVisualParityTest}}" interval="6000" toggled-label="{{$ctrl.cmsData.strings[\'pause\']}}" ng-attr-aria-label="{{$ctrl.cmsData.strings[\'play\']}}" ng-if="$ctrl.punchcardItems.length > 1">\r\n        <li ng-repeat="item in $ctrl.punchcardItems" mee-rewardable>\r\n            <a class="clickable-link" ng-href="{{item.callToAction.url}}">\r\n                <mee-hero-item horz="left"\r\n                            vert="bottom"\r\n                            context="accessory"\r\n                            theme="dark"\r\n                            aria-label="{{item.title}}, {{item.subtitle}}"\r\n                            data-m=\'{{item.biContentString}}\'>\r\n                    <background-picture>\r\n                        <picture>\r\n                            <source ng-srcset="{{item.backgroundImage.source}}" media="(min-width: 1400px)">\r\n                            <source ng-srcset="{{item.backgroundTabletImage.source}}" media="(min-width:768px)">\r\n                            <source ng-srcset="{{item.backgroundMobileImage.source}}" media="(min-width:0)">\r\n                            <img ng-srcset="{{item.backgroundTabletImage.source}}" ng-src="{{item.backgroundTabletImage.source}}" alt="{{item.backgroundTabletImage.alternateText}}" />\r\n                        </picture>\r\n                    </background-picture>\r\n                    <action-area>\r\n                        <h1 mee-heading="heading" tabindex="0">{{item.title}}</h1>\r\n                        <p mee-heading="subheading" tabindex="0">{{item.subtitle}}</p>\r\n                        <div>\r\n                            <span class="pointLink" ng-if="item.callToAction.text">{{item.callToAction.text}} <i class="mee-icon pull-left icon mee-icon-ChevronRightSmall"></i></span>\r\n                        </div>\r\n                    </action-area>\r\n                    <optional-area>\r\n                        <mee-rewards-check-mark complete="item.itemComplete"></mee-rewards-check-mark>\r\n                    </optional-area>\r\n                </mee-hero-item>\r\n                <mee-rewards-debug-info item="item"></mee-rewards-debug-info>\r\n            </a>\r\n        </li>\r\n    </mee-carousel>\r\n    <mee-hero-item horz="left"\r\n                   vert="bottom"\r\n                   context="accessory"\r\n                   theme="dark"\r\n                   mee-rewardable\r\n                   ng-if="$ctrl.punchcardItems.length === 1"\r\n                   aria-label="{{item.title}}, {{item.subtitle}}"\r\n                   data-m=\'{{item.biContentString}}\'>\r\n        <background-picture>\r\n            <picture>\r\n                <source ng-srcset="{{item.backgroundImage.source}}" media="(min-width: 1400px)">\r\n                <source ng-srcset="{{item.backgroundTabletImage.source}}" media="(min-width:768px)">\r\n                <source ng-srcset="{{item.backgroundMobileImage.source}}" media="(min-width:0)">\r\n                <img ng-srcset="{{item.backgroundTabletImage.source}}" ng-src="{{item.backgroundTabletImage.source}}" alt="{{item.backgroundTabletImage.alternateText}}" />\r\n            </picture>\r\n        </background-picture>\r\n        <action-area>\r\n            <h2 mee-heading="heading">{{item.title}}</h2>\r\n            <p mee-heading="subheading">{{item.subtitle}}</p>\r\n            <div>\r\n                <a mee-call-to-action="lightweight"\r\n                   ng-if="item.callToAction.text"\r\n                   ng-href="{{item.callToAction.url}}">\r\n                    {{item.callToAction.text}}\r\n                </a>\r\n            </div>\r\n        </action-area>\r\n        <optional-area>\r\n            <mee-rewards-check-mark complete="item.itemComplete"></mee-rewards-check-mark>\r\n        </optional-area>\r\n    </mee-hero-item>\r\n    <mee-rewards-debug-info item="item" ng-if="$ctrl.punchcardItems.length === 1"></mee-rewards-debug-info>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/RAF/raf-dashboard-progress.html",'<div class="progressBody">\r\n    <div class="imagecontainer">\r\n        <mee-safe-image alt="$ctrl.cmsData.strings[\'raf-progress-image-alt\']"\r\n                        src="$ctrl.cmsData.strings[\'raf-progress-image\']">\r\n            <p></p>\r\n        </mee-safe-image>\r\n    </div>\r\n    <div class="progressContainer">\r\n        <div class="paracontainer">\r\n            <p mee-paragraph="para2Lean" class="margin-bottom-10 progresstext" ng-bind-html="$ctrl.progressText">\r\n            </p>\r\n            <a mee-call-to-action="lightweight"\r\n               id="{{$ctrl.cmsData.links[\'raf-go-to-howtoearn\'].id}}"\r\n               ng-href="{{$ctrl.cmsData.links[\'raf-go-to-howtoearn\'].url}}"\r\n               ng-attr-aria-label="{{$ctrl.cmsData.links[\'raf-go-to-howtoearn\'].ariaLabel}}"\r\n               data-bi-id="{{$ctrl.cmsData.links[\'raf-go-to-howtoearn\'].id}}"\r\n               class="infoicon cta-trim"\r\n               target="{{$ctrl.cmsData.links[\'raf-go-to-howtoearn\'].target}}">\r\n            </a>\r\n        </div>\r\n        \r\n        <mee-progres