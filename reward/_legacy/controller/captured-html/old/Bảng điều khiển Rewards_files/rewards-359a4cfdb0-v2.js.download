ebatesTransfer-sendButton"\r\n                mee-button\r\n                data-bi-id="rebatesTransfer-sendButton"\r\n                ng-disabled="!$ctrl.canSend"\r\n                ng-if="!$ctrl.hasSent"\r\n                ng-click="$ctrl.sendCode()">\r\n            {{$ctrl.cmsData.strings["transfer-challenge-send"]}}\r\n        </button>\r\n    </div>\r\n    <label mee-label for="code" class="margin-top-24" ng-if="$ctrl.hasSent">\r\n        {{$ctrl.cmsData.strings["transfer-challenge-code"]}}\r\n    </label>\r\n    <div>\r\n        <input mee-text-input\r\n               ng-model="$ctrl.code"\r\n               name="code"\r\n               ng-change="$ctrl.onInputChange()"\r\n               ng-class="{\'input-error\': $ctrl.$meeErrors.getError($ctrl.codeError)}"\r\n               class="code"\r\n               ng-if="$ctrl.hasSent"\r\n               required\r\n               autofocus />\r\n        <span class="timer" ng-if="$ctrl.hasSent && $ctrl.timerMessage">{{$ctrl.timerMessage}}</span>\r\n        <button id="rebatesTransfer-resendButton"\r\n                mee-button\r\n                data-bi-id="rebatesTransfer-sendButton"\r\n                class="lightweight"\r\n                ng-if="$ctrl.hasSent && $ctrl.canSend"\r\n                ng-click="$ctrl.sendCode()">\r\n            {{$ctrl.cmsData.strings["transfer-challenge-resend"]}}\r\n        </button>\r\n    </div>\r\n    <mee-inline-error error-id="{{::$ctrl.codeError}}" ng-if="$ctrl.hasSent"></mee-inline-error>\r\n    <div data-grid="col-12" class="actionLink">\r\n        <button id="rebatesTransfer-backButton"\r\n                mee-button\r\n                data-bi-id="rebatesTransfer-backButton"\r\n                class="back"\r\n                ng-click="$ctrl.back()">\r\n            {{$ctrl.cmsData.strings["transfer-back"]}}\r\n        </button>\r\n        <button class="float-right"\r\n                id="rebatesTransfer-nextButton"\r\n                mee-button="primary"\r\n                dat