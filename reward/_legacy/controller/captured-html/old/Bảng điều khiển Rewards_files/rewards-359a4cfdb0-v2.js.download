}}</a>\r\n    </p>\r\n</div>\r\n\r\n<button mee-action-trigger data-glyph="info" id="{{$ctrl.slides[0].taggedItem}}" ng-click="$ctrl.show()" ng-attr-aria-label="{{$ctrl.cmsData.strings[\'coach-marks\']}}">\r\n    <div data-coachmark-tag="coachMarkStart"></div>\r\n</button>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/DailySet/daily-set-item-content.html",'<div class="text-align-center rewards-card-container min-dimension" mee-rewardable data-bi-id="{{item.biId}}" data-m=\'{{item.biContentString}}\' tabindex="{{$ctrl.getTabIndex($ctrl.item.disabled)}}">\r\n    <a class="ds-card-sec"\r\n       ng-if="$ctrl.item.callToAction.text"\r\n       ng-href="{{item.callToAction.url}}"\r\n       aria-disabled="{{$ctrl.item.disabled}}"\r\n       aria-label="{{$ctrl.itemAriaLabel}}"\r\n       target="{{$ctrl.item.openInNewTab}}"\r\n       role="link">\r\n\r\n        <mee-rewards-points complete="$ctrl.item.complete"\r\n                            points="$ctrl.item.points"\r\n                            locked="$ctrl.item.disabled"\r\n                            cms-data="$ctrl.cmsData"\r\n                            show-progress="$ctrl.item.isWot"\r\n                            point-progress="$ctrl.item.pointProgress"\r\n                            is-exclusive-locked-item="item.exclusiveLockedFeatureCardStatus == \'locked\' && !$ctrl.item.complete">\r\n        </mee-rewards-points>\r\n        <div class="imageContainer" ng-class="{\'x-hidden-vp1\' : $ctrl.item.displayType === \'single\' && !$ctrl.areaConfig.isMobileViewModeEnabled}">\r\n            <mee-rewards-animation data="$ctrl.item.icon" ng-if="$ctrl.item.icon.source && !$ctrl.item.disabled"></mee-rewards-animation>\r\n            <mee-rewards-animation data="$ctrl.item.icon" ng-if="$ctrl.item.icon.source && $ctrl.item.disabled" start-frame="1" end-frame="1"></mee-rewards-animation>\r\n        </div>\r\n        <div class="contentContainer">\r\n            <h3 mee-heading="heading" ng-class="{\'ellipsis\': !$ctrl.isDenseDashboard()}">{{$ctrl.item.title}}</h3>\r\n            <p mee-paragraph="para4" ng-class="{\'compact\' : $ctrl.item.isWot && ($ctrl.item.pointProgress > 0 || $ctrl.item.complete)}">{{$ctrl.item.subtitle}}</p>\r\n            <p ng-if="$ctrl.item.isWot && $ctrl.item.pointProgress > 0 && !$ctrl.item.complete" mee-paragraph="para4" class="incomplete">\r\n                {{$ctrl.quizIncompleteMessage}}\r\n            </p>\r\n            <p ng-if="$ctrl.item.isWot && $ctrl.item.complete" mee-paragraph="para4" class="complete-green-color">\r\n                {{$ctrl.quizCompleteMessage}}\r\n            </p>\r\n            <div class="actionLink x-hidden-vp2 x-hidden-vp3 x-hidden-vp4 x-hidden-vp5" ng-if="$ctrl.areaConfig.isMobileViewModeEnabled ">\r\n                <span class="pointLink" ng-if="item.exclusiveLockedFeatureCardStatus != \'locked\' || item.complete">\r\n                    {{$ctrl.item.callToAction.text}} >\r\n                </span>\r\n                <span id="locked_required_text"\r\n                      ng-class="{\'pointLink\': item.destinationUrl != \'\', \'disableLink\': item.destinationUrl == \'\'}"\r\n                      ng-if="item.exclusiveLockedFeatureCardStatus == \'locked\' && !item.complete">\r\n                    {{$ctrl.item.exclusiveLockedFeatureCardDesc}}\r\n                </span>\r\n            </div>\r\n            <div class="actionLink x-hidden-vp1" ng-if="$ctrl.isDenseDashboard()">\r\n                <span class="pointLink" ng-if="item.exclusiveLockedFeatureCardStatus != \'locked\' || item.complete">\r\n                    {{$ctrl.item.callToAction.text}} >\r\n                </span>\r\n                <span id="locked_required_text"\r\n                      ng-class="{\'pointLink\': item.destinationUrl != \'\', \'disableLink\': item.destinationUrl == \'\'}"\r\n                      ng-if="item.exclusiveLockedFeatureCardStatus == \'locked\' && !item.complete">\r\n                    {{$ctrl.item.exclusiveLockedFeatureCardDesc}}\r\n                </span>\r\n            </div>\r\n        </div>\r\n        <div class="actionLink" ng-class="{\'x-hidden-vp1\' : $ctrl.areaConfig.isMobileViewModeEnabled}" ng-hide="$ctrl.isDenseDashboard()">\r\n            <span class="pointLink" ng-if="item.exclusiveLockedFeatureCardStatus != \'locked\' || item.complete">\r\n                {{$ctrl.item.callToAction.text}} >\r\n            </span>\r\n            <span id="locked_required_text"\r\n                  ng-class="{\'pointLink\': item.destinationUrl != \'\', \'disableLink\': item.destinationUrl == \'\'}"\r\n                  ng-if="item.exclusiveLockedFeatureCardStatus == \'locked\' && !item.complete">\r\n                {{$ctrl.item.exclusiveLockedFeatureCardDesc}}\r\n            </span>\r\n        </div>\r\n        <div class="locked_tooltip" ng-if="$ctrl.areaConfig.flights.dSetLockTTEnabled && item.exclusiveLockedFeatureCardStatus == \'locked\' && !$ctrl.item.complete">\r\n            <span>{{$ctrl.item.exclusiveLockedTooltipDesc}}</span>\r\n        </div>\r\n        <mee-rewards-debug-info item="$ctrl.item"></mee-rewards-debug-info>\r\n    </a>\r\n\r\n    <mee-safe-image alt="{{item.exclusiveLockedFeatureCardStatus == \'locked\' ? $ctrl.cmsData.strings[\'locked-img-alt\'] : $ctrl.cmsData.strings[\'unlocked-img-alt\']}}"\r\n                    src="item.secondaryIcon"\r\n                    class="card-banner-locked locked_img"\r\n                    ng-if="item.exclusiveLockedFeatureCategory != \'\' && item.exclusiveLockedFeatureCardStatus != \'notsupported\' && item.secondaryIcon != null && !$ctrl.item.complete">\r\n        <p></p>\r\n    </mee-safe-image>\r\n    <div ng-if="item.exclusiveLockedFeatureCardStatus == \'locked\' && !$ctrl.item.complete" id="exclusiveOverlay" class="exclusiveOverlay"></div>\r\n\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/DailySet/daily-set-section.html",'<div id="daily-sets">\r\n    <h3 mee-heading="heading5" class="display-inline-block" ng-class="{\'f-lean\': $ctrl.isDenseDashboard()}">{{$ctrl.cmsData.strings["daily-set"]}}</h3>\r\n    <div class="machine-trans" ng-if="$ctrl.componentAvailabilityMap[\'machineTranslation\']">\r\n        <mee-safe-image class="text-icon" alt="$ctrl.cmsData.strings[\'machineTrans-icon-text\']"\r\n                        src="$ctrl.cmsData.strings[\'machineTrans-icon-url\']">\r\n        </mee-safe-image>\r\n        <span>{{$ctrl.cmsData.strings["machine-tranlation-hint"]}}</span>\r\n    </div>\r\n    <mee-rewards-coach-marks class="display-inline-block"\r\n                             coach-marks="$ctrl.dashboardResult.coachMarks.streaks"\r\n                             slides="$ctrl.dashboardResult.coachMarks.streaks.slides"\r\n                             cms-data="$ctrl.cmsData"\r\n                             ng-if="$ctrl.componentAvailabilityMap[\'coachMarks\']"\r\n                             trigger-bi-id="rx-streaks-coachmarks">\r\n    </mee-rewards-coach-marks>\r\n    <div class="streakProtectionMode" id="balanceToolTipDiv" ng-if=\'$ctrl.areaConfig.flights["streakProtection"]\'>\r\n        <div id="spToggleInDS" class="sptoggle">\r\n            <mee-rewards-toggle toggle-id="streakprotection"\r\n                                is-toggle-on="$ctrl.isToggleOn"\r\n                                cms-data="$ctrl.cmsData"\r\n                                toggle-log-id="$ctrl.toggleLogId"\r\n                                toggle-text="$ctrl.toggleText()"\r\n                                aria-label="$ctrl.getStreakProtectionTitle()"\r\n                                on-click="$ctrl.handleOnToggleClick()">\r\n            </mee-rewards-toggle>\r\n        </div>\r\n        <p class="sp_title" title="{{$ctrl.getStreakProtectionTitle()}}">{{$ctrl.getStreakProtectionTitle()}}</p>\r\n        <div class="sptooltip" ng-click="$ctrl.openStreakProtectionTooltip($event, $ctrl.spTooltipId)">\r\n            <mee-rewards-tooltip id="$ctrl.spTooltipId"\r\n                                 tooltip-id="$ctrl.spTooltipId"\r\n                                 tooltip-description="$ctrl.spTooltipDescription"\r\n                                 cms-data="$ctrl.cmsData">\r\n            </mee-rewards-tooltip>\r\n        </div>\r\n    </div>\r\n    <div data-coachmark-tag="dailySets"></div>\r\n    <div data-coachmark-tag="dailySetItem1"></div>\r\n    <button mee-button="lightweight"\r\n            class="previous float-left"\r\n            tabindex="0"\r\n            data-bi-id="rx-daily-set-previous"\r\n            ng-disabled="$ctrl.currentIndex === 0"\r\n            ng-click="$ctrl.flipBy(-1)"\r\n            ng-if="$ctrl.dailySets.length > 1">\r\n        <span class="pcView">{{$ctrl.cmsData.strings["go-back"]}}</span>\r\n        <span class="mobileView today">{{$ctrl.cmsData.strings["go-back-mobile"]}}</span>\r\n    </button>\r\n    <button mee-button="lightweight"\r\n            class="next float-right"\r\n            tabindex="0"\r\n            data-bi-id="rx-daily-set-next"\r\n            ng-disabled="$ctrl.currentIndex === $ctrl.dailySets.length - 1"\r\n            ng-click="$ctrl.flipBy(1)"\r\n            ng-if="$ctrl.dailySets.length > 1">\r\n        <span class="pcView">{{$ctrl.cmsData.strings["sneak-peek"]}}</span>\r\n        <span class="mobileView text-right-align">{{$ctrl.cmsData.strings["sneak-peek-mobile"]}}</span>\r\n    </button>\r\n\r\n    <mee-card-group ng-hide="$ctrl.currentIndex !== 0" ng-if="$ctrl.dailySets.length > 0" ng-class="{\'mobileViewMode\' : $ctrl.areaConfig.isMobileViewModeEnabled}">\r\n        <mee-card ng-if="$ctrl.dailySets[0].length > 0" display-type="{{$ctrl.dailySets[0][0].displayType}}" ng-disabled="$ctrl.dailySets[0][0].disabled">\r\n            <card-content>\r\n                <mee-rewards-daily-set-item-content item="$ctrl.dailySets[0][0]" cms-data="$ctrl.cmsData" />\r\n            </card-content>\r\n        </mee-card>\r\n        <mee-card ng-if="$ctrl.dailySets[0].length > 1" display-type="{{$ctrl.dailySets[0][1].displayType}}" ng-disabled="$ctrl.dailySets[0][1].disabled">\r\n            <card-content>\r\n                <mee-rewards-daily-set-item-content item="$ctrl.dailySets[0][1]" cms-data="$ctrl.cmsData" />\r\n            </card-content>\r\n        </mee-card>\r\n        <mee-card ng-if="$ctrl.dailySets[0].length > 2" display-type="{{$ctrl.dailySets[0][2].displayType}}" ng-disabled="$ctrl.dailySets[0][2].disabled">\r\n            <card-content>\r\n                <mee-rewards-daily-set-item-content item="$ctrl.dailySets[0][2]" cms-data="$ctrl.cmsData" />\r\n            </card-content>\r\n        </mee-card>\r\n    </mee-card-group>\r\n\r\n    <mee-card-group ng-hide="$ctrl.currentIndex === 0" ng-if="$ctrl.dailySets.length > 0" ng-class="{\'mobileViewMode\' : $ctrl.areaConfig.isMobileViewModeEnabled}">\r\n        <mee-card display-type="{{$ctrl.dailySets[1][0].displayType}}" ng-disabled="$ctrl.dailySets[1][0].disabled">\r\n            <card-content>\r\n                <mee-rewards-daily-set-item-content item="$ctrl.dailySets[1][0]" cms-data="$ctrl.cmsData" />\r\n            </card-content>\r\n        </mee-card>\r\n        <mee-card display-type="{{$ctrl.dailySets[1][1].displayType}}" ng-disabled="$ctrl.dailySets[1][1].disabled">\r\n            <card-content>\r\n                <mee-rewards-daily-set-item-content item="$ctrl.dailySets[1][1]" cms-data="$ctrl.cmsData" />\r\n            </card-content>\r\n        </mee-card>\r\n        <mee-card display-type="{{$ctrl.dailySets[1][2].displayType}}" ng-disabled="$ctrl.dailySets[1][2].disabled">\r\n            <card-content>\r\n                <mee-rewards-daily-set-item-content item="$ctrl.dailySets[1][2]" cms-data="$ctrl.cmsData" />\r\n            </card-content>\r\n        </mee-card>\r\n    </mee-card-group>\r\n\r\n    <mee-rewards-streak streak-promotion="$ctrl.dashboardResult.streakPromotion"\r\n                        streak-bonus-promotions="$ctrl.dashboardResult.streakBonusPromotions"\r\n        