  <mee-rewards-ugc-cta-button on-open-modal="$ctrl.onOpenModal()"></mee-rewards-ugc-cta-button>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/UserGeneratedContent/ugc-coin-decorations.html",'<div ng-class="\'ugc-coin-decorations--\' + $ctrl.variant" aria-hidden="true">\r\n    <div class="ugc-coin-decoration ugc-orange-coin"\r\n         ng-style="{\'background-image\': \'url(\' + $ctrl.areaConfig.ugcConfig.orangeCoinIconUrl + \')\'}"\r\n         role="presentation">\r\n    </div>\r\n    <div class="ugc-coin-decoration ugc-blue-coin"\r\n         ng-style="{\'background-image\': \'url(\' + $ctrl.areaConfig.ugcConfig.blueCoinIconUrl + \')\'}"\r\n         role="presentation">\r\n    </div>\r\n    <div class="ugc-coin-decoration ugc-red-coin"\r\n         ng-style="{\'background-image\': \'url(\' + $ctrl.areaConfig.ugcConfig.redCoinIconUrl + \')\'}"\r\n         role="presentation">\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/UserGeneratedContent/ugc-cta-button.html",'<div class="ugc-cta-button {{ $ctrl.isNewExp ? \'ugc-cta-newexp\' : \'\' }}">\r\n    \x3c!-- Show sweeps ended message when sweepstakes has ended --\x3e\r\n    <div ng-if="$ctrl.isUgcSweepsEnded" class="sweeps-ended-message">\r\n        <span>{{ $ctrl.ugcSweepsEndedMessage }}</span>\r\n    </div>\r\n\r\n    \x3c!-- Active sweepstakes content --\x3e\r\n    <div ng-if="!$ctrl.isUgcSweepsEnded && !$ctrl.isNewExp">\r\n        \x3c!-- Show status message when entry is pending or approved --\x3e\r\n        <mee-rewards-ugc-status-message \r\n            ng-if="($ctrl.isEntryPending || $ctrl.isEntryApproved) && !$ctrl.currentUser.isAnonymous"\r\n            status-type="{{ $ctrl.isEntryPending ? \'pending\' : \'approved\' }}">\r\n        </mee-rewards-ugc-status-message>\r\n\r\n        \x3c!-- Show submit button with tooltip icon when rejected or default state --\x3e\r\n        <div ng-if="!$ctrl.isEntryPending && !$ctrl.isEntryApproved && !$ctrl.currentUser.isAnonymous"\r\n            class="button-with-tooltip">\r\n            <button class="submit-button"\r\n                    type="button"\r\n                    ng-click="$ctrl.openSubmitUgcModal()">\r\n                <span class="button-text">{{ $ctrl.ctaSubmitVideoText }}</span>\r\n            </button>\r\n\r\n            \x3c!-- Info tooltip icon for rejected state --\x3e\r\n            <mee-rewards-ugc-status-message\r\n                ng-if="$ctrl.isEntryRejected"\r\n                status-type="rejected">\r\n            </mee-rewards-ugc-status-message>\r\n        </div>\r\n\r\n        \x3c!-- Sign in link for anonymous users --\x3e\r\n        <a class="submit-button"\r\n            target="_self"\r\n            ng-href="{{$ctrl.signinUrl}}"\r\n            ng-if="$ctrl.currentUser.isAnonymous">\r\n            <span class="button-text">{{ $ctrl.ctaSigninText }}</span>\r\n        </a>\r\n        <div class="disclaimer" ng-if="$ctrl.currentUser.isAnonymous" ng-bind-html="$ctrl.signinDisclaimerText"></div>\r\n    </div>\r\n\r\n    \x3c!-- NEWEXP: Optimized CTA with enhanced copy and visual hierarchy --\x3e\r\n    <div ng-if="!$ctrl.isUgcSweepsEnded && $ctrl.isNewExp" class="newexp-cta-wrapper">\r\n        \x3c!-- Status messages for submitted entries --\x3e\r\n        <mee-rewards-ugc-status-message\r\n            ng-if="($ctrl.isEntryPending || $ctrl.isEntryApproved) && !$ctrl.currentUser.isAnonymous"\r\n            status-type="{{ $ctrl.isEntryPending ? \'pending\' : \'approved\' }}">\r\n        </mee-rewards-ugc-status-message>\r\n\r\n        \x3c!-- Primary CTA for submission --\x3e\r\n        <div ng-if="!$ctrl.isEntryPending && !$ctrl.isEntryApproved && !$ctrl.currentUser.isAnonymous"\r\n                class="newexp-button-container">\r\n            <div class="newexp-button-with-tooltip">\r\n                <button class="newexp-submit-button"\r\n                        type="button"\r\n                        ng-click="$ctrl.openSubmitUgcModal()">\r\n                    <span class="button-icon">🎥</span>\r\n                    <span class="button-text">{{ $ctrl.getNewExpCtaText() }}</span>\r\n                </button>\r\n\r\n                <mee-rewards-ugc-status-message\r\n                    ng-if="$ctrl.isEntryRejected"\r\n                    status-type="rejected">\r\n                </mee-rewards-ugc-status-message>\r\n            </div>\r\n            <p class="newexp-effort-text">{{ $ctrl.getEffortText() }}</p>\r\n        </div>\r\n\r\n        \x3c!-- Sign in CTA for anonymous users --\x3e\r\n        <div ng-if="$ctrl.currentUser.isAnonymous" class="newexp-signin-container">\r\n            <a class="newexp-submit-button"\r\n                target="_self"\r\n                ng-href="{{$ctrl.signinUrl}}">\r\n                <span class="button-text">{{ $ctrl.ugcCmsData.strings["newexp_cta_signin"] }}</span>\r\n            </a>\r\n            <div class="disclaimer" ng-bind-html="$ctrl.signinDisclaimerText"></div>\r\n        </div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/UserGeneratedContent/ugc-footer.html",'<div class="ugc-footer" data-name="Footer">\r\n    <div class="footer-container">\r\n        <p class="disclaimer-text" ng-bind-html="$ctrl.ugcCmsData.strings[\'ugc_footer\']"></p>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/UserGeneratedContent/ugc-hero-banner.html",'<div class="ugc-hero-banner" ng-class="{\'ugc-hero-newexp\': $ctrl.isNewExp}">\r\n    <div class="hero-container">\r\n        <div class="content-section" ng-if="!$ctrl.isNewExp">\r\n            \x3c!-- OLDEXP: Original layout --\x3e\r\n            <div class="gradient-title">\r\n                <img ng-src="{{ $ctrl.heroBannerTitleImgUrl }}" alt="" role="presentation" class="title-image" />\r\n            </div>\r\n            <img ng-if="!$ctrl.isMobile" class="hero-image-inline" ng-src="{{ $ctrl.heroBannerMobileImgUrl }}" alt="" role="presentation" />\r\n            <p class="description">\r\n                {{ $ctrl.heroBannerDescription }}\r\n            </p>\r\n            <mee-rewards-ugc-cta-button on-open-modal="$ctrl.onOpenModal()"></mee-rewards-ugc-cta-button>\r\n        </div>\r\n\r\n        <div class="content-section" ng-if="$ctrl.isNewExp">\r\n            \x3c!-- NEWEXP: Optimized conversion-focused layout --\x3e\r\n            <div ng-if="$ctrl.isNewExp" class="newexp-content">\r\n                <div class="newexp-prize-badge" role="status" aria-label="Prize value">\r\n                    <span class="prize-amount">{{ $ctrl.ugcCmsData.strings["newexp_hero_prize_badge"] }}</span>\r\n                </div>\r\n                <h1 class="newexp-headline">\r\n                    {{ $ctrl.ugcCmsData.strings["newexp_hero_headline"] }}\r\n                </h1>\r\n                <p class="newexp-subheadline">\r\n                    {{ $ctrl.ugcCmsData.strings["newexp_hero_subheadline"] }}\r\n                </p>\r\n                <div class="newexp-cta-section">\r\n                    <mee-rewards-ugc-cta-button on-open-modal="$ctrl.onOpenModal()"></mee-rewards-ugc-cta-button>\r\n                    <p class="newexp-trust-signal">\r\n                        <i class="mee-icon mee-icon-Completed" aria-hidden="true"></i>\r\n                        <span>{{ $ctrl.getSubmissionCountText() }}</span>\r\n                    </p>\r\n                </div>\r\n                <img ng-if="!$ctrl.isMobile" class="hero-image-inline" ng-src="{{ $ctrl.heroBannerMobileImgUrl }}" alt="" role="presentation" />\r\n            </div>\r\n        </div>\r\n        <div class="hero-image-section" aria-hidden="true">\r\n            <img ng-src="{{ $ctrl.heroBannerDesktopImgUrl }}" alt="" class="hero-image" role="presentation" />\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/UserGeneratedContent/ugc-rewards-upsell.html",'<div class="ugc-rewards-upsell">\r\n    <div class="container">\r\n        <div class="subtitle">{{ $ctrl.ugcCmsData.strings["section_winners"] }}</div>\r\n        <h2 class="main-title">{{ $ctrl.ugcCmsData.strings["what_would_you_do"] }}</h2>\r\n\r\n        <div class="content-section">\r\n            <div class="illustration-section">\r\n                <img ng-src="{{ $ctrl.areaConfig.ugcConfig.upsellImgUrl }}" alt="{{ $ctrl.ugcCmsData.strings["alt_text_rewards_prizes_illustration_image"] }}" class="illustration-image" />\r\n            </div>\r\n\r\n            <div class="info-section">\r\n                <div class="info-item">\r\n                    <h3 class="info-title">{{ $ctrl.ugcCmsData.strings["popular_gift_card"] }}</h3>\r\n                    <p class="info-description">\r\n                        {{ $ctrl.ugcCmsData.strings["use_your_point_for_multiple_gift_card"] }}\r\n                    </p>\r\n                    <a href="https://rewards.bing.com/redeem/shop?form=ML2XAV&OCID=ML2XAV&PUBL=RewardsDO&CREA=ML2XAV" target="_blank" class="link-text">{{ $ctrl.ugcCmsData.strings["explore_gift_cards"] }}</a>\r\n                </div>\r\n\r\n                <div class="info-item">\r\n                    <h3 class="info-title">{{ $ctrl.ugcCmsData.strings["exclusive_sweepstakes"] }}</h3>\r\n                    <p class="info-description">\r\n                        {{ $ctrl.ugcCmsData.strings["boost_your_chances"] }}\r\n                    </p>\r\n                    <a href="https://rewards.bing.com/redeem/win?form=ML2XAW&OCID=ML2XAW&PUBL=RewardsDO&CREA=ML2XAW" target="_blank" class="link-text">{{ $ctrl.ugcCmsData.strings["see_current_sweeps"] }}</a>\r\n                </div>\r\n\r\n                <div class="info-item">\r\n                    <h3 class="info-title">{{ $ctrl.ugcCmsData.strings["give_back"] }}</h3>\r\n                    <p class="info-description">\r\n                        {{ $ctrl.ugcCmsData.strings["did_you_know_you_can_donate"] }}\r\n                    </p>\r\n                    <a href="https://rewards.bing.com/redeem/donate?form=ML2XAX&OCID=ML2XAX&PUBL=RewardsDO&CREA=ML2XAX" target="_blank" class="link-text">{{ $ctrl.ugcCmsData.strings["select_a_cause"] }}</a>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/UserGeneratedContent/ugc-status-message.html",'\x3c!-- Full status bar for pending and approved states --\x3e\r\n<div ng-if="$ctrl.statusType === \'pending\' || $ctrl.statusType === \'approved\'"\r\n     class="ugc-status-message" \r\n     ng-class="{\r\n         \'pending\': $ctrl.statusType === \'pending\',\r\n         \'approved\': $ctrl.statusType === \'approved\'\r\n     }"\r\n     role="status"\r\n     aria-live="polite">\r\n    <div class="status-icon-container">\r\n        \x3c!-- Use image for pending state tooltip icon --\x3e\r\n        <img ng-if="$ctrl.statusType === \'pending\'" \r\n             src="mockimages/iconbtn.png" \r\n             alt="Info" \r\n             class="status-icon-img"\r\n             aria-describedby="pending-tooltip" />\r\n        \r\n        \x3c!-- Green checkmark icon for approved state --\x3e\r\n        <svg ng-if="$ctrl.statusType === \'approved\'" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">\r\n            <circle cx="10" cy="10" r="10" fill="currentColor"/>\r\n            <path d="M14.5 7L8.5 13L5.5 10" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>\r\n        </svg>\r\n        \r\n        \x3c!-- Tooltip for pending state (shows on hover of image) --\x3e\r\n        <div ng-if="$ctrl.statusType === \'pending\'"\r\n             ng-bind-html="$ctrl.tooltipText"\r\n             id="pending-tooltip"\r\n             class="status-tooltip" \r\n             role="tooltip">\r\n        </div>\r\n    </div>\r\n    \r\n    <div class="status-content">\r\n        <p class="status-text">{{ $ctrl.messageText }}</p>\r\n    </div>\r\n</div>\r\n\r\n\x3c!-- Icon-only mode for rejected state (used after button) --\x3e\r\n<div ng-if="$ctrl.statusType === \'rejected\'" \r\n     class="rejected-tooltip-container">\r\n    <img src="mockimages/iconbtn.png" \r\n         alt="Info" \r\n         class="rejected-tooltip-icon"\r\n         aria-describedby="rejected-tooltip" />\r\n    <div id="rejected-tooltip"\r\n         ng-bind-html="$ctrl.tooltipText"\r\n         class="rejected-tooltip" \r\n         role="tooltip">\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/UserGeneratedContent/ugc-submit.html",'\x3c!-- Submit UGC Modal Wrapper --\x3e\r\n<div class="ugc-submit-modal">\r\n    \x3c!-- Modal Overlay --\x3e\r\n    <div class="ugc-modal-overlay"\r\n         ng-if="$ctrl.showModal"\r\n         role="dialog"\r\n         aria-modal="true"\r\n         aria-labelledby="modal-title"\r\n         aria-describedby="modal-description">\r\n\r\n        \x3c!-- Modal Container --\x3e\r\n        <div class="ugc-modal-container" ng-click="$event.stopPropagation()">\r\n            \x3c!-- Modal Content --\x3e\r\n            <div class="ugc-modal-content">\r\n                \x3c!-- Close Button --\x3e\r\n                <button class="ugc-modal-close"\r\n                        ng-click="$ctrl.closeModal()"\r\n                        type="button"\r\n                        aria-label="{{ $ctrl.ugcCmsData.strings[\'close_modal\'] }}"\r\n                        tabindex="0">\r\n                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">\r\n                        <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />\r\n                    </svg>\r\n                </button>\r\n\r\n                \x3c!-- Form Content --\x3e\r\n                <div class="ugc-modal-form">\r\n                    \x3c!-- Title --\x3e\r\n                    <div class="ugc-modal-title">\r\n                        <h2 id="modal-title">\r\n                            <div class="title-main">{{ $ctrl.ugcCmsData.strings[\'microsoft_rewards_million_point_challenge\'] }}</div>\r\n                            <div class="title-sub">{{ $ctrl.ugcCmsData.strings[\'entry_form\'] }}</div>\r\n                        </h2>\r\n                        <div id="modal-description" class="sr-only">\r\n                            {{ $ctrl.ugcCmsData.strings[\'entry_form\'] }} for {{ $ctrl.ugcCmsData.strings[\'microsoft_rewards_million_point_challenge\'] }}\r\n                        </div>\r\n                    </div>\r\n\r\n                    \x3c!-- Form Fields --\x3e\r\n                    <form class="ugc-form"\r\n                          ng-submit="$ctrl.submitForm()"\r\n                          role="form"\r\n                          aria-labelledby="modal-title"\r\n                          novalidate>\r\n\r\n                        \x3c!-- General Error Message --\x3e\r\n                        <div class="ugc-form-error"\r\n                             ng-if="$ctrl.formErrors.general"\r\n                             role="alert"\r\n                             aria-live="assertive"\r\n                             aria-atomic="true"\r\n                             tabindex="-1"\r\n                             ng-bind-html="$ctrl.formErrors.general"\r\n                             id="ugc-general-error">\r\n                        </div>\r\n\r\n                        \x3c!-- Social Handle Field --\x3e\r\n                        <div class="ugc-form-field">\r\n                            <label for="socialHandle" class="ugc-form-label">\r\n                                {{ $ctrl.ugcCmsData.strings[\'your_social_handle\'] }}\r\n                                <span class="required" aria-label="required">*</span>\r\n                            </label>\r\n                            <input type="text"\r\n                                   id="socialHandle"\r\n                                   name="socialHandle"\r\n                                   class="ugc-form-input"\r\n                                   ng-class="{ \'error\': $ctrl.formErrors.socialHandle }"\r\n                                   ng-model="$ctrl.formData.socialHandle"\r\n                                   ng-change="$ctrl.updateField(\'socialHandle\', $ctrl.formData.socialHandle)"\r\n                                   placeholder="{{ $ctrl.ugcCmsData.strings[\'social_handle_placeholder\'] }}"\r\n                                   ng-attr-aria-describedby="{{ $ctrl.formErrors.socialHandle ? \'socialHandle-error\' : undefined }}"\r\n                                   aria-invalid="{{ !!$ctrl.formErrors.socialHandle }}"\r\n                                   aria-required="true"\r\n                                   autocomplete="username"\r\n                                   required>\r\n                            <div id="socialHandle-error"\r\n                                 class="ugc-field-error"\r\n                                 ng-if="$ctrl.formErrors.socialHandle"\r\n                                 role="alert"\r\n                                 aria-live="polite"\r\n                                 aria-atomic="true">\r\n                                {{ $ctrl.formErrors.socialHandle }}\r\n                            </div>\r\n                        </div>\r\n\r\n                        \x3c!-- Video Link Field --\x3e\r\n                        <div class="ugc-form-field">\r\n                            <label for="videoLink" class="ugc-form-label">\r\n                                {{ $ctrl.ugcCmsData.strings[\'your_video_link\'] }}\r\n                                <span class="required" aria-label="required">*</span>\r\n                            </label>\r\n                            <input type="url"\r\n                                   id="videoLink"\r\n                                   name="videoLink"\r\n                                   class="ugc-form-input"\r\n                                   ng-class="{ \'error\': $ctrl.formErrors.videoLink }"\r\n                                   ng-model="$ctrl.formData.videoLink"\r\n                                   ng-change="$ctrl.updateField(\'videoLink\', $ctrl.formData.videoLink)"\r\n                                   placeholder="{{ $ctrl.ugcCmsData.strings[\'video_link_placeholder\'] }}"\r\n                                   ng-attr-aria-describedby="{{ $ctrl.formErrors.videoLink ? \'videoLink-error\' : undefined }}"\r\n                                   aria-invalid="{{ !!$ctrl.formErrors.videoLink }}"\r\n                                   aria-required="true"\r\n                                   autocomplete="url"\r\n                                   required>\r\n                            <div id="videoLink-error"\r\n                                 class="ugc-field-error"\r\n                                 ng-if="$ctrl.formErrors.videoLink"\r\n                                 role="alert"\r\n                                 aria-live="polite"\r\n                                 aria-atomic="true">\r\n                                {{ $ctrl.formErrors.videoLink }}\r\n                            </div>\r\n                        </div>\r\n\r\n                        \x3c!-- Checkboxes --\x3e\r\n                        <fieldset class="ugc-form-checkbox-group" role="group" aria-labelledby="confirmations-legend">\r\n                            <legend id="confirmations-legend" class="sr-only">Required confirmations</legend>\r\n\r\n                            <div class="ugc-form-checkbox">\r\n                                <input type="checkbox"\r\n                                       id="hashtagCheck"\r\n                                       name="hashtagCheck"\r\n                                       ng-model="$ctrl.formData.isHashTagConfirmed"\r\n                                       ng-change="$ctrl.updateField(\'isHashTagConfirmed\', $ctrl.formData.isHashTagConfirmed)"\r\n                                       ng-attr-aria-describedby="{{ $ctrl.formErrors.isHashTagConfirmed ? \'hashtagCheck-error\' : undefined }}"\r\n                                       aria-invalid="{{ !!$ctrl.formErrors.isHashTagConfirmed }}"\r\n                                       aria-required="true"\r\n                                       required>\r\n                                <label for="hashtagCheck" ng-class="{ \'error\': $ctrl.formErrors.isHashTagConfirmed }">\r\n                                    {{ $ctrl.confirmHastagText }}\r\n                                    <span class="required" aria-label="required">*</span>\r\n                                </label>\r\n                                <div id="hashtagCheck-error"\r\n                                     class="ugc-field-error"\r\n                                     ng-if="$ctrl.formErrors.isHashTagConfirmed"\r\n                                     role="alert"\r\n                                     aria-live="polite"\r\n                                     aria-atomic="true">\r\n                                    {{ $ctrl.formErrors.isHashTagConfirmed }}\r\n                                </div>\r\n                            </div>\r\n\r\n                            <div class="ugc-form-checkbox">\r\n                                <input type="checkbox"\r\n                                       id="termsCheck"\r\n                                       name="termsCheck"\r\n                                       ng-model="$ctrl.formData.isTermsConfirmed"\r\n                                       ng-change="$ctrl.updateField(\'isTermsConfirmed\', $ctrl.formData.isTermsConfirmed)"\r\n                                       ng-attr-aria-describedby="{{ $ctrl.formErrors.isTermsConfirmed ? \'termsCheck-error\' : undefined }}"\r\n                                       aria-invalid="{{ !!$ctrl.formErrors.isTermsConfirmed }}"\r\n                                       aria-required="true"\r\n                                       required>\r\n                                <label for="termsCheck" ng-class="{ \'error\': $ctrl.formErrors.isTermsConfirmed }">\r\n                                    {{ $ctrl.ugcCmsData.strings[\'terms_confirmation\'] }}\r\n                                    <span class="required" aria-label="required">*</span>\r\n                                </label>\r\n                                <div id="termsCheck-error"\r\n                                     class="ugc-field-error"\r\n                                     ng-if="$ctrl.formErrors.isTermsConfirmed"\r\n                                     role="alert"\r\n                                     aria-live="polite"\r\n                                     aria-atomic="true">\r\n                                    {{ $ctrl.formErrors.isTermsConfirmed }}\r\n                                </div>\r\n                            </div>\r\n\r\n                            <div class="ugc-form-checkbox">\r\n                                <input type="checkbox"\r\n                                       id="rulesCheck"\r\n                                       name="rulesCheck"\r\n                                       ng-model="$ctrl.formData.isRulesConfirmed"\r\n                                       ng-change="$ctrl.updateField(\'rulesConfirm\', $ctrl.formData.isRulesConfirmed)"\r\n                                       ng-attr-aria-describedby="{{ $ctrl.formErrors.isRulesConfirmed ? \'rulesCheck-error\' : undefined }}"\r\n                                       aria-invalid="{{ !!$ctrl.formErrors.isRulesConfirmed }}"\r\n                                       aria-required="true"\r\n                                       required>\r\n                                <label for="rulesCheck" ng-bind-html="$ctrl.ugcCmsData.strings[\'rules_confirmation\']" ng-class="{ \'error\': $ctrl.formErrors.isRulesConfirmed }">\r\n                                    <span class="required" aria-label="required">*</span>\r\n                                </label>\r\n                                <div id="rulesCheck-error"\r\n                                     class="ugc-field-error"\r\n                                     ng-if="$ctrl.formErrors.isRulesConfirmed"\r\n                                     role="alert"\r\n                                     aria-live="polite"\r\n                                     aria-atomic="true">\r\n                                    {{ $ctrl.formErrors.isRulesConfirmed }}\r\n                                </div>\r\n                            </div>\r\n                        </fieldset>\r\n\r\n                        \x3c!-- Submit Button --\x3e\r\n                        <button type="submit"\r\n                                class="ugc-form-submit"\r\n                                ng-disabled="!$ctrl.isFormValid() || $ctrl.isSubmitting"\r\n                                ng-attr-aria-describedby="{{ $ctrl.isSubmitting ? \'submit-status\' : undefined }}">\r\n                            <span ng-if="!$ctrl.isSubmitting">{{ $ctrl.ugcCmsData.strings[\'submit_your_video\'] }}</span>\r\n                            <span ng-if="$ctrl.isSubmitting" aria-live="polite">{{ $ctrl.ugcCmsData.strings[\'submitting\'] }}</span>\r\n                        </button>\r\n                        <div id="submit-status" class="sr-only" ng-if="$ctrl.isSubmitting" role="status" aria-live="polite" aria-atomic="true">\r\n                            Form is being submitted, please wait.\r\n                        </div>\r\n                    </form>\r\n                </div>\r\n            </div>\r\n\r\n            \x3c!-- Decorative Elements --\x3e\r\n            <div class="ugc-modal-decoration ugc-blue-coin"\r\n                 ng-style="{\'background-image\': \'url(\' + $ctrl.areaConfig.ugcConfig.blueCoinIconUrl + \')\'}"\r\n                 aria-hidden="true"></div>\r\n            <div class="ugc-modal-decoration ugc-red-coin"\r\n                 ng-style="{\'background-image\': \'url(\' + $ctrl.areaConfig.ugcConfig.redCoinIconUrl + \')\'}"\r\n                 aria-hidden="true"></div>\r\n        </div>\r\n    </div>\r\n\r\n    \x3c!-- Success Modal Component --\x3e\r\n    <mee-rewards-ugc-success-modal is-open="$ctrl.showSuccessModal"\r\n                                                      on-close="$ctrl.closeSuccessModal()">\r\n    </mee-rewards-ugc-success-modal>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/UserGeneratedContent/ugc-success-modal.html",'\x3c!-- Success Modal Overlay --\x3e\r\n<div class="ugc-modal-overlay ugc-success"\r\n     ng-if="$ctrl.isOpen"\r\n     ng-click="$ctrl.close()"\r\n     role="dialog"\r\n     aria-modal="true"\r\n     aria-labelledby="ugc-success-heading">\r\n    <div class="ugc-modal-container" ng-click="$event.stopPropagation()">\r\n        <div class="ugc-modal-content ugc-success-content">\r\n            \x3c!-- Close Button --\x3e\r\n            <button class="ugc-modal-close"\r\n                    ng-click="$ctrl.close()"\r\n                    type="button"\r\n                    aria-label="{{ $ctrl.cmsData.strings[\'close_modal\'] }}"\r\n                    tabindex="0">\r\n                <svg class="ugc-icon-close" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">\r\n                    <path d="M18 6L6 18M6 6L18 18" />\r\n                </svg>\r\n            </button>\r\n            \x3c!-- Success Content --\x3e\r\n            <div class="ugc-success-text-container">\r\n                <div class="ugc-success-subtitle">{{ $ctrl.cmsData.strings[\'microsoft_rewards_million_point_challenge\'] }}</div>\r\n                <h2 id="ugc-success-heading" tabindex="-1">\r\n                    {{ $ctrl.cmsData.strings[\'ugc_success_pending_heading\'] }}\r\n                </h2>\r\n                <p class="ugc-success-body" ng-bind-html="$ctrl.successPendingBody1Str"></p>\r\n                <p class="ugc-success-body" ng-bind-html="$ctrl.cmsData.strings[\'ugc_success_pending_body2\']"></p>\r\n                <a href="/" class="ugc-success-dashboard-link">\r\n                    {{ $ctrl.cmsData.strings[\'ugc_success_visit_dashboard_now\'] }}\r\n                </a>\r\n            </div>\r\n        </div>\r\n        \x3c!-- Decorative Coin Elements for Success Modal --\x3e\r\n        <div class="ugc-modal-decoration ugc-blue-coin"\r\n             ng-style="{\'background-image\': \'url(\' + $ctrl.areaConfig.ugcConfig.blueCoinIconUrl + \')\'}"\r\n             aria-hidden="true"></div>\r\n        <div class="ugc-modal-decoration ugc-red-coin"\r\n             ng-style="{\'background-image\': \'url(\' + $ctrl.areaConfig.ugcConfig.redCoinIconUrl + \')\'}"\r\n             aria-hidden="true"></div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/UserGeneratedContent/ugc-video-creation-steps.html",'<div class="ugc-video-creation-steps" ng-class="{\'ugc-steps-newexp\': $ctrl.isNewExp}">\r\n    <div class="container">\r\n        <h2 id="participation-steps" class="main-title" ng-if="!$ctrl.isNewExp">{{ $ctrl.ugcCmsData.strings["section_ready_set_record"] }}</h2>\r\n\r\n        <ol ng-if="!$ctrl.isNewExp" class="steps-list" aria-labelledby="participation-steps">\r\n            <li class="step-item">\r\n                <img ng-src="{{ $ctrl.areaConfig.ugcConfig.cameraIconUrl }}" alt="" class="card-icon" role="presentation" />\r\n                <h3 class="card-title">{{ $ctrl.stepOneHeader }}</h3>\r\n                <p class="card-description" ng-bind-html="$ctrl.ugcCmsData.strings[\'description_create_a_video_with_rewards_love\']"></p>\r\n            </li>\r\n\r\n            <li class="step-item">\r\n                <img ng-src="{{ $ctrl.areaConfig.ugcConfig.megaphoneLoudIconUrl }}" alt="" class="card-icon" role="presentation" />\r\n                <h3 class="card-title">{{ $ctrl.ugcCmsData.strings["header_share_your_video_on_social_media"] }}</h3>\r\n                <p class="card-description" ng-bind-html="$ctrl.stepTwoDecription"></p>\r\n            </li>\r\n\r\n            <li class="step-item">\r\n                <img ng-src="{{ $ctrl.areaConfig.ugcConfig.rewardsMedallionIconUrl }}" alt="" class="card-icon" role="presentation" />\r\n                <h3 class="card-title">{{ $ctrl.ugcCmsData.strings["header_your_chance_to_win"] }}</h3>\r\n                <p class="card-description">\r\n                    {{ $ctrl.ugcCmsData.strings["description_your_chance_to_win"] }}\r\n                </p>\r\n            </li>\r\n\r\n            <li class="step-item">\r\n                <img ng-src="{{ $ctrl.areaConfig.ugcConfig.faceBlowingKissIconUrl }}" alt="" class="card-icon" role="presentation" />\r\n                <h3 class="card-title">{{ $ctrl.ugcCmsData.strings["header_want_to_earn_more_points"] }}</h3>\r\n                <p class="card-description">\r\n                    {{ $ctrl.ugcCmsData.strings["description_header_want_to_earn_more_points"] }}\r\n                </p>\r\n                <div class="referral-section" role="group" aria-labelledby="referral-heading">\r\n                    <div id="referral-heading" class="sr-only">{{ $ctrl.ugcCmsData.strings["share_referral_link"] }}</div>\r\n                    <div class="url-display" role="textbox" aria-readonly="true" aria-label="{{ $ctrl.ugcCmsData.strings["your_referral_link"] }}">\r\n                        <span class="url-text" ng-click="$ctrl.onCopyClick($event)" ng-if="$ctrl.referrerLink">{{$ctrl.referrerLink}}</span>\r\n                        <span class="url-text" ng-if="!$ctrl.referrerLink">{{ $ctrl.ugcCmsData.strings[\'loading_referral_link\'] || \'...\' }}</span>\r\n                    </div>\r\n                    <button class="copy-button" type="button"\r\n                            ng-click="$ctrl.onCopyClick($event)"\r\n                            ng-disabled="!$ctrl.referrerLink"\r\n                            aria-label="{{ $ctrl.ugcCmsData.strings[\'copy_referral_link_to_clipboard\'] || \'Copy referral link to clipboard\' }}"\r\n                            aria-describedby="copy-status">\r\n                        <i role="presentation" aria-hidden="true" class="mee-icon mee-icon-Copy"></i>\r\n                        <span class="copy-toast" ng-class="{\'show\': $ctrl.showCopyToast}">\r\n                            {{ $ctrl.ugcCmsData.strings["copied"] }}\r\n                        </span>\r\n                    </button>\r\n                    <div id="copy-status" class="sr-only" role="status" aria-live="polite" aria-atomic="true">{{$ctrl.copyText}}</div>\r\n                    <button class="share-button" type="button" ng-click="$ctrl.onShareClick()" ng-disabled="!$ctrl.referrerLink">\r\n                        {{ $ctrl.ugcCmsData.strings["share"] }}\r\n                    </button>\r\n                </div>\r\n            </li>\r\n        </ol>\r\n\r\n        \x3c!-- NEWEXP: Simplified flow with trust signals and referral --\x3e\r\n        <div ng-if="$ctrl.isNewExp" class="newexp-steps">\r\n            <div class="newexp-steps-header">\r\n                <h2 class="newexp-main-title">{{ $ctrl.ugcCmsData.strings["newexp_steps_title"] }}</h2>\r\n                <p class="newexp-subtitle">{{ $ctrl.ugcCmsData.strings["newexp_steps_subtitle"] }}</p>\r\n            </div>\r\n\r\n            <ol class="newexp-steps-list" aria-label="How to enter sweepstakes">\r\n                <li class="newexp-step-item">\r\n                    <div class="step-number" aria-label="Step 1">1</div>\r\n                    <div class="step-content">\r\n                        <h3 class="step-title">{{ $ctrl.ugcCmsData.strings["newexp_step1_title"] }}</h3>\r\n                        <p class="step-description">{{ $ctrl.ugcCmsData.strings["newexp_step1_description"] }} <a href="https://promos.microsoftrewards.com/US/en/SS/98/Rules" target="_blank" rel="noopener noreferrer" class="rules-link" aria-label="View official sweepstakes rules">{{ $ctrl.ugcCmsData.strings["newexp_step1_official_rules_text"] }}</a></p>\r\n                        <div class="step-trust-signal">\r\n                            <i class="mee-icon mee-icon-Completed" aria-hidden="true"></i>\r\n                            <span>{{ $ctrl.ugcCmsData.strings["newexp_step1_trust_signal"] }}</span>\r\n                        </div>\r\n                    </div>\r\n                </li>\r\n\r\n                <li class="newexp-step-item">\r\n                    <div class="step-number" aria-label="Step 2">2</div>\r\n                    <div class="step-content">\r\n                        <h3 class="step-title">{{ $ctrl.ugcCmsData.strings["newexp_step2_title"] }} {{ $ctrl.campaignHashtag }}</h3>\r\n                        <p class="step-description">{{ $ctrl.ugcCmsData.strings["newexp_step2_description"] }} <strong>{{ $ctrl.campaignHashtag }} #Sweepstakes</strong></p>\r\n                        <div class="step-trust-signal">\r\n                            <i class="mee-icon mee-icon-Globe" aria-hidden="true"></i>\r\n                            <span>{{ $ctrl.ugcCmsData.strings["newexp_step2_trust_signal"] }}</span>\r\n                        </div>\r\n                    </div>\r\n                </li>\r\n\r\n                <li class="newexp-step-item">\r\n                    <div class="step-number" aria-label="Step 3">3</div>\r\n                    <div class="step-content">\r\n                        <h3 class="step-title">{{ $ctrl.ugcCmsData.strings["newexp_step3_title"] }}</h3>\r\n                        <p class="step-description">{{ $ctrl.ugcCmsData.strings["newexp_step3_description"] }}</p>\r\n                        <div class="step-trust-signal">\r\n                            <i class="mee-icon mee-icon-Clock" aria-hidden="true"></i>\r\n                            <span>{{ $ctrl.ugcCmsData.strings["newexp_step3_trust_signal"] }}</span>\r\n                        </div>\r\n                    </div>\r\n                </li>\r\n\r\n                <li class="newexp-step-item newexp-step-referral">\r\n                    <div class="step-content">\r\n                        <h3 class="step-title">{{ $ctrl.ugcCmsData.strings["header_want_to_earn_more_points"] }}</h3>\r\n                        <p class="step-description">{{ $ctrl.ugcCmsData.strings["description_header_want_to_earn_more_points"] }}</p>\r\n                        <div class="referral-section" role="group" aria-labelledby="referral-heading-newexp">\r\n                            <div id="referral-heading-newexp" class="sr-only">{{ $ctrl.ugcCmsData.strings["share_referral_link"] }}</div>\r\n                            <div class="url-display" role="textbox" aria-readonly="true" aria-label="{{ $ctrl.ugcCmsData.strings["your_referral_link"] }}">\r\n                                <span class="url-text" ng-click="$ctrl.onCopyClick($event)" ng-if="$ctrl.referrerLink">{{$ctrl.referrerLink}}</span>\r\n                                <span class="url-text" ng-if="!$ctrl.referrerLink">{{ $ctrl.ugcCmsData.strings[\'loading_referral_link\'] || \'...\' }}</span>\r\n                            </div>\r\n                            <button class="copy-button" type="button"\r\n                                    ng-click="$ctrl.onCopyClick($event)"\r\n                                    ng-disabled="!$ctrl.referrerLink"\r\n                                    aria-label="{{ $ctrl.ugcCmsData.strings[\'copy_referral_link_to_clipboard\'] || \'Copy referral link to clipboard\' }}"\r\n                                    aria-describedby="copy-status-newexp">\r\n                                <i role="presentation" aria-hidden="true" class="mee-icon mee-icon-Copy"></i>\r\n                                <span class="copy-toast" ng-class="{\'show\': $ctrl.showCopyToast}">\r\n                                    {{ $ctrl.ugcCmsData.strings["copied"] }}\r\n                                </span>\r\n                            </button>\r\n                            <div id="copy-status-newexp" class="sr-only" role="status" aria-live="polite" aria-atomic="true">{{$ctrl.copyText}}</div>\r\n                            <button class="share-button" type="button" ng-click="$ctrl.onShareClick()" ng-disabled="!$ctrl.referrerLink">\r\n                                {{ $ctrl.ugcCmsData.strings["share"] }}\r\n                            </button>\r\n                        </div>\r\n                    </div>\r\n                </li>\r\n            </ol>\r\n\r\n            \x3c!-- Urgency and reward highlight --\x3e\r\n            <div class="newexp-steps-footer">\r\n                <div class="footer-highlight" role="complementary" aria-label="Bonus rewards information">\r\n                    <span class="highlight-icon" aria-hidden="true">⚡</span>\r\n                    <div class="highlight-text">\r\n                        <strong>{{ $ctrl.ugcCmsData.strings["newexp_bonus_title"] }}</strong> {{ $ctrl.ugcCmsData.strings["newexp_bonus_description"] }}\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/UserGeneratedContent/ugc-video-gallery.html",'<section class="ugc-video-gallery" \r\n         ng-if="$ctrl.videoGalleryItems && $ctrl.videoGalleryItems.length > 0"\r\n         aria-labelledby="video-gallery-title">\r\n    <div class="gallery-container">\r\n        <div class="deco-container" aria-hidden="true">\r\n            <mee-rewards-ugc-coin-decorations variant="content">\r\n            </mee-rewards-ugc-coin-decorations>\r\n        </div>\r\n\r\n        <div class="gallery-header">\r\n            <p class="gallery-subtitle">\r\n                {{ $ctrl.ugcCmsData.strings[\'feel_the_love\'] }}\r\n            </p>\r\n            <h2 id="video-gallery-title" class="gallery-title">\r\n                {{ $ctrl.ugcCmsData.strings[\'check_out_what_people_are_saying\'] }}\r\n            </h2>\r\n        </div>\r\n\r\n        <div id="video-gallery-grid" class="gallery-grid" role="list" aria-label="{{ $ctrl.ugcCmsData.strings[\'user_generated_content_videos_list\'] }}">\r\n            <div class="gallery-row" ng-repeat="row in $ctrl.videoGalleryRows track by $index">\r\n                <article class="video-card" \r\n                         role="listitem"\r\n                         ng-repeat="item in row track by item.id">\r\n                    <div class="video-card-inner"\r\n                         ng-click="$ctrl.onVideoClick(item)"\r\n                         role="button"\r\n                         tabindex="0"\r\n                         ng-keydown="($event.keyCode === 13 || $event.keyCode === 32) && $ctrl.onVideoClick(item, $event)"\r\n                         aria-label="{{ ($ctrl.ugcCmsData.strings[\'watch_video_number\'] || \'Play video NUMBER\').replace(\'NUMBER\', item.id) }}"\r\n                         aria-describedby="video-instructions">\r\n                        <div class="video-media">\r\n                            <div class="video-thumbnail-wrapper">\r\n                                <img ng-src="{{ item.thumbnailUrl }}" \r\n                                     alt="" \r\n                                     class="video-thumbnail"\r\n                                     role="presentation" />\r\n                            </div>\r\n                        </div>\r\n                        <div class="video-body">\r\n                            <div class="video-content">\r\n                                <div class="video-play-button" aria-hidden="true">\r\n                                    <span class="play-icon-wrapper">\r\n                                        <svg class="play-icon" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" focusable="false">\r\n                                            <path d="M4.66675 2.83329C4.66675 2.39721 5.13628 2.12471 5.50008 2.34471L12.5001 6.51142C12.8639 6.73142 12.8639 7.26854 12.5001 7.48854L5.50008 11.6552C5.13628 11.8752 4.66675 11.6027 4.66675 11.1667V2.83329Z" fill="currentColor" />\r\n                                        </svg>\r\n                                    </span>\r\n                                    <span class="play-button-text">{{ $ctrl.ugcCmsData.strings[\'watch_here\'] }}</span>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </article>\r\n            </div>\r\n        </div>\r\n        \r\n        <div id="video-instructions" class="sr-only">\r\n            {{ $ctrl.ugcCmsData.strings[\'videos_screen_readers_instructions\'] }}\r\n        </div>\r\n\r\n        <div class="gallery-actions" ng-if="$ctrl.showSeeMoreButton || $ctrl.showSeeLessButton">\r\n            <button type="button"\r\n                    class="see-more-button"\r\n                    ng-if="$ctrl.showSeeMoreButton"\r\n                    ng-click="$ctrl.onSeeMoreClick()"\r\n                    aria-label="{{ $ctrl.getSeeMoreAriaLabel() }}"\r\n                    aria-controls="video-gallery-grid">\r\n                {{ $ctrl.ugcCmsData.strings[\'see_more\'] }}\r\n            </button>\r\n            <button type="button"\r\n                    class="see-more-button"\r\n                    ng-if="$ctrl.showSeeLessButton"\r\n                    ng-click="$ctrl.onSeeLessClick()"\r\n                    aria-label="{{ $ctrl.ugcCmsData.strings[\'show_less\'] }}"\r\n                    aria-controls="video-gallery-grid">\r\n                {{ $ctrl.ugcCmsData.strings[\'show_less\'] }}\r\n            </button>\r\n        </div>\r\n        \r\n        <div role="status" \r\n             aria-live="polite" \r\n             aria-atomic="true" \r\n             class="sr-only">\r\n            <span ng-if="!$ctrl.showSeeMoreButton && $ctrl.videoGalleryItems.length > $ctrl.videosPerRow">\r\n                {{ $ctrl.getAllVideosShownMessage() }}\r\n            </span>\r\n        </div>\r\n    </div>\r\n\r\n    \x3c!-- Video Modal --\x3e\r\n    <div class="video-modal" \r\n         ng-if="$ctrl.isModalOpen"\r\n         ng-click="$ctrl.onModalBackdropClick($event)"\r\n         ng-keydown="$ctrl.onModalKeyDown($event)"\r\n         role="dialog"\r\n         aria-modal="true"\r\n         aria-labelledby="modal-video-title"\r\n         tabindex="-1">\r\n        <div class="video-modal-content">\r\n            <button type="button" \r\n                    class="video-modal-close"\r\n                    ng-click="$ctrl.closeVideoModal()"\r\n                    aria-label="Close video"\r\n                    tabindex="0">\r\n                <svg class="close-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" focusable="false">\r\n                    <path d="M4.21 4.387l.083-.094a1 1 0 011.32-.083l.094.083L12 10.585l6.293-6.292a1 1 0 111.414 1.414L13.415 12l6.292 6.293a1 1 0 01-1.414 1.414L12 13.415l-6.293 6.292a1 1 0 01-1.414-1.414L10.585 12 4.293 5.707a1 1 0 01-.083-1.32l.083-.094-.083.094z" fill="currentColor"/>\r\n                </svg>\r\n            </button>\r\n            <div class="video-modal-wrapper">\r\n                <h2 id="modal-video-title" class="sr-only">{{ $ctrl.ugcCmsData.strings[\'video_player\'] }}</h2>\r\n                <video class="video-modal-player"\r\n                       ng-src="{{ $ctrl.currentVideo.videoUrl }}"\r\n                       controls\r\n                       autoplay\r\n                       aria-label="Video content">\r\n                    {{ $ctrl.ugcCmsData.strings[\'your_browser_does_not_support\'] }}\r\n                </video>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</section>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/UserGeneratedContent/ugc.html",'<div id="oneUiUgc">\r\n    <mee-rewards-pop-up promotion="$ctrl.popUpPromotion"\r\n                    is-confetti-visible="false"\r\n                    content-header="$ctrl.getPopUpHeader()"\r\n                    content-title="$ctrl.getPopUpTitle()"\r\n                    content-description="$ctrl.getPopUpDesp()"\r\n                    on-click="$ctrl.handlePopUpBtnClick()"\r\n                    hide-primary-button="$ctrl.hidePrimaryButton">\r\n    </mee-rewards-pop-up>\r\n\r\n    <div class="svg-banner-wrapper">\r\n        <svg class="ugc-background-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1599 1025" preserveAspectRatio="none">\r\n            <defs>\r\n                <linearGradient id="ugcGradient" x1="235.446" y1="233.637" x2="1544.33" y2="829.826" gradientUnits="userSpaceOnUse">\r\n                    <stop stop-color="#FFD49A" />\r\n                    <stop offset="1" stop-color="#D49CFF" />\r\n                </linearGradient>\r\n            </defs>\r\n            <path d="M-2.48193 0.298828H1602.14V1025C1602.14 1025 1347.49 937.275 791.117 937.275C234.74 937.275 -2.48193 1025 -2.48193 1025V0.298828Z"\r\n                  fill="url(#ugcGradient)" fill-opacity="0.4" />\r\n        </svg>\r\n        <mee-rewards-ugc-hero-banner on-open-modal="$ctrl.openSubmitUgcModal()">\r\n        </mee-rewards-ugc-hero-banner>\r\n\r\n        <mee-rewards-ugc-video-creation-steps>\r\n        </mee-rewards-ugc-video-creation-steps>\r\n    </div>\r\n    <div class="rewards-content">\r\n        <mee-rewards-ugc-winners-videos>\r\n        </mee-rewards-ugc-winners-videos>\r\n\r\n        <mee-rewards-ugc-video-gallery>\r\n        </mee-rewards-ugc-video-gallery>\r\n\r\n        <mee-rewards-ugc-rewards-upsell>\r\n        </mee-rewards-ugc-rewards-upsell>\r\n\r\n        <mee-rewards-ugc-bottom-banner on-open-modal="$ctrl.openSubmitUgcModal()">\r\n        </mee-rewards-ugc-bottom-banner>\r\n\r\n        <mee-rewards-ugc-footer>\r\n        </mee-rewards-ugc-footer>\r\n\r\n        \x3c!-- Modal Component --\x3e\r\n        <mee-rewards-ugc-submit on-register="$ctrl.registerSubmitUgcModal(modal)">\r\n        </mee-rewards-ugc-submit>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/Clippy/clippy-component.html",'<div class="clippy-container" ng-if="$ctrl.isVisible">\r\n    <button class="clippy-emoji"\r\n            type="button"\r\n            ng-class="{\'clippy-paused\': !$ctrl.isAnimating}"\r\n            ng-click="$ctrl.onClippyClick()"\r\n            ng-keydown="$ctrl.onClippyKeyDown($event)"\r\n            ng-attr-aria-label="{{$ctrl.cmsData.strings[\'clippy_aria_label\'] || \'Microsoft Clippy Assistant\'}}"\r\n            title="{{$ctrl.cmsData.strings[\'clippy_tooltip\'] || \'Hi! I\\\'m Clippy, your helpful assistant!\'}}">\r\n        \x3c!-- CLippy SVG--\x3e\r\n        <svg width="30.05023"\r\n             height="54.993175"\r\n             viewBox="-10 0 140.20092 219.97269"\r\n             version="1.1"\r\n             id="clippy-svg"\r\n             xml:space="preserve"\r\n             xmlns="http://www.w3.org/2000/svg"\r\n             xmlns:svg="http://www.w3.org/2000/svg">\r\n            <g id="clippy"\r\n               style="display:inline"\r\n               transform="translate(186.40196,-342.56569)">\r\n                <path style="display:inline;opacity:1;mix-blend-mode:normal;fill:none;fill-opacity:1;stroke:#939397;stroke-width:10;stroke-linecap:round;stroke-linejoin:round;stroke-dasharray:none;stroke-opacity:1;paint-order:normal"\r\n                      d="m 336.35185,506.80637 c 0,0 -6.59814,56.08776 20.00585,56.80982 3.19294,0.0867 6.53927,-1.27816 9.23985,-3.81187 8.07538,-7.5764 2.54766,-28.63271 1.57632,-40.1855 -1.06272,-12.63955 -0.48272,-25.3453 1.16817,-39.18801 2.05646,-17.2434 17.6527,-32.98419 14.45169,-50.05222 -2.07054,-11.04029 -10.25354,-21.84418 -20.97258,-25.20235 -10.60171,-3.32141 -23.57814,0.68151 -30.31332,9.51697 -18.60126,24.40181 -24.42929,61.17852 -24.4259,93.52398 7.7e-4,7.31849 