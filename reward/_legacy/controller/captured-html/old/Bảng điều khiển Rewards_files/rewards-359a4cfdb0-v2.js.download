bel}}"\r\n           data-bi-id="{{$ctrl.merchant.callToAction.biId}}">\r\n            {{$ctrl.merchant.callToAction.text}}\r\n        </a>\r\n    </div>\r\n    <h3 mee-heading="heading" class="subtitle margin-top-15">{{$ctrl.cmsData.strings["what-you-will-save"]}}</h3>\r\n    <ul mee-paragraph="para2" class="content">\r\n        <li class="margin-top-18" ng-repeat="category in $ctrl.merchant.categories">\r\n            <img mee-image ng-src="{{$ctrl.cmsData.strings[\'rebates-deals-icon-left\']}}" class="tag" alt="{{category.deal}}" />\r\n            <span class="tag tagText">{{category.deal}}</span>\r\n            <img mee-image ng-src="{{$ctrl.cmsData.strings[\'rebates-deals-icon-right\']}}" class="tag" alt="{{category.deal}}" />\r\n            <span class="margin-left-10"></span>\r\n            <span class="categoryText">{{category.categoryName}}</span>\r\n        </li>\r\n    </ul>\r\n    <p class="margin-top-32 categoryText" ng-bind-html="$ctrl.merchant.exclusions" ng-if="$ctrl.merchant.exclusions"></p>\r\n\r\n    <div class="margin-top-12 rabate-desc-bottom">\r\n        <a mee-call-to-action="primary"\r\n           id="{{$ctrl.merchant.callToAction.id}}"\r\n           href="{{$ctrl.merchant.callToAction.url}}"\r\n           target="{{$ctrl.merchant.callToAction.target}}"\r\n           aria-label="{{$ctrl.merchant.callToAction.ariaLabel}}"\r\n           data-bi-id="{{$ctrl.merchant.callToAction.biId}}">\r\n            {{$ctrl.merchant.callToAction.text}}\r\n        </a>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Rebates/History/rebates-history.html",'<div id="rebates-history">\r\n    <div class="rebate-history-table" ng-if="$ctrl.hasHistory">\r\n        <div class="flexrow headerrow">\r\n            <div class="col1 flexcol header">\r\n                <p> {{ $ctrl.cmsData.strings["rebates-history-order-header"] }}</p>\r\n                <p mee-caption="caption2">\r\n                    <span class="merchant"> {{ $ctrl.cmsData.st