 class="flexColumn"\r\n                           ng-href="{{counter.destinationUrl}}"\r\n                           target="_blank"\r\n                           id="{{counter.title}}"\r\n                           data-bi-id="{{counter.title}}"\r\n                           role="button">\r\n                            <div class="circle">\r\n                                <mee-rewards-circle-progress\r\n                                    size="counter.size"\r\n                                    icon-color="counter.iconColor"\r\n                                    progress="counter.progress"\r\n                                    progress-max="counter.progressMax"\r\n                                    font-icon="counter.fontIcon">\r\n                                </mee-rewards-circle-progress>\r\n                            </div>\r\n                            <div class="pointsDetail">\r\n                                <p mee-caption="caption1" ng-bind-html="counter.pointProgressText"></p>\r\n                            </div>\r\n                        </a>\r\n                    </div>\r\n                    <button id="rewardsDrawer"\r\n                            data-bi-id="rewardsDrawer"\r\n                            mee-button="lightweight"\r\n                            class="c-call-to-action c-glyph"\r\n                            tabindex="0"\r\n                            ng-click="$ctrl.expandFunction()">\r\n                    </button>\r\n                    <div class="availablePoints">\r\n                        <i class="mee-icon icon mee-icon-Heart" aria-hidden="true" ng-if="$ctrl.isGiveEnabled"></i>\r\n                        <span class="balance" ng-if="$ctrl.isGiveEnabled">{{$ctrl.giveBalance}}</span>\r\n                        <i class="mee-icon icon mee-icon-RewardsLogo" aria-hidden="true"></i>\r\n                        <span class="balance">{{$ctrl.availablePoints}}</span>\r\n                    </div>\r\n                </div>\