dashboardResult"\r\n                                                             status-result="$ctrl.statusResult"\r\n                                                             rebates-result="$ctrl.rebatesResult"\r\n                                                             cms-data="$ctrl.cmsData"\r\n                                                             component-type="$ctrl.slotConfiguration[2]" />\r\n                    </div>\r\n\r\n                    <div ng-if="$ctrl.isSlotEnabled(3)" class="info-column" ng-attr-data-grid="{{$ctrl.getDataGridInfoColumn()}}" ng-class="{\'wide-header\': $ctrl.showWideHeader()}">\r\n                        <mee-rewards-user-status-banner-item user-status="$ctrl.userStatus"\r\n                                                             dashboard-result="$ctrl.dashboardResult"\r\n                                                             status-result="$ctrl.statusResult"\r\n                                                             rebates-result="$ctrl.rebatesResult"\r\n                                                             cms-data="$ctrl.cmsData"\r\n                                                             component-type="$ctrl.slotConfiguration[3]" />\r\n                    </div>\r\n\r\n                    <div ng-if="$ctrl.isSlotEnabled(4)" class="info-column" ng-attr-data-grid="{{$ctrl.getDataGridInfoColumn()}}">\r\n                        <mee-rewards-user-status-banner-item user-status="$ctrl.userStatus"\r\n                                                             dashboard-result="$ctrl.dashboardResult"\r\n                                                             status-result="$ctrl.statusResult"\r\n                                                             rebates-result="$ctrl.rebatesResult"\r\n                                                             cms-data="$ctrl.cmsData"\r\n                                                             component-type="$ctrl.slotConfiguration[4