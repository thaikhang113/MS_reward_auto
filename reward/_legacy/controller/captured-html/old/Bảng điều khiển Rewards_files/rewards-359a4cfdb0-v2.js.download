nvite-desc"] }}\r\n                </p>\r\n                <div class="emailsection">\r\n                    <p class="emailHeading" mee-paragraph="para2Lean">\r\n                        {{ $ctrl.cmsData.strings["community-raf-invite-email-heading"] }}\r\n                    </p>\r\n                    <div class="emailBody">\r\n                        <div class="text-container">\r\n                            <div>\r\n                                <button class="email-ids" ng-repeat="email in $ctrl.emailAddressList">\r\n                                    {{email}}\r\n                                    <span class="c-glyph glyph-cancel cancel-email" tabindex="0" ng-click="$ctrl.cancelEmail(email)">\r\n                                    </span>\r\n                                </button>\r\n                            </div>\r\n                            <mee-text-field data-error-id="email.addresses" kind="flex">\r\n                                <label class="x-screen-reader">{{ $ctrl.cmsData.strings["community-raf-invite-email-heading"] }}</label>\r\n                                <input ng-model="$ctrl.emailAddress"\r\n                                       ng-change="$ctrl.ontextchange()"\r\n                                       mee-auto-focus\r\n                                       tabindex="0"\r\n                                       ng-keyup="$ctrl.emailKeyPress($event)" />\r\n                            </mee-text-field>\r\n                            <mee-inline-error error-id="email.addresses"></mee-inline-error>\r\n                        </div>\r\n                    </div>\r\n                    <div class="emailBoxDesc">\r\n                        {{ $ctrl.cmsData.strings["community-raf-invite-emailbox-description"] }}\r\n                    </div>\r\n                    <mee-progress-view watch-operation="sendEmail">\r\n                        <inert-view>\r\n                        </inert-view>\r\n                        <inprogress-view>\r\n                            <div data-grid="col-12" class="margin-top-5">\r\n                                <mee-progress-ants-mwf kind="local" class="margin-horizontal-auto"></mee-progress-ants-mwf>\r\n                            </div>\r\n                        </inprogress-view>\r\n                        <failed-view>\r\n                            <mee-inline-error error-id="email.send"></mee-inline-error>\r\n                        </failed-view>\r\n                        <finished-view>\r\n                            <mee-inline-error error-id="email.send"></mee-inline-error>\r\n                            <p class="emailSuccess" mee-paragraph="para2" ng-if="$ctrl.showEmailSuccessMessage()">\r\n                                {{ $ctrl.cmsData.strings["community-raf-invite-send-email-success"] }}\r\n                            </p>\r\n                        </finished-view>\r\n                    </mee-progress-view>\r\n\r\n                </div>\r\n\r\n                <div class="button-container">\r\n                    <button mee-button="primary" ng-click="$ctrl.sendEmailClick()" mee-progress-disabled="sendEmail" data-bi-id=\'rx-raf-send-invite\'>\r\n                        {{ $ctrl.cmsData.strings["community-raf-invite-sendemailbutton-text"] }}\r\n                    </button>\r\n                </div>\r\n\r\n                <div class="shareLinkContainer">\r\n                    <div class="linksection">\r\n                        <div class="linkBody">\r\n                            <a class="icon-container" ng-click="$ctrl.onCopyClick()" ng-if="$ctrl.clipboardService.isCopySupported()" data-bi-id="rx-raf-copy-link">\r\n                                <i class="mee-icon pull-left icon mee-icon-Link"></i>\r\n                                <mee-flyout has-beak="true" dismissible="true" placement="bottom">\r\n                                    <p mee-paragraph="para2" class="flyouttext"> {{ $ctrl.copyText }} </p>\r\n                           