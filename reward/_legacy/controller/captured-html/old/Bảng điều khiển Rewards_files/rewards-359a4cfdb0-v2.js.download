angular.module("templateModule",[]).run(["$templateCache",function(e){e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/dashboard.html",'<main id="rewardsAngular" ng-class="{\'dense-dashboard\': $ctrl.isDenseLayout}">\r\n    <mee-rewards-pop-up ng-if="!$ctrl.isCouponPopUp"\r\n                        promotion="$ctrl.popUpPromotion"\r\n                        is-confetti-visible="false"\r\n                        content-header="$ctrl.getPopUpHeader()"\r\n                        content-title="$ctrl.getPopUpTitle()"\r\n                        content-description="$ctrl.getPopUpDesp()"\r\n                        on-click="$ctrl.handlePopUpBtnClick()">\r\n    </mee-rewards-pop-up>\r\n\r\n    <mee-rewards-user-warning ng-if="$ctrl.componentAvailabilityMap[\'userWarnings\']"\r\n                              dashboard-result="$ctrl.dashboardResult">\r\n    </mee-rewards-user-warning>\r\n\r\n    <div class="binguf-machine-trans"\r\n         ng-if="$ctrl.componentAvailabilityMap[\'bingUfMachineTranslation\']">\r\n        <mee-safe-image class="text-icon"\r\n                        alt="$ctrl.cmsData.strings[\'machineTrans-icon-text\']"\r\n                        src="$ctrl.cmsData.strings[\'machineTrans-icon-url\']">\r\n        </mee-safe-image>\r\n        <span>{{$ctrl.cmsData.strings["machine-tranlation-hint"]}}</span>\r\n    </div>\r\n\r\n    <mee-rewards-user-status-banner dashboard-result="$ctrl.dashboardResult"\r\n                                    ng-if="$ctrl.componentAvailabilityMap[\'userStatus\'] && !$ctrl.componentAvailabilityMap[\'giveInfo\']"\r\n                                    ng-class="{\'dense-dashboard\': $ctrl.isDenseLayout}"\r\n                                    show-raf-points="true">\r\n    </mee-rewards-user-status-banner>\r\n\r\n    <mee-rewards-user-status-banner dashboard-result="$ctrl.dashboardResult"\r\n                                    slot-configuration=\'["profile", "giveBalance", "balance", "dailyPoint"]\'\r\n                                    ng-if="$ctrl.componentAvailabilityMap[\'userStatus\'] && $ctrl.componentAvailabilityMap[\'giveInfo\']"\r\n                                    ng-class="{\'dense-dashboard\': $ctrl.isDenseLayout}">\r\n    </mee-rewards-user-status-banner>\r\n\r\n    <mee-rewards-suggested-searches dashboard-result="$ctrl.dashboardResult"\r\n                                    cms-data="$ctrl.cmsData"\r\n                                    suggested-search-items="$ctrl.suggestedSearchItems"\r\n                                    enable-search-box="$ctrl.componentAvailabilityMap[\'searchBox\']"\r\n                                    enable-suggestions="$ctrl.componentAvailabilityMap[\'suggestedSearches\']"\r\n                                    ng-if="$ctrl.componentAvailabilityMap[\'search\'] && $ctrl.search.searchBoxPlacement === \'above-navigation-bar\'">\r\n    </mee-rewards-suggested-searches>\r\n\r\n    <mee-rewards-navigation-bar dashboard-result="$ctrl.dashboardResult" active-id="earn" ng-if="!$ctrl.isDenseLayout"></mee-rewards-navigation-bar>\r\n\r\n    <mee-rewards-pointclaim-banner ng-if="$ctrl.componentAvailabilityMap[\'pointClaimBanner\']"\r\n                                   dashboard-result="$ctrl.dashboardResult">\r\n    </mee-rewards-pointclaim-banner>\r\n\r\n    <mee-rewards-coupon-banner ng-if="$ctrl.componentAvailabilityMap[\'couponBanner\']"\r\n                               dashboard-result="$ctrl.dashboardResult">\r\n    </mee-rewards-coupon-banner>\r\n\r\n    <mee-rewards-raf-top-banner ng-if="$ctrl.componentAvailabilityMap[\'rafBanner\']"\r\n                                dashboard-result="$ctrl.dashboardResult"\r\n                                show-banner-button="true"\r\n                                is-invite-modal-visible="$ctrl.isInviteModalVisible">\r\n    </mee-rewards-raf-top-banner>\r\n\r\n    <mee-rewards-refer-and-earn-invite-modal ng-if="$ctrl.componentAvailabilityMap[\'rafInviteModal\']"\r\n                                             dashboard-result="$ctrl.dashboardResult" \r\n                                             ng-show="$ctrl.isInviteModalVisible" \r\n                                             close-modal="$ctrl.closeInviteModal()">\r\n    </mee-rewards-refer-and-earn-invite-modal>\r\n\r\n    <mee-rewards-mbing-banner id="mbing-banner"\r\n                              ng-if="$ctrl.componentAvailabilityMap[\'mbingBanner\']"\r\n                              dashboard-result="$ctrl.dashboardResult"\r\n                              cms-data="$ctrl.cmsData">\r\n    </mee-rewards-mbing-banner>\r\n\r\n    <div class="rewardsContent" ng-class="$ctrl.getClassName()" ng-cloak>\r\n        \x3c!-- Clippy needs to be the first element here, to ensure it appears behind the other elements --\x3e\r\n        <mee-rewards-clippy dashboard-result="$ctrl.dashboardResult"\r\n                            cms-data="$ctrl.cmsData"\r\n                            ng-if="$ctrl.componentAvailabilityMap[\'clippy\']">\r\n        </mee-rewards-clippy>\r\n\r\n        <mee-rewards-suggested-searches dashboard-result="$ctrl.dashboardResult"\r\n                                        cms-data="$ctrl.cmsData"\r\n                                        suggested-search-items="$ctrl.suggestedSearchItems"\r\n                                        enable-search-box="$ctrl.componentAvailabilityMap[\'searchBox\']"\r\n                                        enable-suggestions="$ctrl.componentAvailabilityMap[\'suggestedSearches\']"\r\n                                        ng-if="$ctrl.componentAvailabilityMap[\'search\'] && $ctrl.search.searchBoxPlacement === \'above-banners\'">\r\n        </mee-rewards-suggested-searches>\r\n\r\n        <mee-rewards-level-up-banner dashboard-result="$ctrl.dashboardResult"\r\n                                     cms-data="$ctrl.cmsData"\r\n                                     ng-if="$ctrl.componentAvailabilityMap[\'levelUpHeroBanner\']">\r\n        </mee-rewards-level-up-banner>\r\n\r\n        <mee-rewards-monthly-bonus-banner dashboard-result="$ctrl.dashboardResult"\r\n                                          cms-data="$ctrl.cmsData"\r\n                                          ng-if="$ctrl.componentAvailabilityMap[\'monthlyBonusHeroBanner\']">\r\n        </mee-rewards-monthly-bonus-banner>\r\n\r\n        <mee-rewards-star-bonus-weekly-banner dashboard-result="$ctrl.dashboardResult"\r\n                                              cms-data="$ctrl.cmsData"\r\n                                              ng-if="$ctrl.componentAvailabilityMap[\'starBonusWeeklyBanner\']">\r\n        </mee-rewards-star-bonus-weekly-banner>\r\n\r\n        <mee-rewards-promotional-items dashboard-result="$ctrl.dashboardResult"\r\n                                       cms-data="$ctrl.cmsData"\r\n                                       ng-if="$ctrl.componentAvailabilityMap[\'promotionalItems\']">\r\n        </mee-rewards-promotional-items>\r\n\r\n        <mee-rewards-promotion dashboard-result="$ctrl.dashboardResult"\r\n                               welcome-tour="$ctrl.dashboardResult.welcomeTour"\r\n                               cms-data="$ctrl.cmsData"\r\n                               ng-if="$ctrl.componentAvailabilityMap[\'promotion\']">\r\n        </mee-rewards-promotion>\r\n\r\n        <mee-rewards-suggested-searches dashboard-result="$ctrl.dashboardResult"\r\n                                        cms-data="$ctrl.cmsData"\r\n                                        suggested-search-items="$ctrl.suggestedSearchItems"\r\n                                        enable-search-box="$ctrl.componentAvailabilityMap[\'searchBox\']"\r\n                                        enable-suggestions="$ctrl.componentAvailabilityMap[\'suggestedSearches\']"\r\n                                        ng-if="$ctrl.componentAvailabilityMap[\'search\'] && $ctrl.search.searchBoxPlacement === \'below-banners\'">\r\n        </mee-rewards-suggested-searches>\r\n\r\n        <mee-rewards-explore-on-bing-section dashboard-result="$ctrl.dashboardResult"\r\n                                             cms-data="$ctrl.cmsData"\r\n                                             component-availability-map="$ctrl.componentAvailabilityMap"\r\n                                             ng-if="$ctrl.componentAvailabilityMap[\'exploreOnBingSection\'] && $ctrl.exploreOnBing.sectionPlacement === \'below-banners\'">\r\n        </mee-rewards-explore-on-bing-section>\r\n\r\n        <mee-rewards-daily-set-section dashboard-result="$ctrl.dashboardResult"\r\n                                       cms-data="$ctrl.cmsData"\r\n                                       component-availability-map="$ctrl.componentAvailabilityMap"\r\n                                       ng-if="$ctrl.componentAvailabilityMap[\'dailySets\']">\r\n        </mee-rewards-daily-set-section>\r\n\r\n        <mee-rewards-punch-cards dashboard-result="$ctrl.dashboardResult"\r\n                                 cms-data="$ctrl.cmsData"\r\n                                 ng-if="$ctrl.componentAvailabilityMap[\'punchCards\'] && !$ctrl.componentAvailabilityMap[\'outageRoaming\']">\r\n        </mee-rewards-punch-cards>\r\n\r\n        <mee-rewards-explore-on-bing-section dashboard-result="$ctrl.dashboardResult"\r\n                                             cms-data="$ctrl.cmsData"\r\n                                             component-availability-map="$ctrl.componentAvailabilityMap"\r\n                                             ng-if="$ctrl.componentAvailabilityMap[\'exploreOnBingSection\'] && $ctrl.exploreOnBing.sectionPlacement === \'above-more-activities\'">\r\n        </mee-rewards-explore-on-bing-section>\r\n\r\n        <mee-rewards-more-activities-card dashboard-result="$ctrl.dashboardResult"\r\n                                          welcome-tour="$ctrl.dashboardResult.welcomeTour"\r\n                                          cms-data="$ctrl.cmsData"\r\n                                          component-availability-map="$ctrl.componentAvailabilityMap"\r\n                                          has-other-offers="$ctrl.componentAvailabilityMap[\'dailySets\']"\r\n                                          ng-if="$ctrl.componentAvailabilityMap[\'moreActivities\']">\r\n        </mee-rewards-more-activities-card>\r\n\r\n        <mee-rewards-redeem-info-card user-status="$ctrl.dashboardResult.userStatus"\r\n                                      cms-data="$ctrl.cmsData"\r\n                                      ng-if="$ctrl.componentAvailabilityMap[\'redeemInfo\']">\r\n        </mee-rewards-redeem-info-card>\r\n\r\n        <mee-rewards-suggested-rewards-card suggested-rewards="$ctrl.dashboardResult.suggestedRewards"\r\n                                            cms-data="$ctrl.cmsData"\r\n                                            ng-if="$ctrl.componentAvailabilityMap[\'suggestedRewards\']">\r\n        </mee-rewards-suggested-rewards-card>\r\n    </div>\r\n</main>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Family/community.html",'<div id="rewards-community-page">\r\n    <mee-rewards-user-status dashboard-result="$ctrl.dashboardResult"\r\n                             ng-if="$ctrl.componentVisibilityMap[\'userStatus\']"\r\n                             slot-configuration=\'["profile", "balance", "streak", "dailyPoint"]\'>\r\n    </mee-rewards-user-status>\r\n    <mee-rewards-navigation active-id="family"></mee-rewards-navigation>\r\n    <div id="rewards-community-body" data-grid="container">\r\n        <h1 mee-heading="heading5" class="f-lean heading" ng-if="$ctrl.hasCommunity">\r\n            {{ $ctrl.cmsData.strings["community-title"] }}\r\n        </h1>\r\n\r\n        <div id="rewards-community-content" ng-class="{\'community\' : $ctrl.hasCommunity,\'progress\':$ctrl.componentVisibilityMap[\'referrerProgress\']}">\r\n            <div id="community-referrer-section" ng-class="{\'community\' : $ctrl.hasCommunity,\'progress\':$ctrl.componentVisibilityMap[\'referrerProgress\'], \'firstObj\': true}">\r\n                <mee-rewards-raf-banner ng-if="$ctrl.componentVisibilityMap[\'referrerBanner\']"\r\n                                        progress-info="$ctrl.dashboardResult.userStatus.referrerProgressInfo"\r\n                                        small="$ctrl.hasCommunity">\r\n                </mee-rewards-raf-banner>\r\n\r\n                <mee-rewards-raf-progress ng-if="$ctrl.componentVisibilityMap[\'referrerProgress\']"\r\n                                          progress-info="$ctrl.dashboardResult.userStatus.referrerProgressInfo"\r\n                                          small="$ctrl.hasCommunity">\r\n                </mee-rewards-raf-progress>\r\n            </div>\r\n            <div id="community-referrer-section" ng-class="{\'community\' : $ctrl.hasCommunity,\'progress\':$ctrl.componentVisibilityMap[\'referrerProgress\'], \'secondObj\': true}">\r\n                <mee-rewards-raf-banner ng-if="$ctrl.componentVisibilityMap[\'referrerBanner\']"\r\n                                        progress-info="$ctrl.dashboardResult.userStatus.referrerProgressInfo"\r\n                                        small="$ctrl.hasCommunity">\r\n                </mee-rewards-raf-banner>\r\n\r\n                <mee-rewards-raf-progress ng-if="$ctrl.componentVisibilityMap[\'referrerProgress\']"\r\n                                          progress-info="$ctrl.dashboardResult.userStatus.referrerProgressInfo"\r\n                                          small="$ctrl.hasCommunity">\r\n                </mee-rewards-raf-progress>\r\n            </div>\r\n            <div id="community-family-section" ng-class="{\'community\' : $ctrl.hasCommunity,\'progress\':$ctrl.componentVisibilityMap[\'referrerProgress\']}">\r\n                <mee-rewards-community-banner ng-if="!$ctrl.hasCommunity">\r\n                </mee-rewards-community-banner>\r\n                <mee-rewards-community-list ng-if="$ctrl.hasCommunity"\r\n                                            community-result="$ctrl.familyResult">\r\n                </mee-rewards-community-list>\r\n                <div class="spacer"></div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Family/family.html",'<div id="familyRewards">\r\n    <mee-rewards-navigation active-id="family"></mee-rewards-navigation>\r\n\r\n    <section id="familyBanner" mee-feature="align-left" class="margin-top-12" ng-class="{\'margin-bottom-36\' : !$ctrl.hasFamily}">\r\n        <div>\r\n            <h2 mee-heading="heading" class="noMargin"><strong>{{$ctrl.familyPage.title}}</strong></h2>\r\n            <p mee-paragraph="para4">{{$ctrl.familyPage.description}}</p>\r\n\r\n            <div class="clear" ng-class="{\'pointsContainer\' : $ctrl.hasFamily}">\r\n                <div ng-repeat="callToAction in $ctrl.familyPage.callToActions" class="pointsAction" ng-class="{\'text-align-center\' : $ctrl.hasFamily}">\r\n                    <img mee-image ng-src="{{callToAction.icon.source}}" alt="{{callToAction.icon.alternateText}}" ng-if="callToAction.icon" />\r\n                    <a mee-call-to-action="lightweight" ui-sref="{{callToAction.state}}" data-bi-id="{{callToAction.id}}" id="{{callToAction.id}}" ng-if="callToAction.state">\r\n                        {{callToAction.text}}\r\n                    </a>\r\n                    <a role="button"\r\n                       mee-button="primary"\r\n                       ng-href={{callToAction.url}}\r\n                       data-bi-id="{{callToAction.id}}"\r\n                       id="{{callToAction.id}}"\r\n                       ng-if="callToAction.url">\r\n                        {{callToAction.text}}\r\n                    </a>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <picture class="hideImage">\r\n            <img mee-image\r\n                 ng-src="{{$ctrl.familyPage.image.source}}"\r\n                 alt="{{$ctrl.familyPage.image.alternateText}}"\r\n                 aria-label="{{$ctrl.familyPage.image.alternateText}}"\r\n                 role="img" />\r\n        </picture>\r\n    </section>\r\n\r\n    <mee-rewards-family-list ng-if="$ctrl.hasFamily"\r\n                             family-result="$ctrl.familyResult"\r\n                             cms-data="$ctrl.cmsData">\r\n    </mee-rewards-family-list>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-countdown-timer.html",'<div id="sweepstakeCountdown" class="sweepstakesContent">\r\n    <div class="timer">\r\n        <h2>{{ $ctrl.title }}</h2>\r\n        <div class="timer-unit-group">\r\n            <div class="time-unit">\r\n                <div class="time-value">{{ $ctrl.timeUnits.days }}</div>\r\n                <div class="time-label">{{ $ctrl.cmsData.strings["all_countdownclock_timeslot1title_days"] }}</div>\r\n            </div>\r\n            <div class="time-unit">\r\n                <div class="time-value">{{ $ctrl.timeUnits.hours }}</div>\r\n                <div class="time-label">{{ $ctrl.cmsData.strings["all_countdownclock_timeslot2title_hours"] }}</div>\r\n            </div>\r\n            <div class="timer-separator">:</div>\r\n            <div class="time-unit">\r\n                <div class="time-value">{{ $ctrl.timeUnits.minutes }}</div>\r\n                <div class="time-label">{{ $ctrl.cmsData.strings["all_countdownclock_timeslot3title_minutes"] }}</div>\r\n            </div>\r\n            <div class="timer-separator">:</div>\r\n            <div class="time-unit">\r\n                <div class="time-value">{{ $ctrl.timeUnits.seconds }}</div>\r\n                <div class="time-label">{{ $ctrl.cmsData.strings["all_countdownclock_timeslot4title_seconds"] }}</div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-entry-banner.h