ink">\r\n        <a mee-call-to-action="lightweight"\r\n           id="{{$ctrl.earningTip.callToAction.id}}"\r\n           ng-href="{{$ctrl.earningTip.callToAction.url}}"\r\n           ng-attr-aria-label="{{$ctrl.earningTip.callToAction.ariaLabel}}"\r\n           target="{{$ctrl.earningTip.callToAction.target}}"\r\n           data-bi-id="{{$ctrl.earningTip.callToAction.id}}">\r\n            {{$ctrl.earningTip.callToAction.text}}\r\n        </a>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Status/LevelInfo/level-benefits.html",'<div id="levelBenefits" tabindex="-1" ng-class="{\'new-levels-feature\': $ctrl.isNewLevelsFeatureAvailable}">\r\n    <h4 mee-heading="heading4" mee-auto-focus ng-attr-aria-label="{{$ctrl.cmsData.strings[\'lb-locked-level2-title\']}}" ng-if="$ctrl.showLockedView" id="locked-header" class="f-lean margin-bottom-10">{{$ctrl.cmsData.strings["lb-locked-level2-title"]}}</h4>\r\n    <h4 mee-heading="heading4" mee-auto-focus ng-attr-aria-label="{{$ctrl.cmsData.strings[\'lb-title\']}}" ng-if="!$ctrl.showLockedView" class="f-lean margin-bottom-10">{{$ctrl.cmsData.strings["lb-title"]}}</h4>\r\n    <div class="level-selector margin-bottom-16" ng-if="!$ctrl.isNewLevelsFeatureAvailable">\r\n        <mee-select ng-model="$ctrl.selectedLevel">\r\n            <select ng-attr-aria-label="{{$ctrl.cmsData.strings[\'lb-select-level\']}}">\r\n                <option value="{{levelKey}}" ng-repeat="levelKey in $ctrl.benefitsPromotion.supportedLevelKeys">{{$ctrl.getMobileLevelTitle($index, levelKey)}}</option>\r\n            </select>\r\n        </mee-select>\r\n    </div>\r\n\r\n    <div ng-if="$ctrl.showLockedView" id="locked-center" class="center" data-grid="8">\r\n        <p ng-if="!$ctrl.pointsSummary.isLevelTaskComplete" ng-bind-html="$ctrl.pointsSummary.levelProgressText" class="pointsDetail c-subheading-3"></p>\r\n        <p mee-caption="caption1" class="c-meta-text padding-bottom-20">\r\n            <mee-rewards-counter-animation from="$ctrl.previousPointsToNextLevel"\r\n                                           to="$ctrl.pointsSummary.remainingPointsToNextLevel"\r\n                                           format="$ctrl.pointsSummary.nextLevelTask">\r\n            </mee-rewards-counter-animation>\r\n        </p>\r\n        <mee-progress-determinate data-grid="6"\r\n                                  progress-value="$ctrl.pointsSummary.nextLevelProgressPercentage"\r\n                                  aria-hidden="true"\r\n                                  ng-if="!$ctrl.pointsSummary.isLevelTaskComplete">\r\n        </mee-progress-determinate>\r\n    </div>\r\n    <h4 mee-heading="heading4" ng-if="$ctrl.showLockedView" id="locked-header" class="f-lean align-left">{{$ctrl.cmsData.strings["ways-to-earn-title"]}}</h4>\r\n    <div id="locked-table" role="list" ng-if="$ctrl.showLockedView" class="benefit-table">\r\n        <div class="benefit-row" role="listitem" ng-repeat="item in $ctrl.pointsCounters">\r\n            <div class="locked-cell">\r\n                <p mee-paragraph="para4Lean">\r\n                    <a mee-hyperlink\r\n                       ng-href="{{item.destinationUrl}}"\r\n                       ng-if="item.destinationUrl"\r\n                       id="{{item.title | lowercase}}"\r\n                       data-bi-id="{{item.destinationUrl | lowercase}}">\r\n                        <span>{{item.title}}</span>\r\n                    </a>\r\n                    <span class="font-18" ng-if="!item.destinationUrl">{{item.title}}</span>\r\n                </p>\r\n            </div>\r\n            <div class="locked-cell">\r\n                <p class="locked-cell-desc align-left">{{item.description}}</p>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <h4 mee-heading="heading4" ng-if="$ctrl.showLockedView" id="locked-header" class=" f-lean align-left">{{$ctrl.cmsData.strings["rewards-level-perks-title"]}}</h4>\r\n\r\n    <p ng-if="$ctrl.isNewLevelsFeatureAvailable && $ctrl.isDistinctHvaFlightV2" class="benefit-header-description">{{ $ctrl.cmsData.strings["rewards-level-perks-header2"] }}</p>\r\n    <p ng-if="$ctrl.isNewLevelsFeatureAvailable && !$ctrl.isDistinctHvaFlightV2" class="benefit-header-description">{{ $ctrl.cmsData.strings["rewards-level-perks-header1"] }}</p>\r\n\r\n    <div class="level-selector margin-bottom-16" ng-if="$ctrl.isNewLevelsFeatureAvailable">\r\n        <div ng-repeat="levelKey in $ctrl.benefitsPromotion.supportedLevelKeys"\r\n             ng-if="$ctrl.isNewLevelsFeatureAvailable && $ctrl.isLevelSelected(levelKey)"\r\n             class="new-level-icon-container">\r\n            <object data="{{$ctrl.newLevelIcons[$index]}}" type="image/svg+xml" class="new-level-icon" aria-label="{{$ctrl.getMobileLevelTitle($index, levelKey)}} Level Icon" aria-hidden="true" tabindex="-1"></object>\r\n        </div>\r\n        <mee-select ng-model="$ctrl.selectedLevel">\r\n            <select ng-attr-aria-label="{{$ctrl.cmsData.strings[\'lb-select-level\']}}">\r\n                <option value="{{levelKey}}" ng-repeat="levelKey in $ctrl.benefitsPromotion.supportedLevelKeys">{{$ctrl.getMobileLevelTitle($index, levelKey)}}</option>\r\n            </select>\r\n        </mee-select>\r\n    </div>\r\n    <table class="benefit-table" aria-label={{$ctrl.cmsData.strings["rewards-level-perks-title"]}}>\r\n        <tr class="benefit-row benefit-header">\r\n            <td class="benefit-cell" id="benefit-header" scope="col">\r\n                <p ng-if="!$ctrl.isNewLevelsFeatureAvailable" mee-paragraph="para4Lean">{{ $ctrl.cmsData.strings["lb-desc-header"] }}</p>\r\n                <p ng-if="$ctrl.isNewLevelsFeatureAvailable" mee-paragraph="para4Lean" class="mobile-benefit-requirements-title-row">{{ $ctrl.cmsData.strings["lb-desc-header-level-requirements"] }}</p>\r\n            </td>\r\n            <td class="benefit-cell"\r\n                id="level-header-{{$index}}"\r\n                scope="col"\r\n                ng-repeat="level in $ctrl.benefitsPromotion.supportedLevelKeys"\r\n                ng-class="{\'activeLevel\': $ctrl.isLevelActive(level), \'selectedLevel\': $ctrl.isLevelSelected(level) }">\r\n                \r\n                <mee-persona id="benefits-profile-picture" size="persona1" ng-if="$ctrl.isLevelActive(level)">\r\n                    <persona-image>\r\n                        <mee-safe-image img-class="round" src="$ctrl.currentUser.profilePictureUrl" alt="{{$ctrl.currentUser.displayName}}" aria-hidden="true"></mee-safe-image>\r\n                    </persona-image>\r\n                </mee-persona>\r\n\r\n                <p ng-if="!$ctrl.isNewLevelsFeatureAvailable" mee-paragraph="para4Lean" class="benefit-header-padding" ng-bind-html="$ctrl.getLevelTitle($index)"></p>\r\n                <div ng-if="$ctrl.isNewLevelsFeatureAvailable" class="new-level-icon-content">\r\n                    <p mee-paragraph="para4Lean" class="benefit-header-padding" ng-bind-html="$ctrl.getLevelTitle($index)"></p>\r\n                    <object id="member-icon-{{$index}}" data="{{$ctrl.newLevelIcons[$index]}}" type="image/svg+xml" class="new-level-icon" aria-label="{{$ctrl.getLevelTitle($index)}} Level Icon" aria-hidden="true" tabindex="-1"></object>\r\n                </div>\r\n            </td>\r\n        </tr>\r\n\r\n        <tr ng-if="$ctrl.isNewLevelsFeatureAvailable" class="benefit-row benefit-header benefit-requirements-title-row">\r\n            <td class="benefit-cell">\r\n                <p mee-paragraph="para4Lean">{{ $ctrl.cmsData.strings["lb-desc-header-level-requirements"] }}</p>\r\n            </td>\r\n            <td class="benefit-cell" ng-repeat="level in $ctrl.benefitsPromotion.supportedLevelKeys"\r\n                ng-class="{\'activeLevel\': $ctrl.isLevelActive(level), \'selectedLevel\': $ctrl.isLevelSelected(level) }" />\r\n        </tr>\r\n        <tr ng-if="$ctrl.isNewLevelsFeatureAvailable" class="benefit-row" ng-repeat="levelRequirement in $ctrl.benefitsPromotion.levelRequirements">\r\n            <td class="benefit-cell" headers="benefit-header">\r\n                <p mee-paragraph="para4Lean">\r\n                    <a mee-hyperlink\r\n                       ng-href="{{levelRequirement.url}}"\r\n                       ng-if="levelRequirement.url"\r\n                       id="{{levelRequirement.key | lowercase}}"\r\n                       data-bi-id="{{levelRequirement.key | lowercase}}">\r\n                        <span>{{ $ctrl.commonCmsData.strings[levelRequirement.text] || benefit.text }}</span>\r\n                    </a>\r\n                    <span ng-if="!levelRequirement.url" class="benefit-text">{{ $ctrl.commonCmsData.strings[levelRequirement.text] || benefit.text }}</span>\r\n                </p>\r\n            </td>\r\n            <td class="benefit-cell"\r\n                headers="benefit-header level-header-{{$index}}"\r\n                ng-repeat="level in $ctrl.benefitsPromotion.supportedLevelKeys"\r\n                ng-class="{\'activeLevel\': $ctrl.isLevelActive(level), \'selectedLevel\': $ctrl.isLevelSelected(level) }">\r\n                <p mee-paragraph="para4Lean"\r\n                   class="benefit-value"\r\n                   ng-class="{ \'mee-icon\': levelRequirement.supportedLevels[level] === \'\', \'mee-icon-CheckMark\': levelRequirement.supportedLevels[level] === \'\' }">\r\n                    {{ levelRequirement.supportedLevels[level] }}\r\n                </p>\r\n                <p ng-if="(levelRequirement.supportedLevels[level]=== \'\')" class="vis-Hid">\r\n                    Checked\r\n                </p>\r\n                <p ng-if="!(levelRequirement.supportedLevels[level]) && !(levelRequirement.supportedLevels[level]=== \'\')" mee-paragraph="para4Lean">\r\n                    --\r\n                </p>\r\n            </td>\r\n        </tr>\r\n        <tr ng-if="$ctrl.isNewLevelsFeatureAvailable" class="benefit-row benefit-header">\r\n            <td class="benefit-cell">\r\n                <p mee-paragraph="para4Lean">{{ $ctrl.cmsData.strings["lb-desc-header-new-levels"] }}</p>\r\n            </td>\r\n            <td class="benefit-cell" ng-repeat="level in $ctrl.benefitsPromotion.supportedLevelKeys"\r\n                ng-class="{\'activeLevel\': $ctrl.isLevelActive(level), \'selectedLevel\': $ctrl.isLevelSelected(level) }" />\r\n        </tr>\r\n        <tr class="benefit-row" ng-repeat="benefit in $ctrl.filteredBenefits">\r\n            <td class="benefit-cell" headers="benefit-header">\r\n                <p mee-paragraph="para4Lean">\r\n                    <a mee-hyperlink\r\n                       ng-href="{{benefit.url}}"\r\n                       ng-if="benefit.url"\r\n                       id="{{benefit.key | lowercase}}"\r\n                       data-bi-id="{{benefit.key | lowercase}}">\r\n                        <span>{{ $ctrl.commonCmsData.strings[benefit.text] || benefit.text }}</span>\r\n                    </a>\r\n                    <span ng-if="!benefit.url" class="benefit-text">{{ $ctrl.commonCmsData.strings[benefit.text] || benefit.text }}</span>\r\n                </p>\r\n            </td>\r\n            <td ng-if="!$ctrl.isNewLevelsFeatureAvailable"\r\n                class="benefit-cell"\r\n                headers="benefit-header level-header-{{$index}}"\r\n                ng-repeat="level in $ctrl.benefitsPromotion.supportedLevelKeys"\r\n                ng-class="{\'activeLevel\': $ctrl.isLevelActive(level), \'selectedLevel\': $ctrl.isLevelSelected(level) }">\r\n                <p mee-paragraph="para4Lean"\r\n                   ng-class="{ \'mee-icon\': benefit.supportedLevels[level] === \'\', \'mee-icon-CheckMark\': benefit.supportedLevels[level] === \'\'}">\r\n                    {{ benefit.supportedLevels[level] }}\r\n                </p>\r\n                <p ng-if="(benefit.supportedLevels[level]=== \'\')" class="vis-Hid">\r\n                    Checked\r\n                </p>\r\n                <p ng-if="!(benefit.supportedLevels[level]) && !(benefit.supportedLevels[level]=== \'\')" mee-paragraph="para4Lean">\r\n                    X\r\n                </p>\r\n            </td>\r\n            <td ng-if="$ctrl.isNewLevelsFeatureAvailable"\r\n                class="benefit-cell"\r\n                headers="benefit-header level-header-{{$index}}"\r\n                ng-repeat="level in $ctrl.benefitsPromotion.supportedLevelKeys"\r\n                ng-class="{\'activeLevel\': $ctrl.isLevelActive(level), \'selectedLevel\': $ctrl.isLevelSelected(level) }">\r\n                <p mee-paragraph="para4Lean"\r\n                   class="benefit-value"\r\n                   ng-class="{ \'checkmark\': benefit.supportedLevels[level] === \'\'}">\r\n                    {{ benefit.supportedLevels[level] }}\r\n                </p>\r\n                <p ng-if="!(benefit.supportedLevels[level]) && !(benefit.supportedLevels[level]=== \'\')" mee-paragraph="para4Lean">\r\n                    --\r\n                </p>\r\n            </td>\r\n        </tr>\r\n        <tr class="benefit-row-test" />\r\n    </table>\r\n    <div class="benefits-help">\r\n        <div ng-if="benefit.helpText" class="benefits-help-item" ng-repeat="benefit in $ctrl.benefitsPromotion.benefits">\r\n            <p ng-bind-html="$ctrl.commonCmsData.strings[benefit.helpText] || benefit.helpText"></p>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Status/LevelInfo/level-info.html",'<div id="levelInfo" aria-labelledby="levelInfoTitle" aria-describedby="levelInfoDescription levelInfoText">\r\n    <div class="largePointContainer left">\r\n        <mee-rewards-animation-item item="$ctrl.levelInfoModel.leftIcon" ng-if="$ctrl.levelInfoModel.leftIcon.source"></mee-rewards-animation-item>\r\n        <div class="pointContent">\r\n            <div class="f-lean margin-bottom-4" mee-heading="heading2">\r\n                <mee-rewards-counter-animation from="0"\r\n                                               to="$ctrl.levelInfoModel.lifetimePoints"\r\n                                               screen-reader-text="$ctrl.cmsData.strings[\'li-points-earned-text\']">\r\n                </mee-rewards-counter-animation>\r\n            </div>\r\n            <div mee-heading="subheading4" class="f-lean">{{ $ctrl.cmsData.strings["li-points-earned-text"] }}</div>\r\n        </div>\r\n    </div>\r\n    <div class="levelSection">\r\n        <mee-persona id="profile-picture" size="persona1">\r\n            <persona-image>\r\n                <mee-safe-image img-class="round" src="$ctrl.currentUser.profilePictureUrl" alt="{{$ctrl.currentUser.displayName}}"></mee-safe-image>\r\n            </persona-image>\r\n        </mee-persona>\r\n        <h2 mee-heading="heading3" id="levelInfoTitle" class="large f-lean margin-bottom-5">{{ $ctrl.levelInfoModel.activeLevelName }}</h2>\r\n        <h4 mee-heading="heading4" class="small f-lean margin-bottom-5">{{ $ctrl.levelInfoModel.activeLevelName }}</h4>\r\n\r\n        <mee-rewards-month-breakdown-button ng-if="$ctrl.isNewLevelsFeatureAvailable"></mee-rewards-month-breakdown-button>\r\n        <p mee-paragraph="para3Lean" id="levelInfoDescription" class="margin-top-12" ng-if="$ctrl.isNewLevelsFeatureAvailable">\r\n            <mee-rewards-points-progress current="$ctrl.userStatus.levelInfo.progress"\r\n                                         max="$ctrl.userStatus.levelInfo.progressMax"\r\n                                         format="{0}/{1}">\r\n            </mee-rewards-points-progress>\r\n        </p>\r\n        <mee-progress-determinate data-grid="6"\r\n                                  progress-value="$ctrl.levelInfoModel.nextLevelProgressPercentage"\r\n                                  mee-aria-label="determinate progress bar"\r\n                                  class="f-lean margin-bottom-6"\r\n                                  ng-if="!$ctrl.levelInfoModel.isLevelTaskComplete || $ctrl.isNewLevelsFeatureAvailable"\r\n                                  ng-class="{completed: $ctrl.levelInfoModel.isLevelTaskComplete, \'new-levels-feature\': $ctrl.isNewLevelsFeatureAvailable}">\r\n        </mee-progress-determinate>\r\n        <p mee-paragraph="para3Lean" id="levelInfoDescription" ng-if="!$ctrl.levelInfoModel.isLevelTaskComplete && !$ctrl.isNewLevelsFeatureAvailable">\r\n            <mee-rewards-counter-animation from="$ctrl.levelInfoModel.previousPointsToNextLevel"\r\n                                           to="$ctrl.levelInfoModel.remainingPointsToNextLevel"\r\n                                           format="$ctrl.levelInfoModel.levelTaskIncompleteText">\r\n            </mee-rewards-counter-animation>\r\n        </p>\r\n        <p mee-paragraph="para3Lean" id="levelInfoText" ng-if="$ctrl.levelInfoModel.isLevelTaskComplete && !$ctrl.isNewLevelsFeatureAvailable">{{ $ctrl.levelInfoModel.levelTaskCompleteText }}</p>\r\n        <p class="levelProgressBarContainer" ng-if="$ctrl.isNewLevelsFeatureAvailable">\r\n            <mee-rewards-level-progress user-status="$ctrl.userStatus" page-sref=".levelbenefits">\r\n            </mee-rewards-level-progress>\r\n        </p>\r\n        <a mee-call-to-action\r\n           class="margin-top-24"\r\n           id=\'{{$ctrl.cmsData.links["li-level-benefit-link"].id}}\'\r\n           ui-sref=\'{{$ctrl.cmsData.links["li-level-benefit-link"].url}}\'\r\n           ng-attr-aria-label=\'{{$ctrl.cmsData.links["li-level-benefit-link"].ariaLabel}}\'\r\n           data-bi-id=\'{{$ctrl.cmsData.links["li-level-benefit-link"].id}}\'\r\n           mee-focusable=\'glyph-cancel\'\r\n           ng-if=\'$ctrl.areaConfig.flights["levelBenefits"] && $ctrl.cmsData.links["li-level-benefit-link"] && $ctrl.userStatus.levelInfo.benefitsPromotion && $ctrl.userStatus.levelInfo.benefitsPromotion.benefits\'>\r\n            {{$ctrl.cmsData.links["li-level-benefit-link"].text}}\r\n        </a>\r\n        <div class="smallPointContainer">\r\n            <div class="pointSection borderRight">\r\n                <div class="pointsContent left">\r\n                    <mee-safe-image src="$ctrl.cmsData.strings[\'li-small-left-image\']" alt="{{this.cmsData.strings[\'li-left-header-image-alternate-text\']}}"></mee-safe-image>\r\n                    <div class="f-lean margin-bottom-2 margin-top-4" mee-heading="heading4">\r\n                        <mee-rewards-counter-animation from="0"\r\n                                                       to="$ctrl.levelInfoModel.lifetimePoints"\r\n                                                       screen-reader-text="$ctrl.cmsData.strings[\'li-points-earned-text\']">\r\n                        </mee-rewards-counter-animation>\r\n                    </div>\r\n                    <p mee-paragraph="para4Lean">{{ $ctrl.cmsData.strings["li-points-earned-text"] }}</p>\r\n                </div>\r\n            </div>\r\n            <div class="pointSection">\r\n                <div class="pointsContent right">\r\n                    <mee-safe-image src="$ctrl.cmsData.strings[\'li-small-right-image\']" alt="{{this.cmsData.strings[\'li-right-header-image-alternate-text\']}}"></mee-safe-image>\r\n                    <div class="f-lean margin-bottom-2 margin-top-4" mee-heading="heading4">\r\n                        <mee-rewards-counter-animation from="0"\r\n                                                       to="$ctrl.levelInfoModel.pointsRedeemed"\r\n                                                       screen-reader-text="$ctrl.cmsData.strings[\'li-points-redeem-text\']">\r\n                        </mee-rewards-counter-animation>\r\n                    </div>\r\n                    <p mee-paragraph="para4Lean">{{ $ctrl.cmsData.strings["li-points-redeem-text"] }}</p>\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div class="travelContainer margin-top-18" ng-if="$ctrl.levelInfoModel.showTravelInfo" >\r\n            <div class="travelContent">\r\n                <div class="yetToCredit">\r\n                    <div class="f-lean yetToCreditPoints" mee-heading="subheading4">{{ $ctrl.levelInfoModel.yetToBeCredited }}</div>\r\n                    <div class="yetToCreditText">\r\n                        <div class="f-lean creditedText" mee-heading="subheading4">{{ $ctrl.cmsData.strings["li-yet-to-be-credtited-text"] }}</div>\r\n                        <mee-rewards-tooltip tooltip-id="$ctrl.tooltipId"\r\n                                             tooltip-description="$ctrl.tooltipDescription"\r\n                                             cms-data="$ctrl.cmsData"\r\n                                             class="yetToCreditTooltip"\r\n                                             tooltip-icon="$ctrl.tooltipIcon"\r\n                                             beak-direction="$ctrl.beakDirection">\r\n                        </mee-rewards-tooltip>\r\n                    </div>\r\n                </div>\r\n                <a mee-hyperlink\r\n                   id="{{$ctrl.cmsData.links[\'user-status-travel\'].id}}"\r\n                   ng-href="{{$ctrl.cmsData.links[\'user-status-travel\'].url}}"\r\n                   ng-attr-aria-label="{{$ctrl.cmsData.links[\'user-status-travel\'].ariaLabel}}"\r\n                   data-bi-id="{{$ctrl.cmsData.links[\'user-status-travel\'].id}}"\r\n                   target="{{$ctrl.cmsData.links[\'user-status-travel\'].target}}">\r\n                    {{$ctrl.cmsData.links[\'user-status-travel\'].text}}\r\n                    <span class="mee-icon mee-icon-OpenInNewWindow"></span>\r\n                </a>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <div class="largePointContainer right">\r\n        <mee-rewards-animation-item item="$ctrl.levelInfoModel.rightIcon" ng-if="$ctrl.levelInfoModel.rightIcon.source"></mee-rewards-animation-item>\r\n        <div class="pointContent">\r\n            <div class="f-lean margin-bottom-4" mee-heading="heading2">\r\n                <mee-rewards-counter-animation from="0"\r\n                                               to="$ctrl.levelInfoModel.pointsRedeemed"\r\n                                               screen-reader-text="$ctrl.cmsData.strings[\'li-points-redeem-text\']">\r\n                </mee-rewards-counter-animation>\r\n            </div>\r\n            <div mee-heading="subheading4" class="f-lean">{{ $ctrl.cmsData.strings["li-points-redeem-text"] }}</div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Status/LevelInfo/level-progress-bar.html",'<p mee-caption="caption1">{{$ctrl.bingSearchPoints}}</p>\r\n<div id="levelProgressBar">\r\n    <div class="level-progress-container">\r\n        <mee-progress-determinate data-grid="6"\r\n            progress-value="$ctrl.percentage"\r\n            mee-aria-label="{{$ctrl.bingSearchPoints}}"\r\n            ng-class="{completed: $ctrl.percentage === 100}">\r\n        </mee-progress-determinate>\r\n\r\n        <div class="pending" ng-repeat="limit in $ctrl.levelsConfig"\r\n             ng-class="{surpassed: $ctrl.isLowerLevel(limit), disabled: $ctrl.isHigherLevel(limit), limit: $ctrl.isLastLevel(limit)}"\r\n             ng-style="limit.positioning">\r\n             <div class="legend" ng-if="$ctrl.currentValue <= limit.max">{{limit.levelName}}</div>\r\n             <div class="max">{{limit.max}}</div>\r\n        </div>\r\n\r\n        <div class="limit-progress-bar"\r\n             ng-if="$ctrl.barPositioning"\r\n             ng-style="$ctrl.barPositioning"\r\n             ng-class="{limit: $ctrl.currentLevelLimits.max === $ctrl.maxValue, empty: $ctrl.percentage === 0}">\r\n        </div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Status/LevelInfo/level-progress.html",'<div id="levelProgress">\r\n    <div class="levelBlock" ng-repeat-start="level in $ctrl.levelProgress.levels">\r\n        <a class="c-hyperlink levelRequiredPoints" ng-if="$ctrl.pageSref" ui-sref="{{$ctrl.pageSref}}">\r\n            {{level.name}} {{level.requiredPoints}}\r\n        </a>\r\n        <a class="c-hyperlink levelRequiredPoints" ng-if="$ctrl.href" ng-href="{{$ctrl.href}}">\r\n            {{level.name}} {{level.requiredPoints}}\r\n        </a>\r\n        <span ng-if="level.hasLevelUpActivities" class="levelUpProgressLabel">\r\n            {{$ctrl.cmsData.strings["level-up-activities-progress"]}}\r\n        </span>\r\n        <span ng-if="level.hasLevelUpActivities" class="levelUpProgress">\r\n            {{level.levelUpProgress}}\r\n        </span>\r\n    </div>\r\n    <div class="separator" ng-repeat-end ng-if="!$last"></div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Status/LevelInfo/level-up-completions.html",'<div class="level-up-completion-container">\r\n    <div ng-repeat="item in $ctrl.items">\r\n        <img class="checkmark" src="{{item.source}}" alt="{{item.alternateText}}">\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Status/Redemptions/redeem-summary-item.html",'<div class="text-align-center rewards-card-container" id="{{$ctrl.item.id}}">\r\n    <div class="imageContainer">\r\n        <mee-rewards-animation data="$ctrl.item.icon"></mee-rewards-animation>\r\n    </div>\r\n\r\n    <div class="contentContainer">\r\n        <h3 mee-heading="heading" class="ellipsis">{{$ctrl.item.title}}</h3>\r\n        <p mee-paragraph="para4">{{$ctrl.item.subtitle}}</p>\r\n    </div>\r\n\r\n    <div class="actionLink">\r\n        <a mee-call-to-action="lightweight"\r\n           id="{{$ctrl.item.callToAction.id}}"\r\n           data-bi-id="{{$ctrl.item.callToAction.id}}"\r\n           ng-href="{{$ctrl.item.callToAction.url}}"\r\n           ng-attr-aria-label="{{$ctrl.item.callToAction.ariaLabel}}"\r\n           aria-describedby="{{$ctrl.item.id}}"\r\n           target="{{$ctrl.item.callToAction.target}}">\r\n            {{$ctrl.item.callToAction.text}}\r\n        </a>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Status/Redemptions/redeem-summary.html",'<div id="redeemSummary" class="section" ng-if="$ctrl.newUserCard">\r\n    <h2 mee-heading="heading3" class="margin-bottom-18">{{$ctrl.newUserCard.title}}</h2>\r\n    <p mee-paragraph="para3">{{$ctrl.newUserCard.subtitle}}</p>\r\n    <div class="margin-top-24">\r\n        <mee-rewards-animation-item item="$ctrl.newUserCard.icon"></mee-rewards-animation-item>\r\n    </div>\r\n    <a mee-call-to-action\r\n       data-bi-id="{{$ctrl.newUserCard.callToAction.id}}"\r\n       id="{{$ctrl.newUserCard.callToAction.id}}"\r\n       ng-href="{{$ctrl.newUserCard.callToAction.url}}"\r\n       target="{{$ctrl.newUserCard.callToAction.target}}"\r\n       aria-label="{{$ctrl.newUserCard.callToAction.ariaLabel}}"\r\n       class="margin-top-24">\r\n        {{$ctrl.newUserCard.callToAction.ariaLabel}}\r\n    </a>\r\n</div>\r\n\r\n<div id="redeemSummary" class="section" ng-if="!$ctrl.newUserCard">\r\n    <h2 mee-heading="heading3" class="margin-bottom-18">{{$ctrl.cmsData.strings[\'redeem-title\']}}</h2>\r\n    <mee-card-group class="margin-adjustment-3">\r\n        <mee-card display-type="single">\r\n            <card-content>\r\n                <mee-rewards-redeem-summary-item item="$ctrl.donateCard"></mee-rewards-redeem-summary-item>\r\n            </card-content>\r\n        </mee-card>\r\n        <mee-card display-type="single">\r\n            <card-content>\r\n                <mee-rewards-redeem-summary-item item="$ctrl.shopCard"></mee-rewards-redeem-summary-item>\r\n            </card-content>\r\n        </mee-card>\r\n        <mee-card display-type="single">\r\n            <card-content>\r\n                <mee-rewards-redeem-summary-item item="$ctrl.winCard"></mee-rewards-redeem-summary-item>\r\n            </card-content>\r\n        </mee-card>\r\n    </mee-card-group>\r\n    <a mee-call-to-action\r\n       data-bi-id="{{$ctrl.cmsData.links[\'redeem-orderhistory\'].id}}"\r\n       id="{{$ctrl.cmsData.links[\'redeem-orderhistory\'].id}}"\r\n       ng-href="{{$ctrl.cmsData.links[\'redeem-orderhistory\'].url}}"\r\n       target="{{$ctrl.cmsData.links[\'redeem-orderhistory\'].target}}"\r\n       ng-attr-aria-label="{{$ctrl.cmsData.links[\'redeem-orderhistory\'].ariaLabel}}"\r\n       class="margin-top-24">\r\n        {{$ctrl.cmsData.links[\'redeem-orderhistory\'].ariaLabel}}\r\n    </a>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Status/StarBonusDistribution/star-bonus-distribution.html",'<div class="star-bonus-distribution-modal">\r\n    <div class="sd-modal-header">\r\n        <h2 id="star-bonus-title" mee-heading="heading4" class="modal-title">\r\n            {{$ctrl.pageTitle}}\r\n        </h2>\r\n        <p id="star-bonus-description" mee-paragraph="para2" class="modal-subtitle">\r\n            {{$ctrl.pageDescription}}\r\n        </p>\r\n    </div>\r\n\r\n    <div class="modal-body">\r\n        <div class="content-section">\r\n            <div class="tips-section">\r\n                <h3 mee-heading="heading5" class="tips-title">\r\n                    {{$ctrl.cmsData.strings["starbonus-pointsdistribution-tips-title"]}}\r\n                </h3>\r\n                <ol class="tips-list">\r\n                    <li>{{$ctrl.cmsData.strings[\'starbonus-pointsdistribution-tips-text1\']}}</li>\r\n                    <li>{{$ctrl.cmsData.strings[\'starbonus-pointsdistribution-tips-text2\']}}</li>\r\n                    <li>{{$ctrl.cmsData.strings[\'starbonus-pointsdistribution-tips-text3\']}}</li>\r\n                </ol>\r\n                <p ng-if="$ctrl.tooltipDescription"\r\n                   mee-paragraph="para4"\r\n                   class="tips-link"\r\n                   ng-bind-html="$ctrl.tooltipDescription">\r\n                </p>\r\n            </div>\r\n\r\n            <div class="chart-section">\r\n                <h3 mee-heading="heading6" class="chart-title">\r\n                    {{$ctrl.cmsData.strings[\'starbonus-pointsdistribution-chart-title\']}}\r\n  