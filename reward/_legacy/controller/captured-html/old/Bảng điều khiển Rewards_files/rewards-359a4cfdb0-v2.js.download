 class="shareLink" ng-bind-html="$ctrl.redTigerReferrerLink"></div>\r\n        </div>\r\n\r\n        <div class="sharecontainer">\r\n            <div>\r\n                <mee-rewards-twitter-share model="$ctrl.twitterShareModel" ng-if="$ctrl.twitterShareModel"></mee-rewards-twitter-share>\r\n            </div>\r\n            <div>\r\n                <a mee-no-ref\r\n                   id="fb-share-button"\r\n                   aria-label=\'{{$ctrl.cmsData.strings["facebook-link"]}}\'\r\n                   role="button"\r\n                   data-bi-id="fb-share-button"\r\n                   ng-click="$ctrl.onFBbtnClick($ctrl.shareLinkFB)"\r\n                   ng-keyup="$ctrl.onKeyPress($event, $ctrl.shareLinkFB)"\r\n                   tabindex="0">\r\n                    <i class="mee-icon pull-left icon mee-icon-FacebookLogo" aria-hidden="true"></i>\r\n                </a>\r\n            </div>\r\n        </div>\r\n        <div class="helpTextContainer" ng-bind-html="$ctrl.helpText"></div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/ShareAndWin/share-and-win-invite.html",'<div id="shareAndWinInviteCard" class="shareAndWinInviteContent" ng-if="!$ctrl.isMobileRedesign" tabindex="0">\r\n    <a target="_self"\r\n       id="shareAndWinInviteCardLink"\r\n       class="clickable-card"\r\n       ng-if="$ctrl.clipboardService.isCopySupported()"\r\n       ng-attr-href="{{$ctrl.currentUser.isAnonymous || !$ctrl.hasPuid ? $ctrl.nonLocalizedCmsData.links[\'sweepstakes-highvalue-sign-in-share\'].url : undefined}}"\r\n       ng-click="!ctrl.currentUser.isAnonymous && $ctrl.hasPuid ? $ctrl.onShareClick(): undefined">\r\n        <div class="shareAndWinInviteImageContainer">\r\n            <img class="shareAndWinInviteImage" ng-srcset=\'{{$ctrl.heroImageUrl}}\' ng-src=\'{{$ctrl.heroImageUrl}}\' alt="{{$ctrl.cmsData.strings[\'share-invite-referal-link-input-text\']}}">\r\n        </div>\r\n        <div class="sweepstakes-cta-card">\r\n            <div ng-if="$ctrl.subtitle" class="inviteTextSubtitle">{{$ctrl.subtitle}}</div>\r\n            <h3 ng-if="$ctrl.cardTitle"\r\n                class="inviteTextTitle">\r\n                {{$ctrl.cardTitle}}\r\n            </h3>\r\n            <p ng-if="$ctrl.description" class="inviteText" ng-click="$ctrl.preventSharePopupForTermsLink($event)" ng-bind-html=\'$ctrl.description\'></p>\r\n\r\n            \x3c!-- Buttons --\x3e\r\n            <div ng-if="!$ctrl.currentUser.isAnonymous && $ctrl.hasPuid" class="inviteButtonsContainer">\r\n                <div class="textAndIcon sptooltip" ng-click="$ctrl.openTooltip($event, $ctrl.tooltipId)">\r\n                    <input id="referralLinkInputBox" ng-attr-aria-label="{{$ctrl.cmsData.strings[\'share-invite-referal-link-input-text\']}}" type="text" value=\'{{$ctrl.referrerLink}}\' readonly>\r\n                    <mee-rewards-tooltip id="$ctrl.tooltipId"\r\n                                         tooltip-id="$ctrl.tooltipId"\r\n                                         tooltip-description="$ctrl.copyText"\r\n                                         beak-direction="$ctrl.beakDirection"\r\n                                         cms-data="$ctrl.cmsData">\r\n                    </mee-rewards-tooltip>\r\n                </div>\r\n                <a tabindex="0" id="refUrlCopyButton" class="inviteSelectButton" ng-click="$ctrl.onCopyClick()" ng-if="$ctrl.clipboardService.isCopySupported()"\r\n                   ng-attr-aria-label="{{$ctrl.cmsData.strings[\'share-invite-copy-link-text\']}}" target="_self">\r\n                    <img id="copyIcon" class="copyIcon" ng-srcset="{{$ctrl.copyIcon}}" ng-src="{{$ctrl.copyIcon}}" alt="{{$ctrl.cmsData.strings[\'share-and-win-copy-icon-alt\']}}" />\r\n                    {{$ctrl.copyLink}}\r\n                    <mee-flyout class="copyFlyout" has-beak="true" dismissible="true" placement="top">\r\n                        <p mee-paragraph="para2" class="flyouttext"> {{$ctrl.copyText}} </p>\r\n                    </mee-flyout>\r\n                </a>\r\n                <a tabindex="0" id="refShareButton" class="inviteCloseButton" ng-click="$ctrl.onShareClick()"\r\n                   aria-label="{{ $ctrl.moreOptions }}">\r\n                    <img class="copyIcon" ng-srcset="{{$ctrl.shareIcon}}" ng-src="{{$ctrl.shareIcon}}" alt="{{$ctrl.cmsData.strings[\'share-and-win-share-icon-alt\']}}" />\r\n                    {{$ctrl.moreOptions}}\r\n                </a>\r\n            </div>\r\n\r\n            \x3c!-- CTA Button for anonymous users --\x3e\r\n            <div ng-if="$ctrl.currentUser.isAnonymous || !$ctrl.hasPuid" class="hva-card-buttons-container">\r\n                <a ng-if="$ctrl.currentUser.isAnonymous || !$ctrl.hasPuid"\r\n                   id="{{$ctrl.nonLocalizedCmsData.links[\'sweepstakes-highvalue-sign-in-share\'].id}}"\r\n                   class="hva-button cta-trim"\r\n                   href="{{$ctrl.nonLocalizedCmsData.links[\'sweepstakes-highvalue-sign-in-share\'].url}}"\r\n                   ng-attr-aria-label="{{$ctrl.nonLocalizedCmsData.links[\'sweepstakes-highvalue-sign-in-share\'].ariaLabel}}"\r\n                   data-bi-id="{{$ctrl.nonLocalizedCmsData.links[\'sweepstakes-highvalue-sign-in-share\'].id}}"\r\n                   target="{{$ctrl.nonLocalizedCmsData.links[\'sweepstakes-highvalue-sign-in-share\'].target}}">\r\n                    {{$ctrl.nonLocalizedCmsData.links[\'sweepstakes-highvalue-sign-in-share\'].text}}\r\n                </a>\r\n            </div>\r\n        </div>\r\n    </a>\r\n</div>\r\n<div id="shareAndWinInviteImageMobile" class="top-banner" ng-if="$ctrl.isMobileRedesign">\r\n    <div target="_self" tabindex="0" class="share-and-win-invite-card-mobile"\r\n        ng-if="$ctrl.clipboardService.isCopySupported()"\r\n        ng-href="{{$ctrl.currentUser.isAnonymous || !$ctrl.hasPuid ? $ctrl.nonLocalizedCmsData.links[\'sweepstakes-highvalue-sign-in-share\'].url : \'\'}}"\r\n        ng-click="!$ctrl.currentUser.isAnonymous && $ctrl.hasPuid && $ctrl.onShareClick()">\r\n            <img class="card-image" ng-src="{{$ctrl.heroImageUrl}}"\r\n                alt="{{$ctrl.cmsData.strings[\'share-invite-referal-link-input-text\']}}" />\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/ShareAndWin/share-and-win.html",'<main id="rewardsAngular" ng-class="{\'dense-dashboard\': $ctrl.isDenseLayout}">\r\n    <div id="rewardsShareAndWin">\r\n        <mee-rewards-user-warning ng-if="$ctrl.componentAvailabilityMap[\'userWarnings\']"\r\n                                  dashboard-result="$ctrl.dashboardResult">\r\n        </mee-rewards-user-warning>\r\n        <mee-rewards-user-status-banner dashboard-result="$ctrl.dashboardResult"\r\n                                        slot-configuration=\'["profile", "giveBalance", "balance", "dailyPoint"]\'\r\n                                        ng-if="$ctrl.componentAvailabilityMap[\'userStatus\']"\r\n                                        ng-class="{\'dense-dashboard\': $ctrl.isDenseLayout}">\r\n        </mee-rewards-user-status-banner>\r\n\r\n        <mee-rewards-navigation-bar dashboard-result="$ctrl.dashboardResult" active-id="shareandwin" ng-if="!$ctrl.isDenseLayout"></mee-rewards-navigation-bar>\r\n\r\n        <mee-rewards-coupon-banner ng-if="$ctrl.componentAvailabilityMap[\'couponBanner\']"\r\n                                   dashboard-result="$ctrl.dashboardResult">\r\n        </mee-rewards-coupon-banner>\r\n\r\n        <div class="rewardsContent" ng-class="$ctrl.getClassName()" ng-cloak>\r\n            <mee-rewards-promotion dashboard-result="$ctrl.dashboardResult"\r\n                                   welcome-tour="$ctrl.dashboardResult.welcomeTour"\r\n                                   cms-data="$ctrl.cmsData"\r\n                                   is-share-and-win="$ctrl.isShareAndWin">\r\n            </mee-rewards-promotion>\r\n            <div class="twoCardSection">\r\n                <div id="donutChartSection">\r\n                    <mee-rewards-donut-chart donut-chart-data="$ctrl.donutChartData"\r\n                                             donut-chart-options="$ctrl.donutChartOptions">\r\n                    </mee-rewards-donut-chart>\r\n                </div>\r\n                <div id="shareAndWinInvite">\r\n                    <mee-rewards-share-and-win-invite dashboard-result="$ctrl.dashboardResult" description="$ctrl.description" hero-image-url="$ctrl.heroImageUrl" is-invite-modal-visible="$ctrl.isInviteModalVisible">\r\n                    </mee-rewards-share-and-win-invite>\r\n                </div>\r\n            </div>\r\n            <div class="entryCardsSection">\r\n                <mee-rewards-share-and-win-entry-card dashboard-result="$ctrl.dashboardResult"\r\n                                                      sweepstakes-entry-card="$ctrl.entryCards[0]"\r\n                                                      card-id="$ctrl.cardIds[0]">\r\n                </mee-rewards-share-and-win-entry-card>\r\n                <mee-rewards-share-and-win-entry-card dashboard-result="$ctrl.dashboardResult"\r\n                                                      sweepstakes-entry-card="$ctrl.entryCards[1]"\r\n                                                      card-id="$ctrl.cardIds[1]">\r\n                </mee-rewards-share-and-win-entry-card>\r\n                <mee-rewards-share-and-win-entry-card dashboard-result="$ctrl.dashboardResult"\r\n                                                      sweepstakes-entry-card="$ctrl.entryCards[2]"\r\n                                                      card-id="$ctrl.cardIds[2]">\r\n                </mee-rewards-share-and-win-entry-card>\r\n                <mee-rewards-share-and-win-entry-card dashboard-result="$ctrl.dashboardResult"\r\n                                                      sweepstakes-entry-card="$ctrl.entryCards[3]"\r\n                                                      card-id="$ctrl.cardIds[3]"\r\n                                                      ng-click="$ctrl.clickOnShareCard()">\r\n                </mee-rewards-share-and-win-entry-card>\r\n            </div>\r\n            <div class="termsSection">\r\n                <span class="termsText">\r\n                    {{$ctrl.cmsData.strings[\'share-invite-terms\']}}\r\n                </span>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</main>\r\n<mee-rewards-pop-up promotion="$ctrl.popUpPromotion"\r\n                    is-confetti-visible="false"\r\n                    content-title="$ctrl.getPopUpTitle()"\r\n                    content-description="$ctrl.getPopUpDesp()"\r\n                    on-click="$ctrl.handlePopUpBtnClick()">\r\n</mee-rewards-pop-up>\r\n<mee-rewards-share-and-win-invite-modal ng-show="$ctrl.isInviteModalVisible" close-modal="$ctrl.closeInviteModal()"></mee-rewards-share-and-win-invite-modal>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Status/status.html",'<div id="rewardsStatus">\r\n    <mee-rewards-user-warning ng-if="$ctrl.componentAvailabilityMap[\'userWarnings\']"\r\n                              dashboard-result="$ctrl.dashboardResult">\r\n    </mee-rewards-user-warning>\r\n    <mee-rewards-user-status-banner dashboard-result="$ctrl.dashboardResult"\r\n                                    status-result="$ctrl.statusResult"\r\n                                    slot-configuration=\'["profile", "giveBalance", "balance", "dailyPoint"]\'\r\n                                    ng-if="$ctrl.componentAvailabilityMap[\'userStatus\']">\r\n    </mee-rewards-user-status-banner>\r\n\r\n    <mee-rewards-navigation-bar dashboard-result="$ctrl.dashboardResult" active-id="status" ng-if="!$ctrl.isDenseLayout"></mee-rewards-navigation-bar>\r\n\r\n    <mee-rewards-coupon-banner ng-if="$ctrl.componentAvailabilityMap[\'couponBanner\']"\r\n                               dashboard-result="$ctrl.dashboardResult">\r\n    </mee-rewards-coupon-banner>\r\n\r\n    <mee-rewards-