hare-cta\'].ariaLabel}}"\r\n        data-bi-id="{{$ctrl.cmsData.links[\'sweepstakes-highvalue-hva-entry-banner-share-cta\'].id}}"\r\n        target="{{$ctrl.cmsData.links[\'sweepstakes-highvalue-hva-entry-banner-share-cta\'].target}}"\r\n        ng-click="$ctrl.scrollToShareAndWinCard()"\r\n        ng-class="{\'entry-card-clickable\': true}">\r\n        <div class="card-title">{{ $ctrl.highvalueSweepstakesCmsData.strings["hvapage_trackertile3_title_shareentries"] }}</div>\r\n        <div class="card-number">\r\n            <div>{{ $ctrl.shareAndWinEntries }}</div>\r\n        </div>\r\n        <div class="cardAction">\r\n            <div id="{{$ctrl.cmsData.links[\'sweepstakes-highvalue-hva-entry-banner-share-cta\'].id}}">\r\n                {{ $ctrl.highvalueSweepstakesCmsData.strings["hvapage_trackertile3_textlink_shareentries"] }}\r\n            </div>\r\n        </div>\r\n    </button>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-faq.html",'<div class="rewardsContent color-bg-white">\r\n    <div class="accordion">\r\n        <div class="term-content" ng-bind-html="$ctrl.content"></div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-filter.html",'<div class="status-filter" ng-class="{\'grid-view\': !$ctrl.useFlexLayout, \'flex-view\': $ctrl.useFlexLayout}">\r\n  <button ng-repeat="status in $ctrl.statuses" ng-class="{\'active\': $ctrl.selectedStatus === status.value}"\r\n    ng-click="$ctrl.applyFilter(status.value)">\r\n    {{ status.label }} ({{ status.count }})\r\n  </button>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-hva-card-item-group.html",'<div id="hvaCardGroup" class="sweepstakesContent">\r\n    <div id="banners" class="centered-cards-view margin-top-72" ng-if="$ctrl.showBannerCard() && !$ctrl.isMobileRedesign">\r\n        <div class="section-title margin-bottom-48">\r\n            {{\r\n                $ctrl.nonLocalizedCmsData.strings["sweepstake_search_in_the_bing_app_for_weekly_10000_usd_prize"]\r\n            }}\r\n        </div>\r\n        <mee-rewards-highvalue-sweepstakes-banner ng-repeat="banner in $ctrl.banners track by banner.name">\r\n            <banner-content>\r\n            <div role="button" target="_self" tabindex="0" class="clickable-hva-card" \r\n                 ng-click="banner.onclick()" \r\n                 aria-label="{{banner.title || \'Banner card\'}} - {{$ctrl.getStatusText(banner.status)}}"\r\n                 ng-keydown="$event.keyCode === 13 && banner.onclick()"\r\n                 aria-haspopup="dialog">\r\n                <div class="imageContainer">\r\n                    <img class="width-match-parent" mee-image ng-src="{{banner.bannerImage.source}}" alt="{{banner.bannerImage.alternateText || banner.title || \'Banner image\'}}" />\r\n                </div>\r\n                <div class="sr-only-focusable">\r\n                    <button class="card-action-button" ng-click="banner.onclick()" aria-label="{{banner.bannerImage.alternateText || \'Activate\'}}">Activate</button>\r\n                </div>\r\n            </div>\r\n            </banner-content>\r\n        </mee-rewards-highvalue-sweepstakes-banner>\r\n    </div>\r\n    <div\r\n        id="featuredCards"\r\n        class="centered-cards-view margin-top-72"\r\n        ng-if="$ctrl.featuredCards.length > 0 && !$ctrl.isMobileRedesign">\r\n        <div class="section-title margin-bottom-48" mee-heading="heading" role="heading" aria-level="2">\r\n            {{$ctrl.cmsData.strings["hvapage_mod1_sectiontitle"]}}\r\n        </div>\r\n        <mee-card-group class="featured-cards" role="region" aria-label="Featured bonus entry options">\r\n            <mee-card\r\n                ng-repeat="card in $ctrl.featuredCards track by card.name">\r\n                <card-content>\r\n                    <div\r\n                        tabindex="0"\r\n                        class="clickable-hva-card"\r\n                        ng-click="$ctrl.openModal(card, true)"\r\n                        aria-label="{{card.title}} - {{$ctrl.getStatusText(card.status)}}"\r\n                        ng-keydown="$event.keyCode === 13 && $ctrl.openModal(card, true)"\r\n                        aria-haspopup="dialog">\r\n                        <div class="imageContainer">\r\n                            <img\r\n                                mee-image\r\n                                ng-src="{{card.image.source}}"\r\n                                alt="{{card.image.alternateText || card.title || \'Reward offer image\'}}" />\r\n                        </div>\r\n                        <div class="card-title">{{card.title}}</div>\r\n                        <div class="card-buttons-container">\r\n                            <mee-rewards-status-indicator status="card.status"></mee-rewards-status-indicator>\r\n                        </div>\r\n                        <mee-rewards-card-badge count="card.numberEntries" status="card.status"></mee-rewards-card-badge>\r\n                    </div>\r\n                </card-content>\r\n            </mee-card>\r\n        </mee-card-group>\r\n    </div>\r\n    <div id="allCards" ng-if="!$ctrl.isMobileRedesign">\r\n        <div class="card-carousel" ng-if="!$ctrl.isGridFlight()">\r\n            <div class="section-title margin-bottom-32" mee-heading="heading" role="heading" aria-level="2">\r\n                {{$ctrl.cmsData.strings["hvapage_mod2_sectiontitle"]}}\r\n            </div>\r\n            <mee-card-group role="region" aria-label="All bonus entry options">\r\n                <mee-card\r\n                    ng-repeat="card in $ctrl.hvaCards track by card.name"\r\n                    ng-style="{\'transform\': \'translateX(\' + $ctrl.translateX + \'px)\'}"\r\n                    class="all-hva-cards">\r\n                    <card-content>\r\n                        <div\r\n                            class="clickable-hva-card"\r\n                            role="button"\r\n                            tabindex="0"\r\n                            ng-click="$ctrl.openModal(card)"\r\n                            aria-label="{{card.title}} - {{$ctrl.getStatusText(card.status)}}"\r\n                            ng-keydown="$event.keyCode === 13 && $ctrl.openModal(card)"\r\n                            aria-haspopup="dialog">\r\n                            <div class="imageContainer">\r\n                                <img\r\n                                    mee-image\r\n                                    ng-src="{{card.image.source}}"\r\n                                    alt="{{card.image.alternateText || card.title || \'Sweepstakes HVA image\'}}" />\r\n                            </div>\r\n\r\n                            <div class="card-title">{{card.title}}</div>\r\n                            <div class="card-buttons-container">\r\n                                <mee-rewards-status-indicator status="card.status"></mee-rewards-status-indicator>\r\n                            </div>\r\n                            <mee-rewards-card-badge count="card.numberEntries" status="card.status"></mee-rewards-card-badge>\r\n                        </div>\r\n                    </card-content>\r\n                </mee-card>\r\n            </mee-card-group>\r\n            <mee-rewards-dot-progress-indicator\r\n                size="$ctrl.hvaCards.length"\r\n                current-index="$ctrl.currentIndex"\r\n                scroll-left="$ctrl.scrollLeft()"\r\n                scroll-right="$ctrl.scrollRight()">\r\n            </mee-rewards-dot-progress-indicator>\r\n        </div>\r\n        <div\r\n            id="allCardsGrid"\r\n            class="centered-cards-view margin-top-72 padding-bottom-96"\r\n            ng-if="$ctrl.isGridFlight()">\r\n            <div class="section-title margin-top-56 margin-bottom-32" mee-heading="heading" role="heading" aria-level="2">\r\n                {{ $ctrl.cmsData.strings["hvapage_mod2_sectiontitle"] }}\r\n            </div>\r\n            <div id="allCardsFilter">\r\n                <mee-rewards-highvalue-sweepstakes-filter ng-if="!$ctrl.currentUser.isAnonymous" cards="$ctrl.hvaCards"\r\n                    has-featured-card="$ctrl.featuredCards.length > 0"></mee-rewards-highvalue-sweepstakes-filter>\r\n            </div>\r\n            <div class="all-cards">\r\n                <mee-card-group role="region" aria-label="All bonus entry grid">\r\n                    <mee-card\r\n                        ng-repeat="card in $ctrl.hvaCards track by card.name"\r\n                        data-categories=\'["{{card.status}}"]\'>\r\n                        <card-content>\r\n                            <div\r\n                                target="_self"\r\n                                tabindex="0"\r\n                                class="clickable-hva-card"\r\n                                ng-click="$ctrl.openModal(card, true)"\r\n                                aria-label="{{card.title}} - {{$ctrl.getStatusText(card.status)}}"\r\n                                ng-keydown="$event.keyCode === 13 && $ctrl.openModal(card, true)"\r\n                                aria-haspopup="dialog">\r\n                                <div class="imageContainer">\r\n                                    <img\r\n                                        mee-image\r\n                                        ng-src="{{card.image.source}}"\r\n                                        alt="{{card.image.alternateText || card.title || \'Sweepstakes HVA image\'}}" />\r\n                                </div>\r\n                                <div class="card-title">{{card.title}}</div>\r\n                                <div class="card-buttons-container">\r\n                                    <mee-rewards-status-indicator status="card.status"></mee-rewards-status-indicator>\r\n                                </div>\r\n                                <mee-rewards-card-badge count="card.numberEntries" status="card.status"></mee-rewards-card-badge>\r\n                            </div>\r\n                        </card-content>\r\n                    </mee-card>\r\n                </mee-card-group>\r\n            </div>\r\n        </div>\r\n        <div id="shareAndWinSection" class="margin-top-72">\r\n            <mee-rewards-highvalue-sweepstakes-earn-more-entries\r\n                dashboard-result="$ctrl.dashboardResult"\r\n                more-chances-to-win-title="$ctrl.cmsData.strings[\'hvapage_mod4_sectiontitle\']"\r\n                share-and-win-description="$ctrl.shareAndWinDesp"\r\n                share-and-win-hero-image-url="$ctrl.shareAndWinHeroImg"\r\n                is-invite-modal-visible="$ctrl.isInviteModalVisible"\r\n                is-mobile-redesign="$ctrl.isMobileRedesign"\r\n                scroll-to-name="\'featuredCards\'">\r\n            </mee-rewards-highvalue-sweepstakes-earn-more-entries>\r\n        </div>\r\n\r\n        <div\r\n            class="modal-overlay"\r\n            ng-click="$ctrl.closeModal()"></div>\r\n        <mee-rewards-highvalue-sweepstakes-hva-modal\r\n            selected-card="$ctrl.selectedCard"\r\n            is-deep-link="$ctrl.isDeepLink"\r\n            ng-show="$ctrl.isModalOpen"\r\n            close-modal="$ctrl.closeModal()"\r\n            scroll-to-term="$ctrl.scrollToFAQ()">\r\n        </mee-rewards-highvalue-sweepstakes-hva-modal>\r\n        <mee-rewards-share-and-win-invite-modal\r\n            ng-show="$ctrl.isInviteModalVisible"\r\n            close-modal="$ctrl.closeInviteModal()"></mee-rewards-share-and-win-invite-modal>\r\n    </div>\r\n    <div id="hvaCardGroupMobileOnly" ng-if="$ctrl.isMobileRedesign">\r\n        <div\r\n            id="featuredCardsMobileOnly"\r\n            ng-if="$ctrl.featuredCards.length > 0 && $ctrl.isMobileRedesign">\r\n            <mee-card-group class="featured-cards" role="region" aria-label="Featured bonus entries mobile">\r\n                <div class="section-title margin-bottom-16 margin-top-15" mee-heading="heading" role="heading" aria-level="2">\r\n                    {{$ctrl.cmsData.strings["hvapage_mod1_sectiontitle"]}}\r\n                </div>\r\n                <mee-card\r\n                    ng-repeat="card in $ctrl.featuredCards track by card.name"\r\n                    class="featured-card">\r\n                    <card-content>\r\n                        <div role="button" tabindex="0"\r\n                            class="clickable-hva-card"\r\n                            ng-click="$ctrl.openModal(card, true)"\r\n                            aria-label="{{card.title}} - {{$ctrl.getStatusText(card.status)}}"\r\n                            ng-keydown="$event.keyCode === 13 && $ctrl.openModal(card, true)"\r\n                            aria-haspopup="dialog">\r\n                            <div class="imageContainer">\r\n                                <img\r\n                                    mee-image\r\n                                    ng-src="{{card.image.source}}"\r\n                                    alt="{{card.image.alternateText || card.title || \'Sweepstakes HVA image\'}}" />\r\n                            </div>\r\n                            <div class="hva-card-content">\r\n                                <div class="card-title">{{card.title}}</div>\r\n                                <div class="card-buttons-badge-container">\r\n                                    <mee-rewards-card-badge count="card.numberEntries" status="card.status"></mee-rewards-card-badge>\r\n                                    <mee-rewards-status-indicator status="card.status"></mee-rewards-status-indicator>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </card-content>\r\n                </mee-card>\r\n            </mee-card-group>\r\n        </div>\r\n        <mee-rewards-share-and-win-invite\r\n            ng-if="!$ctrl.currentUser.isAnonymous"\r\n            dashboard-result="$ctrl.dashboardResult"\r\n            hero-image-url="$ctrl.shareAndWinHeroImg"\r\n            copy-text\r\n            is-invite-modal-visible="$ctrl.isInviteModalVisible"\r\n            is-mobile-redesign="$ctrl.isMobileRedesign">\r\n        </mee-rewards-share-and-win-invite>\r\n        <div id="allCardsMobileOnly" ng-if="$ctrl.isMobileRedesign">\r\n            <div class="section-title margin-bottom-16" mee-heading="heading" role="heading" aria-level="2">\r\n                {{$ctrl.cmsData.strings["hvapage_mod2_sectiontitle"]}}\r\n            </div>\r\n            <div id="allCardsFilter">\r\n                <mee-rewards-highvalue-sweepstakes-filter ng-if="!$ctrl.currentUser.isAnonymous" cards="$ctrl.hvaCards"\r\n                    has-featured-card="$ctrl.featuredCards.length > 0"></mee-rewards-highvalue-sweepstakes-filter>\r\n            </div>\r\n            <div id="all-cards-mobile">\r\n                <mee-card-group class="featured-cards" role="region" aria-label="All bonus entries mobile">\r\n                    <mee-card\r\n                        id="allhvacards"\r\n                        ng-repeat="card in $ctrl.hvaCards track by card.name"\r\n                        class="featured-card"\r\n                        data-categories=\'["{{card.status}}"]\'>\r\n                        <card-content>\r\n                            <div tabindex="0"\r\n                                class="clickable-hva-card"\r\n                                ng-click="$ctrl.openModal(card, true)"\r\n                                aria-label="{{card.title}} - {{$ctrl.getStatusText(card.status)}}"\r\n                                ng-keydown="$event.keyCode === 13 && $ctrl.openModal(card, true)"\r\n                                aria-haspopup="dialog">\r\n                                <div class="imageContainer">\r\n                                    <img\r\n                                        mee-image\r\n                                        ng-src="{{card.image.source}}"\r\n                                        alt="{{card.image.alternateText || card.title || \'Sweepstakes HVA image\'}}" />\r\n                                </div>\r\n                                <div class="hva-card-content">\r\n                                    <div class="card-title">{{card.title}}</div>\r\n                                    <div class="card-buttons-badge-container">\r\n                                        <mee-rewards-card-badge count="card.numberEntries" status="card.status" is-mobile-redesign="$ctrl.isMobileRedesign"></mee-rewards-card-badge>\r\n                                        <mee-rewards-status-indicator status="card.status"></mee-rewards-status-indicator>\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                        </card-content>\r\n                    </mee-card>\r\n                </mee-card-group>\r\n            </div>\r\n        </div>\r\n        <div\r\n            class="modal-overlay"\r\n            ng-show="$ctrl.isModalOpen"\r\n            ng-click="$ctrl.closeModal()"></div>\r\n        <mee-rewards-highvalue-sweepstakes-hva-modal\r\n            selected-card="$ctrl.selectedCard"\r\n            is-deep-link="$ctrl.isDeepLink"\r\n            ng-show="$ctrl.isModalOpen"\r\n            close-modal="$ctrl.closeModal()"\r\n            scroll-to-term="$ctrl.scrollToFAQ()">\r\n        </mee-rewards-highvalue-sweepstakes-hva-modal>\r\n        <mee-rewards-share-and-win-invite-modal\r\n            ng-show="$ctrl.isInviteModalVisible"\r\n            close-modal="$ctrl.closeInviteModal()"></mee-rewards-share-and-win-invite-modal>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-hva-modal.html",'<div id="highvalue-sweepstakes-hva-modal" role="dialog" aria-modal="true" aria-labelledby="hva-modal-title" ng-keydown="$event.keyCode === 27 && $ctrl.closeModal()">\r\n    <div id="highvalue-sweepstakes-hva-window" class="modal">\r\n        <div class="hva-modal-content autoredeem-confirmed-content">\r\n            <div class="modal-buttons">\r\n                <h2 id="hva-modal-title" class="modal-title">{{ $ctrl.entryCountingHeader }}</h2>\r\n                <button type="button" id="highvalue-sweepstakes-hva-modal-close-cross" data-bi-id="highvalue-sweepstakes-hva-modal-close-cross" class="hva-modal-close-cross" ng-click="$ctrl.closeModal()" aria-label="Close" ng-keydown="$event.keyCode === 13 && $ctrl.closeModal()">&times;</button>\r\n            </div>\r\n            \r\n            <div class="modal-content-wrapper">\r\n                <div class="imageContainer">\r\n                    <img mee-image ng-src="{{$ctrl.selectedCard.modalImage.source}}" alt="{{$ctrl.selectedCard.modalImage.alternateText || $ctrl.selectedCard.title || \'Sweepstakes HVA image\'}}" />\r\n                    <mee-rewards-card-badge count="$ctrl.numberEntries" status="$ctrl.status"></mee-rewards-card-badge>\r\n                </div>\r\n                <h2 class="modal-header">{{$ctrl.selectedCard.title}}</h2>\r\n                <div class="card-content" ng-bind-html="$ctrl.content"></div>\r\n            </div>\r\n            <div class="modal-buttons">\r\n                <a  target="_blank" ng-href="{{$ctrl.termLink}}" class="hva-modal-secondary-submit" aria-label="{{ $ctrl.ctaButtonText }}">\r\n                    {{ $ctrl.termText }}\r\n                </a>\r\n                <div ng-if="$ctrl.selectedCard.status === \'Complete\' && $ctrl.actionText">\r\n                    <mee-rewards-status-indicator status="$ctrl.selectedCard.status"></mee-rewards-status-indicator>\r\n                </div>\r\n                <div ng-if="$ctrl.selectedCard.status !== \'Complete\' && $ctrl.actionText">\r\n                    <a target="_blank" ng-href="{{$ctrl.actionLink}}" class="hva-modal-submit" aria-label="{{ $ctrl.ctaButtonText }}">\r\n                        {{ $ctrl.actionText }}\r\n                    </a>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-intro.html",'<h2 id="intro-section-heading" class="sweepstakes-header text-align-center">{{$ctrl.nonLocalizedCmsData.strings[\'promo_mod2_sectiontitle\']}}</h2>\r\n\r\n<div id="intro-card-container" class="intro-card-container">\r\n    <div class="intro-card">\r\n        <div id="into-join-image-link"\r\n           class="intro-image-link">\r\n            <img ng-src="{{$ctrl.areaConfig.highValueSweepstakesConfig.sweepstakesCardImageUrl}}"\r\n                 alt="{{$ctrl.nonLocalizedCmsData.strings[\'sweepstakes_intro_sweepstakes_card_banner_alt\']}}">\r\n        </div>\r\n        \r\n\r\n        <div class="intro-card-caption">\r\n            <p mee-heading="heading" class="intro-title">{{$ctrl.nonLocalizedCmsData.strings[\'promo_mod2a_title_step1\']}}</p>\r\n            <p id="intro-rewards" class="intro-description" ng-bind-html="$ctrl.nonLocalizedCmsData.strings[\'promo_mod2a_body_step1\']"></p>\r\n        </div>\r\n    </div>\r\n\r\n    <div class="intro-card">\r\n        <div id="intro-dashboard-image-link"\r\n           class="intro-image-link">\r\n            <img ng-src="{{$ctrl.areaConfig.highValueSweepstakesConfig.dashboardCardImageUrl}}"\r\n                 alt="{{$ctrl.nonLocalizedCmsData.strings[\'sweepstakes_intro_sweepstakes_card_banner_alt\']}}">\r\n        </div>\r\n\r\n        <div class="intro-card-caption">\r\n            <p mee-heading="heading" class="intro-title">{{$ctrl.nonLocalizedCmsData.strings[\'promo_mod2b_title_step2\']}}</p>\r\n            <p id="intro-points" class="intro-description" ng-bind-html="$ctrl.nonLocalizedCmsData.strings[\'promo_mod2b_body_step2\']"></p>\r\n        </div>\r\n    </div>\r\n\r\n    <div class="intro-card last-intro-card">\r\n        <div id="intro-redeem-img-link"\r\n           class="intro-image-link">\r\n            <img ng-src="{{$ctrl.areaConfig.highValueSweepstakesConfig.redeemCardImageUrl}}"\r\n                 alt="{{$ctrl.nonLocalizedCmsData.strings[\'sweepstakes_intro_sweepstakes_card_banner_alt\']}}">\r\n        </div>\r\n\r\n        <div class="intro-card-caption">\r\n            <p mee-heading="heading" class="intro-title">{{$ctrl.nonLocalizedCmsData.strings[\'promo_mod2c_title_step3\']}}</p>\r\n            <p id="intro-redeem" class="intro-description" ng-bind-html="$ctrl.nonLocalizedCmsData.strings[\'promo_mod2c_body_step3\']"></p>\r\n        </div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-landing-page.html",'<div id="oneUiSweepstakes" class="rewardsContent">\r\n    <img ng-src="{{ $ctrl.instantWinSweepstakesHeroBackground }}" alt="Background" class="bg-img" />\r\n    <div ng-class="{ \'background-layer-v3\': $ctrl.isInstantWinsSweepstake, \'background-layer-v2\': !$ctrl.isInstantWinsSweepstake }">\r\n        <div id="landingPageContainer">\r\n            <div id="heroBanner" class="sweepstakesContent display-block" ng-class="{\'min-height-500\': !$ctrl.isMobileRedesign, \'min-height-auto\': $ctrl.isMobileRedesign }">\r\n                <mee-rewards-highvalue-sweepstakes-hero-banner\r\n                    dashboard-result="$ctrl.dashboardResult"\r\n                    banner-title="$ctrl.heroBannerTitleText"\r\n                    description="$ctrl.heroBannerBodyText"\r\n                    cta-button-url="$ctrl.heroBannerUrl"\r\n                    cta-button-text="$ctrl.heroBannerUrlText"\r\n                    cta-button-function="$ctrl.ctaButtonFunction()"\r\n                    show-cta-button="$ctrl.showCtaButton"\r\n                    legal-text="$ctrl.nonLocalizedCmsData.strings[\'promo_hero_disclaimer\']"\r\n                    hero-image-desktop-url="$ctrl.heroImageDesktopUrl"\r\n                    hero-image-mobile-url="$ctrl.heroImageMobileUrl"\r\n                    is-mobile-redesign="$ctrl.isMobileRedesign">\r\n                </mee-rewards-highvalue-sweepstakes-hero-banner>\r\n            </div>\r\n            <div class="sweepstakesContent margin-top-72">\r\n                <mee-rewards-highvalue-sweepstakes-countdown-timer\r\n                    ng-if="$ctrl.sweepstakeEndDate && $ctrl.showCountdownTimer"\r\n                    sweepstake-end-date="$ctrl.sweepstakeEndDate">\r\n                </mee-rewards-highvalue-sweepstakes-countdown-timer>\r\n            </div>\r\n            <div class="sweepstakesContent">\r\n                <mee-rewards-instant-win-section\r\n                    section-title="$ctrl.instantWinSectionTitle"\r\n                    section-subtitle="$ctrl.isInstantWinOnlyCountries ? $ctrl.nonLocalizedCmsData.strings[\'promo_mod1_sectionbody_iwonlymarkets\'] : $ctrl.nonLocalizedCmsData.strings[\'promo_mod1_sectionbody\']"\r\n                    left-image-url="$ctrl.leftImageUrl"\r\n                    right-image-url="$ctrl.rightImageUrl"\r\n                    section-url="$ctrl.heroBannerUrl"\r\n                    cta-button-function="$ctrl.ctaButtonFunction()"\r\n                    show-cta-button="$ctrl.showCtaButton">\r\n                </mee-rewards-instant-win-section>\r\n                <mee-rewards-highvalue-sweepstakes-intro></mee-rewards-highvalue-sweepstakes-intro>\r\n            </div>\r\n            <div id="bottomHeroBanner" class="sweepstakesContent">\r\n                <mee-rewards-highvalue-sweepstakes-hero-banner\r\n                    ng-if="$ctrl.showFooterBanner"\r\n                    dashboard-result="$ctrl.dashboardResult"\r\n                    banner-title="$ctrl.isInstantWinOnlyCountries ? $ctrl.nonLocalizedCmsData.strings[\'promo_mod3_title_iwonlymarkets\'] : $ctrl.nonLocalizedCmsData.strings[\'promo_mod3_title\']"\r\n                    description="$ctrl.buttomHeroBannerDescriptionBody"\r\n                    cta-button-url="$ctrl.heroBannerUrl"\r\n                    cta-button-text="$ctrl.heroBannerUrlText"\r\n                    use-footer-typography="true"\r\n                    use-centered-text="true">\r\n                </mee-rewards-highvalue-sweepstakes-hero-banner>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <mee-rewards-share-and-win-invite-modal ng-show="$ctrl.isInviteModalVisible"\r\n        close-modal="$ctrl.closeInviteModal()"></mee-rewards-share-and-win-invite-modal>\r\n    <mee-rewards-highvalue-sweepstakes-modal ng-show="$ctrl.isModalOpen" is-visible="$ctrl.isModalOpen" modal-style="confetti"\r\n        close-modal="$ctrl.closeModalFunction()" left-background-image="$ctrl.leftBackgroundImage"\r\n        right-background-image="$ctrl.rightBackgroundImage">\r\n        <div class="modal-container">\r\n            <div class="mobile-modal-image">\r\n                <img ng-src="{{$ctrl.mobileModalImage}}" alt="QR Code for additional entry" />\r\n            </div>\r\n            <div class="sweepstakes-modal-title">{{$ctrl.cmsData.strings[\'hva_congratsoverlay_title_pc\']}}</div>\r\n            <div class="sweepstakes-modal-body sweepstakes-modal-body-hide">{{$ctrl.cmsData.strings["hva_congratsoverlay_body1_pc"]}}</div>\r\n            <div class="sweepstakes-modal-body">{{$ctrl.cmsData.strings["hva_congratsoverlay_body2_pc"]}}</div>\r\n            <div>\r\n                <img ng-src="{{$ctrl.bingmobileappQrcode}}" alt="QR Code for additional entry" class="qr-code-image" />\r\n                <button class="qr-code-button" ng-click="$ctrl.$window.open($ctrl.bingMobileAppUrl, \'_blank\')">\r\n                    {{$ctrl.cmsData.links["sweepstakes-highvalue-modal-bing-mobile-app-cta"].text}}\r\n                </button>\r\n            </div>\r\n        </div>\r\n    </mee-rewards-highvalue-sweepstakes-modal>\r\n    <mee-rewards-highvalue-sweepstakes-faq></mee-rewards-highvalue-sweepstakes-faq>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-more-entries.html",'<div id="sweepstakesMoreEntriesContainer">\r\n    <div class="sweepstakesContent" ng-class="{\'min-height-500\': !$ctrl.isMobileRedesign, \'min-height-auto\': $ctrl.isMobileRedesign }">\r\n        <mee-rewards-highvalue-sweepstakes-hero-banner\r\n            dashboard-result="$ctrl.dashboardResult"\r\n            banner-title="$ctrl.heroBannerTitle"\r\n            description="$ctrl.heroBannerDescription"\r\n            cta-button-url="$ctrl.heroBannerUrl"\r\n            cta-button-function="$ctrl.ctaButtonFunction()"\r\n            show-cta-button="$ctrl.showCtaButton"\r\n            cta-button-text="$ctrl.ctaButtonText"\r\n            legal-text="$ctrl.heroBannerLegalText"\r\n            use-anonymous-cta-padding="true"\r\n            is-mobile-redesign="$ctrl.isMobileRedesign"\r\n            hero-image-desktop-url="$ctrl.heroImageDesktopUrl"\r\n            hero-image-mobile-url="$ctrl.heroImageMobileUrl"\r\n            sweepstake-info="$ctrl.sweepstakeInfo"\r\n            show-entry-counter="true"\r\n        >\r\n        </mee-rewards-highvalue-sweepstakes-hero-banner>\r\n    </div>\r\n    <mee-rewards-highvalue-sweepstakes-entry-banner\r\n        ng-if="!$ctrl.currentUser.isAnonymous && !$ctrl.isMobileRedesign"\r\n        dashboard-result="$ctrl.dashboardResult"\r\n        sweepstake-info="$ctrl.sweepstakeInfo"\r\n    ></mee-rewards-highvalue-sweepstakes-entry-banner>\r\n    <mee-rewards-highvalue-sweepstakes-hva-card-item-group\r\n        dashboard-result="$ctrl.dashboardResult"\r\n        sweepstake-info="$ctrl.sweepstakeInfo"\r\n        is-mobile-redesign="$ctrl.isMobileRedesign"\r\n        is-invite-modal-visible="$ctrl.isInviteModalVisible"\r\n        role="region"\r\n        aria-label="Bonus entry options"\r\n    ></mee-rewards-highvalue-sweepstakes-hva-card-item-group>\r\n    <mee-rewards-instant-win-section\r\n        section-title="$ctrl.instantWinSectionTitle"\r\n        section-subtitle="$ctrl.cmsData.strings[\'promo_mod1_sectionbody\']"\r\n        left-image-url="$ctrl.leftImageUrl"\r\n        right-image-url="$ctrl.rightImageUrl"\r\n        section-url="$ctrl.heroBannerUrl"\r\n        show-cta-button="$ctrl.showCtaButton"\r\n        cta-button-function="$ctrl.ctaButtonFunction()">\r\n    </mee-rewards-instant-win-section>\r\n    <mee-rewards-highvalue-sweepstakes-modal ng-show="$ctrl.isModalOpen" is-visible="$ctrl.isModalOpen" modal-style="confetti"\r\n        close-modal="$ctrl.closeModalFunction()" left-background-image="$ctrl.leftBackgroundImage"\r\n        right-background-image="$ctrl.rightBackgroundImage">\r\n        <div class="modal-container">\r\n            <div class="mobile-modal-image">\r\n                <img ng-src="{{$ctrl.mobileModalImage}}" alt="QR Code for additional entry" />\r\n            </div>\r\n            <div class="sweepstakes-modal-title">{{$ctrl.highvalueSweepstakesCmsData.strings[\'hva_congratsoverlay_title\']}}</div>\r\n            <div class="sweepstakes-modal-body sweepstakes-modal-body-hide">{{$ctrl.highvalueSweepstakesCmsData.strings["hva_congratsoverlay_body1_pc"]}}</div>\r\n            <div class="sweepstakes-modal-body">{{$ctrl.highvalueSweepstakesCmsData.strings["hva_congratsoverlay_body2_pc"]}}</div>\r\n            <div>\r\n                <img ng-src="{{$ctrl.bingmobileappQrcode}}" alt="QR Code for additional entry" class="qr-code-image" />\r\n                <button class="qr-code-button" ng-click="$ctrl.$window.open($ctrl.bingMobileAppUrl, \'_blank\')">\r\n                    {{$ctrl.highvalueSweepstakesCmsData.links["sweepstakes-highvalue-modal-bing-mobile-app-cta"].text}}\r\n                </button>\r\n            </div>\r\n        </div>\r\n    </mee-rewards-highvalue-sweepstakes-modal>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-signup-congrats.html",'<div id="highValueSweepstakesSignupCongratsContainer">\r\n    <div id="congratsHeroBanner">\r\n        <mee-rewards-highvalue-sweepstakes-hero-banner \r\n            dashboard-result="$ctrl.dashboardResult"\r\n            banner-title="$ctrl.heroBannerTitle"\r\n            description="$ctrl.nonLocalizedCmsData.strings[\'hero_banner_subtitle\']"\r\n            cta-button-url="$ctrl.hvaEarnMoreEntriesCtaButtonUrl"\r\n            cta-button-text="$ctrl.nonLocalizedCmsData.strings[\'earn_more_entries\']">\r\n        </mee-rewards-highvalue-sweepstakes-hero-banner>\r\n    </div>\r\n\r\n    <mee-rewards-highvalue-sweepstakes-earn-more-entries \r\n        dashboard-result="$ctrl.dashboardResult"\r\n        share-and-win-description="$ctrl.shareAndWinDesp"\r\n        share-and-win-hero-image-url="$ctrl.shareAndWinHeroImg"\r\n        is-invite-modal-visible="$ctrl.isInviteModalVisible">\r\n    </mee-rewards-highvalue-sweepstakes-earn-more-entries>\r\n    <mee-rewards-share-and-win-invite-modal ng-show="$ctrl.isInviteModalVisible" close-modal="$ctrl.closeInviteModal()"></mee-rewards-share-and-win-invite-modal>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-signup.html",'\x3c!-- High Value Sweepstakes Signup Container --\x3e\r\n<div id="highValueSweepstakesSignupContainer" class="sweepstakesContent">\r\n    \x3c!-- Success/Congratulations Page --\x3e\r\n    <div ng-if="$ctrl.shouldShowSignupOrCongratsPage()">\r\n        <mee-rewards-highvalue-sweepstakes-signup-congrats></mee-rewards-highvalue-sweepstakes-signup-congrats>\r\n    </div>\r\n\r\n    \x3c!-- Main Signup Form --\x3e\r\n    <div role="dialog" \r\n         ng-class="$ctrl.getModalOrRegularFormClass()" \r\n         ng-if="!$ctrl.shouldShowSignupOrCongratsPage()">\r\n        \r\n        \x3c!-- Hero Banner Section --\x3e\r\n        <div id="signupHeroBanner" styles="min-height-500">\r\n            <mee-rewards-highvalue-sweepstakes-hero-banner \r\n                dashboard-result="$ctrl.dashboardResult"\r\n                banner-title="$ctrl.heroBannerTitle"\r\n                banner-second-title="$ctrl.heroBannerSecondTitle"\r\n                description="$ctrl.heroBannerDescription"\r\n                cta-button-url="$ctrl.signinUrl"\r\n                cta-button-text="$ctrl.heroBannerSigninUrlText"\r\n                legal-text="$ctrl.headerBannerLegalText"\r\n                use-anonymous-cta-padding="true"\r\n                hero-image-desktop-url="$ctrl.heroImageDesktopUrl"\r\n                hero-image-mobile-url="$ctrl.heroImageMobileUrl">\r\n            </mee-rewards-highvalue-sweepstakes-hero-banner>\r\n        </div>\r\n        \r\n        <div id="results-panel"></div>\r\n\r\n        \x3c!-- Form Content --\x3e\r\n        <div ng-class="$ctrl.getContentClass()">\r\n            \x3c!-- Modal Close Button --\x3e\r\n            <span class="close"\r\n                  ng-show="$ctrl.isModalOpen"\r\n                  ng-click="$ctrl.toggleFormModal()"\r\n                  aria-label="Close modal"\r\n                  role="button"\r\n                  tabindex="0">\r\n                &times;\r\n            </span>\r\n\r\n            \x3c!-- Form Title --\x3e\r\n            <div class="entry-form" aria-label="{{$ctrl.formTitle}}" mee-heading="heading">\r\n                {{$ctrl.formTitle}}\r\n            </div>\r\n\r\n            \x3c!-- Entry Statement and Required Fields Warning --\x3e\r\n            <div class="entry-statement">\r\n                <div class="statment">\r\n                    <p ng-bind-html="$ctrl.entryFormStatementBody1"></p>\r\n                    <br />\r\n                    <p ng-bind-html="$ctrl.entryFormStatementBody2"></p>\r\n                </div>\r\n\r\n                <div class="warning">\r\n                    {{$ctrl.formWarningText}}\r\n                </div>\r\n            </div>\r\n\r\n            \x3c!-- Personal Information Section --\x3e\r\n            <section aria-labelledby="personal-info-heading">\r\n                <h3 id="personal-info-heading" class="visually-hidden">Personal Information</h3>\r\n\r\n                \x3c!-- First and Last Name Fields --\x3e\r\n                <div class="form-row" id="nameRow">\r\n                    <div class="form-group">\r\n                        <label for="firstName">\r\n                            {{$ctrl.firstNameLabel}}\r\n                        </label>\r\n                        <input maxlength="50"\r\n                               type="text"\r\n                               id="firstName"\r\n                               ng-model="$ctrl.currentUser.userInformation.firstName"\r\n                               required\r\n                               aria-required="true"\r\n                               ng-readonly="$ctrl.currentUser.isAnonymous"\r\n                               ng-click="$ctrl.handleInputClick()"\r\n                               ng-change="$ctrl.handleFieldsStateChange()"\r\n                               ng-class="{\'clickable-input\': $ctrl.currentUser.isAnonymous}">\r\n                    </div>\r\n\r\n                    <div class="form-group">\r\n                        <label for="lastName">\r\n                            {{$ctrl.lastNameLabel}}\r\n                        </label>\r\n                        <input maxlength="50"\r\n                               type="text"\r\n                               id="lastName"\r\n                               ng-model="$ctrl.currentUser.userInformation.lastName"\r\n                               required\r\n                               aria-required="true"\r\n                               ng-readonly="$ctrl.currentUser.isAnonymous"\r\n                               ng-click="$ctrl.handleInputClick()"\r\n                               ng-change="$ctrl.handleFieldsStateChange()"\r\n                               ng-class="{\'clickable-input\': $ctrl.currentUser.isAnonymous}">\r\n                    </div>\r\n                </div>\r\n\r\n                \x3c!-- Email Address Field --\x3e\r\n                <div class="form-row" id="emailRow">\r\n                    <div class="form-group">\r\n                        <label for="email">\r\n                            {{$ctrl.emailLabel}}\r\n                        </label>\r\n                        <input ng-disabled="!$ctrl.currentUser.isAnonymous ? true : false"\r\n                               type="email"\r\n                               id="email"\r\n                               ng-model="$ctrl.currentUser.userInformation.email"\r\n                               required\r\n                               aria-required="true"\r\n                               ng-readonly="$ctrl.currentUser.isAnonymous"\r\n                               ng-click="$ctrl.handleInputClick()"\r\n                               ng-change="$ctrl.handleFieldsStateChange()"\r\n                               ng-class="{\'clickable-input\': $ctrl.currentUser.isAnonymous}">\r\n\r\n                        <div class="text-align-right font-size-13" ng-if="$ctrl.currentUser && !$ctrl.currentUser.isAnonymous">\r\n                            <div ng-bind-html="$ctrl.signoutMessage"></div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </section>\r\n\r\n            \x3c!-- Address Information Section --\x3e\r\n            <section aria-labelledby="address-info-heading">\r\n                <h3 id="address-info-heading" class="visually-hidden">Address Information</h3>\r\n\r\n                \x3c!-- Address Fields --\x3e\r\n                <div class="form-row" id="addressRow">\r\n                    <div class="form-group">\r\n                        <label for="address1">\r\n                            {{$ctrl.address1Label}}\r\n                        </label>\r\n                        <input type="text"\r\n                               id="address1"\r\n                               ng-model="$ctrl.currentUser.userInformation.addressLine1"\r\n                               required\r\n                               maxlength="100"\r\n                               aria-required="true"\r\n                               role="combobox"\r\n                               aria-autocomplete="list"\r\n                               aria-controls="address-suggestions"\r\n                               ng-readonly="$ctrl.currentUser.isAnonymous"\r\n                               ng-click="$ctrl.handleInputClick()"\r\n                               ng-change="$ctrl.handleFieldsStateChange()"\r\n                               ng-class="{\'clickable-input\': $ctrl.currentUser.isAnonymous}">\r\n\r\n                        <div id="address-suggestions" role="listbox" aria-label="Address suggestions"></div>\r\n                        <div id="address-suggestions-announcement"\r\n                             class="visually-hidden"\r\n                             aria-live="polite"\r\n                             aria-atomic="true"></div>\r\n                    </div>\r\n\r\n                    <div class="form-group">\r\n                        <label for="address2">\r\n                            {{$ctrl.address2Label}}\r\n                        </label>\r\n                        <input maxlength="50"\r\n                               type="text"\r\n                               id="address2"\r\n                               ng-model="$ctrl.currentUser.userInformation.addressLine2"\r\n                               ng-readonly="$ctrl.currentUser.isAnonymous"\r\n                               ng-click="$ctrl.handleInputClick()"\r\n                               ng-change="$ctrl.handleFieldsStateChange()"\r\n                               ng-class="{\'clickable-input\': $ctrl.currentUser.isAnonymous}">\r\n                    </div>\r\n                </div>\r\n\r\n                \x3c!-- City and State Fields --\x3e\r\n                <div class="form-row" id="cityStateRow">\r\n                    <div class="form-group">\r\n                        <label for="city">\r\n                            {{$ctrl.cityLabel}}\r\n                        </label>\r\n                        <input maxlength="50"\r\n                               type="text"\r\n                               id="city"\r\n                               ng-model="$ctrl.currentUser.userInformation.city"\r\n                               required\r\n                               aria-required="true"\r\n                               ng-readonly="$ctrl.currentUser.isAnonymous"\r\n                               ng-click="$ctrl.handleInputClick()"\r\n                               ng-change="$ctrl.handleFieldsStateChange()"\r\n                               ng-class="{\'clickable-input\': $ctrl.currentUser.isAnonymous}">\r\n                    </div>\r\n\r\n                    <div class="form-group">\r\n                        <label for="state">\r\n                            {{$ctrl.stateLabel}}\r\n                        </label>\r\n                        <input maxlength="50"\r\n                               type="text"\r\n                               id="state"\r\n                               ng-model="$ctrl.currentUser.userInformation.state"\r\n                               required\r\n                               aria-required="true"\r\n                               ng-readonly="$ctrl.currentUser.isAnonymous"\r\n                               ng-click="$ctrl.handleInputClick()"\r\n                               ng-change="$ctrl.handleFieldsStateChange()"\r\n                               ng-class="{\'clickable-input\': $ctrl.currentUser.isAnonymous}">\r\n                    </div>\r\n                </div>\r\n\r\n                \x3c!-- Country and Zipcode Fields --\x3e\r\n                <div class="form-row" id="countryZipcodeRow">\r\n                    <div class="form-group">\r\n                        <label for="countryNameDropdown">\r\n                            {{$ctrl.countryLabel}}\r\n                        </label>\r\n                        <select id="countryNameDropdown"\r\n                                aria-label="{{$ctrl.countryDropdownAriaLabel}}"\r\n                                ng-model="$ctrl.currentUser.userInformation.country"\r\n                                ng-readonly="$ctrl.currentUser.isAnonymous"\r\n                                ng-click="$ctrl.handleInputClick()"\r\n                                ng-class="{\'clickable-input\': $ctrl.currentUser.isAnonymous}"\r\n                                ng-change="$ctrl.handleFieldsStateChange()"\r\n                                required\r\n                                aria-required="true">\r\n                            <option ng-repeat="country in $ctrl.countryNameOptions"\r\n                                    value="{{country.value}}">\r\n                                {{country.text}}\r\n                            </option>\r\n                        </select>\r\n                    </div>\r\n\r\n                    <div class="form-group">\r\n                        <label for="zipcode">\r\n                            {{$ctrl.zipcodeLabel}}\r\n                        </label>\r\n                        <input maxlength="12"\r\n                               type="text"\r\n                               id="zipcode"\r\n                               ng-model="$ctrl.currentUser.userInformation.postalCode"\r\n                               required\r\n                               aria-required="true"\r\n                               ng-readonly="$ctrl.currentUser.isAnonymous"\r\n                               ng-click="$ctrl.handleInputClick()"\r\n                               ng-change="$ctrl.handleFieldsStateChange()"\r\n                               ng-class="{\'clickable-input\': $ctrl.currentUser.isAnonymous}">\r\n                    </div>\r\n                </div>\r\n            </section>\r\n\r\n            \x3c!-- Save and Continue Section --\x3e\r\n            <section aria-labelledby="save-and-continue-heading"\r\n                     class="save-and-continue"\r\n                     ng-show="$ctrl.shouldShowSaveAndContinue()">\r\n\r\n                \x3c!-- Phone Number Input for Save and Continue Flow --\x3e\r\n                <div class="form-row" id="phoneRow"\r\n                     ng-show="!$ctrl.shouldShowSmsVerification()">\r\n                    <div class="phone-input">\r\n                        <div class="input-block">\r\n                            <label for="countryCodeDropdownQR">\r\n                                {{$ctrl.countryCodeLabel}}\r\n                            </label>\r\n                            <select id="countryCodeDropdownQR"\r\n                                    aria-label="{{$ctrl.countryCodeDropdownAriaLabel}}"\r\n                                    ng-model="$ctrl.rewardsRedeemChallenge.Phone.CountryCode"\r\n                                    ng-change="$ctrl.handleFieldsStateChange()"\r\n                                    ng-click="$ctrl.handleInputClick()">\r\n                                <option ng-repeat="country in $ctrl.countryPhoneCodeOptions"\r\n                                        value="{{country.value}}"\r\n                                        ng-selected="country.selected">\r\n                                    {{country.text}}\r\n                                </option>\r\n                            </select>\r\n                        </div>\r\n\r\n                        <div class="input-block">\r\n                            <label for="phoneNumberInputQR">\r\n                                {{$ctrl.phoneNumberLabel}}\r\n                            </label>\r\n                            <input type="tel"\r\n                                   id="phoneNumberInputQR"\r\n                                   ng-model="$ctrl.rewardsRedeemChallenge.Phone.Number"\r\n                                   placeholder="{{$ctrl.phoneNumberPlaceholderQR}}"\r\n                                   autocomplete="tel"\r\n                                   inputmode="tel"\r\n                                   aria-label="{{$ctrl.phoneNumberAriaLabel}}"\r\n                                   ng-pattern="/^[\\d\\s\\-\\(\\)\\+]+$/"\r\n                                   maxlength="30"\r\n                                   required\r\n                                   aria-required="true"\r\n                                   ng-change="$ctrl.handleFieldsStateChange()"\r\n                                   ng-click="$ctrl.handleInputClick()">\r\n                        </div>\r\n                    </div>\r\n\r\n                    \x3c!-- Phone Input Error Display for Save and Continue Flow --\x3e\r\n                    <div class="form-row" ng-if="$ctrl.shouldShowPhoneInputError() && $ctrl.isStateChanged">\r\n                        <div class="error-phone-input" role="alert">\r\n                            <span ng-bind-html="$ctrl.errorMessage"></span>\r\n                        </div>\r\n                    </div>\r\n\r\n                    \x3c!-- General Error Messages --\x3e\r\n                    <div class="form-row" ng-if="$ctrl.hasVerificationError()">\r\n                        <div class="error-verification" role="alert">\r\n                            <span ng-bind-html="$ctrl.errorMessage"></span>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                \x3c!-- Terms and Conditions Section --\x3e\r\n                <div class="form-row" id="termsRow">\r\n                    <div class="form-group-terms" ng-class="{\'mobile\': $ctrl.isMobile}">\r\n                        <input ng-disabled="$ctrl.currentUser.isAnonymous"\r\n                               type="checkbox"\r\n                               ng-model="$ctrl.currentUser.userInformation.isAgreed"\r\n                               ng-attr-aria-label="{{$ctrl.entryFormLegalText}}">\r\n                        <span ng-bind-html="$ctrl.entryFormLegalText"></span>\r\n                    </div>\r\n                </div>\r\n\r\n                \x3c!-- Save and Continue Button for Save and Continue Flow --\x3e\r\n                <button type="submit"\r\n                        class="submit-btn save"\r\n                        ng-click="$ctrl.validatePhoneNumberAndSavePiiAsync()"\r\n                        ng-disabled="$ctrl.isSaveAndContinueButtonDisabled()"\r\n                        ng-attr-aria-label="{{$ctrl.getSaveAndContinueButtonText()}}">\r\n                    {{$ctrl.getSaveAndContinueButtonText()}}\r\n                </button>\r\n\r\n                \x3c!-- TODO: remove after flight cleanup Alternative Verification Method Toggle --\x3e\r\n                <div class="more-ways-to-verify s"\r\n                     ng-show="$ctrl.areaConfig.flights[\'smsorqrcode\']"\r\n                     ng-click="$ctrl.toggleChallengeType()"\r\n                     role="button"\r\n                     tabindex="0"\r\n                     ng-keydown="$event.keyCode === 13 && $ctrl.toggleChallengeType()">\r\n                    {{$ctrl.moreWaysToVerifyText}}\r\n                </div>\r\n            </section>\r\n\r\n            \x3c!-- Phone Number Verification Section (SMS/Call) --\x3e\r\n            <section aria-labelledby="verification-heading"\r\n                     ng-show="$ctrl.shouldShowSmsVerification()">\r\n                <h3 id="sms-verification-heading" class="verify" mee-heading="heading">\r\n                    {{$ctrl.letsVerifyItsYouTextSms}}\r\n                </h3>\r\n\r\n                \x3c!-- Code Delivery Method Selection --\x3e\r\n                <fieldset>\r\n                    <legend class="visually-hidden">Choose verification method</legend>\r\n\r\n                    <div class="form-row" id="sendCodeOptionsRow">\r\n                        <div class="form-group-radio">\r\n                            <input type="radio"\r\n                                   id="sendCodeByText"\r\n                                   name="verificationMethod"\r\n                                   value="SMS"\r\n                                   ng-model="$ctrl.rewardsRedeemChallenge.SendingType"\r\n                                   ng-init="$ctrl.rewardsRedeemChallenge.SendingType=\'SMS\'"\r\n                                   ng-click="$ctrl.handleInputClick()">\r\n                            <label for="sendCodeByText">\r\n                                {{$ctrl.smsTextCheckboxLabel}}\r\n                            </label>\r\n                        </div>\r\n\r\n                        <div class="form-group-radio">\r\n                            <input type="radio"\r\n                                   id="sendCodeByPhone"\r\n                                   name="verificationMethod"\r\n                                   value="Call"\r\n                                   ng-model="$ctrl.rewardsRedeemChallenge.SendingType"\r\n                                   ng-click="$ctrl.handleInputClick()">\r\n                            <label for="sendCodeByPhone">\r\n                                {{$ctrl.landlineCheckboxLabel}}\r\n                            </label>\r\n                        </div>\r\n                    </div>\r\n                </fieldset>\r\n\r\n                \x3c!-- Phone Number Input --\x3e\r\n                <div class="form-row" id="phoneRow">\r\n                    <div class="phone-input">\r\n                        <div class="input-block">\r\n                            <label for="countryCodeDropdown">\r\n                                {{$ctrl.countryCodeLabel}}\r\n                            </label>\r\n                            <select id="countryCodeDropdown"\r\n                                    aria-label="{{$ctrl.countryCodeDropdownAriaLabel}}"\r\n                                    ng-model="$ctrl.rewardsRedeemChallenge.Phone.CountryCode"\r\n                                    ng-click="$ctrl.handleInputClick()"\r\n                                    required\r\n                                    aria-required="true">\r\n                                <option ng-repeat="country in $ctrl.countryPhoneCodeOptions"\r\n                                        value="{{country.value}}"\r\n                                        ng-selected="country.selected">\r\n                                    {{country.text}}\r\n                                </option>\r\n                            </select>\r\n                        </div>\r\n\r\n                        <div class="input-block">\r\n                            <label for="phoneNumberInput">\r\n                                {{$ctrl.phoneNumberLabel}}\r\n                            </label>\r\n                            <input type="tel"\r\n                                   ng-model="$ctrl.rewardsRedeemChallenge.Phone.Number"\r\n                                   placeholder="{{$ctrl.phoneNumberPlaceholder}}"\r\n                                   autocomplete="tel"\r\n                                   inputmode="tel"\r\n                                   aria-label="{{$ctrl.phoneNumberAriaLabel}}"\r\n                                   ng-pattern="/^[\\d\\s\\-\\(\\)\\+]+$/"\r\n                                   maxlength="30"\r\n                                   required\r\n                                   aria-required="true"\r\n                                   ng-click="$ctrl.handleInputClick()">\r\n                        </div>\r\n\r\n                        <div class="input-block-button">\r\n                            <label class="send-code-label" aria-hidden="true">&nbsp;</label>\r\n                            <button id="sendCodeButton"\r\n                                    type="button"\r\n                                    class="send-code-btn"\r\n                                    ng-click="$ctrl.validatePhoneNumberAndSubmitChallengeAsync()"\r\n                                    ng-disabled="$ctrl.isSendCodeButtonDisabled()"\r\n                                    ng-attr-aria-label="{{$ctrl.sendCodeButtonAriaLabel}}">\r\n                                {{$ctrl.getSendingButtonText()}}\r\n                            </button>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class="data-rate-may-apply">\r\n                        <span>{{$ctrl.smsTooltipText}}</span>\r\n                    </div>\r\n\r\n                    \x3c!-- Countdown Message --\x3e\r\n                    <div ng-if="$ctrl.countdownMessage" class="countdown-message" role="alert">\r\n                        <span ng-bind-html="$ctrl.countdownMessage"></span>\r\n                    </div>\r\n\r\n                    \x3c!-- Phone Input Error Messages --\x3e\r\n                    <div class="form-row" ng-if="$ctrl.shouldShowPhoneInputError() && !$ctrl.isStateChanged">\r\n                        <div class="error-phone-input" role="alert">\r\n                            <span ng-bind-html="$ctrl.errorMessage"></span>\r\n                        </div>\r\n                    </div>\r\n\r\n                    \x3c!-- Verification Error Messages --\x3e\r\n                    <div class="form-row" ng-if="$ctrl.hasVerificationError()">\r\n                        <div class="error-verification" role="alert">\r\n                            <span ng-bind-html="$ctrl.errorMessage"></span>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                \x3c!-- General Error Messages --\x3e\r\n                <div class="form-row" ng-if="$ctrl.shouldShowErrorMessage()">\r\n                    <div class="error-order-status" role="alert">\r\n                        <span ng-bind-html="$ctrl.errorMessage"></span>\r\n                    </div>\r\n                </div>\r\n\r\n                \x3c!-- Verification Code Field --\x3e\r\n                <div class="form-row" id="verificationCodeRow">\r\n                    <div class="form-group">\r\n                        <label for="verificationCode">\r\n                            {{$ctrl.verificationCodeLabel}}\r\n                        </label>\r\n                        <input id="verificationCode"\r\n                               type="text"\r\n                               maxlength="6"\r\n                               ng-pattern="/^[0-9]*$/"\r\n                               ng-model="$ctrl.rewardsRedeemChallenge.Code"\r\n                               ng-disabled="$ctrl.isVerificationCodeInputFieldDisabled()"\r\n                               required\r\n                               aria-required="true"\r\n                               inputmode="numeric"\r\n                               autocomplete="one-time-code" />\r\n                    </div>\r\n                </div>\r\n\r\n                \x3c!-- Alternative Verification Method Toggle --\x3e\r\n                <div class="more-ways-to-verify"\r\n                     ng-show="$ctrl.isSapphireCaptchaEnabled && !$ctrl.isSmsChallengeEnabled"\r\n                     ng-click="$ctrl.toggleChallengeType()"\r\n                     role="button"\r\n                     tabindex="0"\r\n                     ng-keydown="$event.keyCode === 13 && $ctrl.toggleChallengeType()">\r\n                    {{$ctrl.moreWaysToVerifyText}}\r\n                </div>\r\n            </section>\r\n\r\n            \x3c!-- QR Code Verification Section --\x3e\r\n            <section aria-labelledby="qr-verification-heading"\r\n                     class="qr-code"\r\n                     ng-show="$ctrl.shouldShowQrVerification()">\r\n\r\n                \x3c!-- Phone Number Input for QR Code Flow --\x3e\r\n                <div class="form-row" id="phoneRow">\r\n                    <div class="phone-input"\r\n                         ng-show="!$ctrl.shouldShowSaveAndContinue()">\r\n                        <div class="input-block">\r\n                            <label for="countryCodeDropdownQR">\r\n                                {{$ctrl.countryCodeLabel}}\r\n                            </label>\r\n                            <select id="countryCodeDropdownQR"\r\n                                    aria-label="{{$ctrl.countryCodeDropdownAriaLabel}}"\r\n                                    ng-model="$ctrl.rewardsRedeemChallenge.Phone.CountryCode"\r\n                                    ng-click="$ctrl.handleInputClick()">\r\n                                <option ng-repeat="country in $ctrl.countryPhoneCodeOptions"\r\n                                        value="{{country.value}}"\r\n                                        ng-selected="country.selected">\r\n                                    {{country.text}}\r\n                                </option>\r\n                            </select>\r\n                        </div>\r\n\r\n                        <div class="input-block">\r\n                            <label for="phoneNumberInputQR">\r\n                                {{$ctrl.phoneNumberLabel}}\r\n                            </label>\r\n                            <input type="tel"\r\n                                   id="phoneNumberInputQR"\r\n                                   ng-model="$ctrl.rewardsRedeemChallenge.Phone.Number"\r\n                                   placeholder="{{$ctrl.phoneNumberPlaceholderQR}}"\r\n                                   autocomplete="tel"\r\n                                   inputmode="tel"\r\n                                   aria-label="{{$ctrl.phoneNumberAriaLabel}}"\r\n                                   ng-pattern="/^[\\d\\s\\-\\(\\)\\+]+$/"\r\n                                   maxlength="30"\r\n                                   required\r\n                                   aria-required="true"\r\n                                   ng-click="$ctrl.handleInputClick()">\r\n                        </div>\r\n                    </div>\r\n\r\n                    \x3c!-- Phone Input Error Display for QR Code Flow --\x3e\r\n                    <div class="form-row" ng-if="$ctrl.shouldShowPhoneInputError() && !$ctrl.isStateChanged">\r\n                        <div class="error-phone-input" role="alert">\r\n                            <span ng-bind-html="$ctrl.errorMessage"></span>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                <div ng-show="!$ctrl.hasEmptyRequiredFields()">\r\n                    \x3c!-- Verification Header for QR Code --\x3e\r\n                    <h3 id="qr-verification-heading" class="verify" mee-heading="heading">\r\n                        {{$ctrl.letsVerifyItsYouText}}\r\n                    </h3>\r\n\r\n                    \x3c!-- Sapphire Captcha QR Code Component --\x3e\r\n                    <mee-rewards-sapphire-captcha dashboard-result="$ctrl.dashboardResult"\r\n                                                  sapphire-captcha-qr-code="$ctrl.sapphireCaptchaDetails.qrCodeImage"\r\n                                                  sapphire-captcha-download-bing-app-url="$ctrl.sapphireCaptchaDetails.downloadBingAppUrl"\r\n                                                  sapphire-captcha-remaining-expiry-time="$ctrl.sapphireCaptchaDetails.remainingExipryTimeInSeconds"\r\n                                                  captcha-scenario="\'sweep\'"\r\n                                                  is-save-and-continue-enabled="$ctrl.isSavePiiAndContinueEnabled"\r\n                                                  redirect-url="$ctrl.getRedirectToSuccessPageUrl()">\r\n                    </mee-rewards-sapphire-captcha>\r\n\r\n                    \x3c!-- QR Code Verification Error Display --\x3e\r\n                    <div class="form-row" ng-if="$ctrl.hasVerificationError()">\r\n                        <div class="error-verification" role="alert">\r\n                            <span ng-bind-html="$ctrl.errorMessage"></span>\r\n                        </div>\r\n                    </div>\r\n\r\n                    \x3c!-- QR Code Order Error Display --\x3e\r\n                    <div class="form-row" ng-if="$ctrl.shouldShowErrorMessage()">\r\n                        <div class="error-order-status" role="alert">\r\n                            <span ng-bind-html="$ctrl.errorMessage"></span>\r\n                        </div>\r\n                    </div>\r\n\r\n                    \x3c!-- Alternative Verification Method Toggle for QR Code --\x3e\r\n                    <div class="more-ways-to-verify"\r\n                         ng-show="!$ctrl.areaConfig.flights[\'smsorqrcode\'] && !$ctrl.isQrCodeChallengeEnabled"\r\n                         ng-click="$ctrl.toggleChallengeType()"\r\n                         role="button"\r\n                         tabindex="0"\r\n                         ng-keydown="$event.keyCode === 13 && $ctrl.toggleChallengeType()">\r\n                        {{$ctrl.moreWaysToVerifyText}}\r\n                    </div>\r\n\r\n                    <div ng-show="!$ctrl.isSavePiiAndContinueEnabled" class="step-final" ng-bind-html="$ctrl.completeYourEntry"></div>\r\n                </div>\r\n            </section>\r\n\r\n            \x3c!-- Terms and Conditions Section --\x3e\r\n            <div class="form-row" id="termsRow"\r\n                 ng-show="!$ctrl.isSavePiiAndContinueEnabled">\r\n                <div class="form-group-terms" ng-class="{\'mobile\': $ctrl.isMobile}">\r\n                    <input ng-disabled="$ctrl.currentUser.isAnonymous"\r\n                           type="checkbox"\r\n                           ng-model="$ctrl.currentUser.userInformation.isAgreed"\r\n                           ng-attr-aria-label="{{$ctrl.entryFormLegalText}}">\r\n                    <span ng-bind-html="$ctrl.entryFormLegalText"></span>\r\n                </div>\r\n            </div>\r\n\r\n            \x3c!-- Submit Button Section --\x3e\r\n            <section aria-labelledby="submit-heading">\r\n                <h3 id="submit-heading" class="visually-hidden">Submit Entry</h3>\r\n\r\n                <div class="form-row" id="submitRow">\r\n                    \x3c!-- Submit Button for SMS/Call Flow --\x3e\r\n                    <button type="submit"\r\n                            class="submit-btn"\r\n                            ng-show="$ctrl.shouldShowSmsVerification()"\r\n                            ng-click="$ctrl.handleSubmitButtonClick()"\r\n                            ng-disabled="$ctrl.isSubmitButtonDisabled() || $ctrl.currentUser.isAnonymous"\r\n                            ng-attr-aria-label="{{$ctrl.getSubmitButtonText()}}">\r\n                        {{$ctrl.getSubmitButtonText()}}\r\n                    </button>\r\n\r\n                    \x3c!-- Submit Button for QR Code Flow --\x3e\r\n                    <button type="submit"\r\n                            class="submit-btn"\r\n                            ng-show="$ctrl.shouldShowQrVerification() && !$ctrl.isSavePiiAndContinueEnabled"\r\n                            ng-click="$ctrl.validatePhoneNumberAndverifyCaptchaAndSignupAsync()"\r\n                            ng-disabled="!$ctrl.currentUser.userInformation.isAgreed || $ctrl.isSendCodeButtonDisabled() || $ctrl.currentUser.isAnonymous"\r\n                            ng-attr-aria-label="{{$ctrl.getSubmitButtonText()}}">\r\n                        {{$ctrl.getSubmitButtonText()}}\r\n                    </button>\r\n                </div>\r\n            </section>\r\n\r\n            \x3c!-- Privacy Statement --\x3e\r\n            <div class="privacy">\r\n                <span ng-bind-html="$ctrl.privacyText"></span>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes-winner.html",'<div id="oneUiSweepstakes" class="rewardsContent dark-purple-background ">\r\n    <img ng-src="{{ $ctrl.instantWinSweepstakesHeroBackground }}" alt="Background" class="bg-img" />\r\n    <div class="background-layer-v3">\r\n        <div id="winnerPageContainer-v2">\r\n            <div id="winnerPageHeroBanner" class="sweepstakesContent min-height-600">\r\n                <mee-rewards-highvalue-sweepstakes-hero-banner dashboard-result="$ctrl.dashboardResult"\r\n                    banner-title="$ctrl.highvalueSweepstakesCmsData.strings[$ctrl.isSweepstakeEnded ? \'winnerspage_hero_title_new\' : \'winnerspage_hero_title\']"\r\n                    description="$ctrl.heroBannerDescription" use-anonymous-cta-padding="true"\r\n                    hero-image-desktop-url="$ctrl.heroImageDesktopUrl" hero-image-mobile-url="$ctrl.heroImageMobileUrl"\r\n                    sweepstake-info="$ctrl.sweepstakeInfo" cta-button-text="$ctrl.heroBannerCtaButtonText"\r\n                    cta-button-url="$ctrl.heroBannerCtaUrl" legal-text="$ctrl.isSweepstakeEnded ? $ctrl.highvalueSweepstakesCmsData.strings[\'promo_hero_disclaimer\'] : \'\'">\r\n                </mee-rewards-highvalue-sweepstakes-hero-banner>\r\n            </div>\r\n            <div class="sweepstakesContent margin-bottom-56">\r\n                <div class="featured-winner-upper-title">\r\n                    {{$ctrl.nonLocalizedCmsData.strings["winnerspage_mod1_sectiontitlesubhead_featuredwinner"]}}</div>\r\n                <div class="section featured-winner-title margin-bottom-56">\r\n                    {{$ctrl.winnerspageSectiontitleFeaturedwinner}}</div>\r\n                <div class="video-banner">\r\n                    <div class="video-banner-content video-banner-content-v2">\r\n                        <div class="video-banner-text">\r\n                            <div class="video-banner-title">\r\n                                {{$ctrl.nonLocalizedCmsData.strings["winnerspage_mod1_title_featuredwinner"]}}</div>\r\n                            <div class="video-banner-description">\r\n                                {{$ctrl.nonLocalizedCmsData.strings[\'winnerspage_mod1_body1_featuredwinnerquote\']}}\r\n                            </div>\r\n                        </div>\r\n                        <div class="video-banner-image">\r\n                            <img ng-src="https://rewards.bing.com/rewardscdn/images/rewards/1Mhva/video_banner_2m_grand_prize_winner_656x369.png"\r\n                                alt="{{$ctrl.videoBanner && $ctrl.videoBanner.title || \'Sweepstakes video thumbnail\'}}"\r\n                                class="video-poster-image" />\r\n                             <div class="video-play-button" \r\n                                ng-click="$ctrl.openVideoModal(\'2M_Sweeps_Nate_Video\')">\r\n                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">\r\n                                    <path d="M4.16797 4.39522C4.16797 2.97284 5.68971 2.06842 6.93912 2.74824L17.2404 8.35337C18.5456 9.06351 18.5456 10.9372 17.2404 11.6473L6.93912 17.2525C5.68971 17.9323 4.16797 17.0279 4.16797 15.6055V4.39522Z" fill="white"/>\r\n                                </svg>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div ng-if="$ctrl.showCards" class="sweepstakesContent margin-bottom-56">\r\n                <h2 class="section section-title margin-bottom-16">\r\n                    {{$ctrl.highvalueSweepstakesCmsData.strings["winnerspage_mod2_sectiontitle_hvacards"]}}</h2>\r\n                <div class="margin-top-32">\r\n                    <mee-card-group>\r\n                        <mee-card ng-repeat="card in $ctrl.hvaCards">\r\n                            <card-content>\r\n                                <a class="clickable-card" ng-href="{{ card.callToAction.url }}"\r\n                                    aria-label="{{ card.callToAction.text }}" target="{{ card.callToAction.target }}">\r\n                                    <div class="imageContainer">\r\n                                        <img mee-image ng-src="{{ card.image.source }}"\r\n                                            alt="{{card.image.alternateText || card.title}}" />\r\n                                    </div>\r\n                                    <div class="card-content">\r\n                                        <div class="card-title">{{card.title}}</div>\r\n                                        <div class="card-buttons-container">\r\n                                            <mee-rewards-status-indicator status="card.status"></mee-rewards-status-indicator>\r\n                                        </div>\r\n                                    </div>\r\n                                </a>\r\n                            </card-content>\r\n                        </mee-card>\r\n                    </mee-card-group>\r\n                </div>\r\n            </div>\r\n            \x3c!-- Winners Map Section --\x3e\r\n            <div class="sweepstakesContent margin-bottom-56" ng-if="$ctrl.showWinnersMap">\r\n                <h2 class="section section-title margin-bottom-36">\r\n                    {{$ctrl.nonLocalizedCmsData.strings[\'winnerspage_mod4_sectiontitle1_mapsmodule\']}}\r\n                </h2>\r\n                <div class="section section-subtitle">\r\n                        {{$ctrl.nonLocalizedCmsData.strings[\'winnerspage_mod4_sectiontitle2_mapsmodule\']}}\r\n                    </div>\r\n                <div class="winners-map-container margin-top-48">\r\n                    <div id="winnersMap" class="winners-map"></div>\r\n                </div>\r\n            </div>\r\n            <div class="sweepstakesContent margin-bottom-56">\r\n                <div class="section section-title">\r\n                    {{$ctrl.highvalueSweepstakesCmsData.strings["winnerspage_mod3_sectiontitle_ugpastwinner"]}}</div>\r\n                <div class="video-banner"\r\n                     tabindex="0"\r\n                     role="button"\r\n                     aria-label="Play past winner video"\r\n                     onkeydown="if(event.key === \'Enter\' || event.key === \' \') { angular.element(this).scope().$ctrl.openVideoModal(\'past\'); }">\r\n                    <div class="video-banner-content" ng-class="{\'video-banner-content-v2\' : $ctrl.isInstantWinsSweepstake, \'video-banner-content-v1\': !$ctrl.isInstantWinsSweepstake}">\r\n                        <div class="video-banner-text">\r\n                            <div class="video-banner-description">\r\n                                {{$ctrl.nonLocalizedCmsData.strings[\'winnerspage_mod3_body1_ugpastwinnerquote\']}}\r\n                            </div>\r\n                        </div>\r\n                        <div class="video-banner-image">\r\n                            <img ng-src="https://rewards.bing.com/rewardscdn/images/rewards/1Mhva/video_banner_1m_grand_prize_winner.png"\r\n                                alt="{{$ctrl.videoBanner && $ctrl.videoBanner.title || \'Sweepstakes video thumbnail\'}}"\r\n                                class="video-poster-image" />\r\n                            <div class="video-play-button" \r\n                                ng-click="$ctrl.openVideoModal(\'1mwinner_ron_g_video\')">\r\n                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">\r\n                                    <path d="M4.16797 4.39522C4.16797 2.97284 5.68971 2.06842 6.93912 2.74824L17.2404 8.35337C18.5456 9.06351 18.5456 10.9372 17.2404 11.6473L6.93912 17.2525C5.68971 17.9323 4.16797 17.0279 4.16797 15.6055V4.39522Z" fill="white"/>\r\n                                </svg>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class="sweepstakesContent margin-bottom-56" ng-if="$ctrl.showTable">\r\n                <h2 class="section section-title margin-bottom-36">\r\n                    {{$ctrl.highvalueSweepstakesCmsData.strings[\'winnerspage_mod4_sectiontitle_winnerlist\']}}\r\n                </h2>\r\n                <div class="winners-table-container">\r\n                    <div class="winners-table-wrapper">\r\n                        <table class="winners-table" role="table" aria-label="Sweepstakes winners list">\r\n                            <thead>\r\n                                <tr>\r\n                                    <th scope="col">{{$ctrl.highvalueSweepstakesCmsData.strings[\'winnerspage_mod4_winnerlist_col_country\']}}</th>\r\n                                    <th scope="col">{{$ctrl.highvalueSweepstakesCmsData.strings[\'winnerspage_mod4_winnerlist_col_state\']}}</th>\r\n                                    <th scope="col">{{$ctrl.highvalueSweepstakesCmsData.strings[\'winnerspage_mod4_winnerlist_col_name\']}}</th>\r\n                                    <th scope="col">{{$ctrl.highvalueSweepstakesCmsData.strings[\'winnerspage_mod4_winnerlist_col_sweepstake\']}}</th>\r\n                                </tr>\r\n                            </thead>\r\n                            <tbody>\r\n                                <tr ng-repeat="winnerPair in $ctrl.displayedWinners track by $index">\r\n                                    <td>\r\n                                        <img class="winner-flag-image" ng-src="{{winnerPair.flagUrl}}"\r\n                                            alt="{{winnerPair.country}}" loading="lazy" decoding="async"\r\n                                            onerror="this.style.display=\'none\'" />\r\n                                        {{winnerPair.country}}\r\n                                    </td>\r\n                                    <td>{{winnerPair.state}}</td>\r\n                                    <td>{{winnerPair.name}}</td>\r\n                                    <td>{{winnerPair.prizeName}}</td>\r\n                                </tr>\r\n                            </tbody>\r\n                        </table>\r\n                    </div>\r\n                    <div class="winners-table-footer" ng-if="$ctrl.shouldShowLoadMoreButton()">\r\n                        <button class="winners-table-button" \r\n                                type="button" \r\n                                tabindex="0"\r\n                                ng-click="$ctrl.loadMoreWinners()"\r\n                                ng-disabled="$ctrl.isLoadingMore"\r\n                                aria-label="Load more winners">\r\n                            <span ng-if="!$ctrl.isLoadingMore">{{$ctrl.highvalueSweepstakesCmsData.strings[\'winnerspage_mod4_winnerlist_button_see_all_winners\']}}</span>\r\n                            <span ng-if="$ctrl.isLoadingMore" class="loading-text">\r\n                                <svg class="loading-spinner" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none">\r\n                                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-dasharray="31.416" stroke-dashoffset="31.416">\r\n                                        <animate attributeName="stroke-dasharray" dur="2s" values="0 31.416;15.708 15.708;0 31.416;0 31.416" repeatCount="indefinite"/>\r\n                                        <animate attributeName="stroke-dashoffset" dur="2s" values="0;-15.708;-31.416;-31.416" repeatCount="indefinite"/>\r\n                                    </circle>\r\n                                </svg>\r\n                                Loading...\r\n                            </span>\r\n                        </button>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div id="bottomHeroBanner" class="sweepstakesContent padding-bottom-50">\r\n                <mee-rewards-highvalue-sweepstakes-hero-banner dashboard-result="$ctrl.dashboardResult"\r\n                    cta-button-text="$ctrl.heroBannerCtaButtonText"\r\n                    cta-button-url="$ctrl.heroBannerCtaUrl"\r\n                    use-footer-typography="true" use-centered-text="true"\r\n                    banner-title="$ctrl.highvalueSweepstakesCmsData.strings[$ctrl.isSweepstakeEnded ? \'winnerspage_mod5_title_dashboard_new\' : \'winnerspage_mod5_title_dashboard\']"\r\n                    description="$ctrl.highvalueSweepstakesCmsData.strings[$ctrl.isSweepstakeEnded ? \'winnerspage_mod5_body_dashboard_new\' : \'winnerspage_mod5_body_dashboard\']">\r\n                </mee-rewards-highvalue-sweepstakes-hero-banner>\r\n            </div>\r\n\r\n            <div ng-if="$ctrl.showVideoBanner" ng-show="$ctrl.showVideoModal" class="video-modal-fullscreen"\r\n                 role="dialog"\r\n                 aria-modal="true"\r\n                 aria-label="Video player modal">\r\n                <div class="video-modal-header">\r\n                    <div class="video-modal-title">\r\n                        {{$ctrl.currentVideo.title}}\r\n                    </div>\r\n                    <button class="modal-close" \r\n                            ng-click="$ctrl.closeVideoModal()" \r\n                            aria-label="Close video modal"\r\n                            tabindex="0">\r\n                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">\r\n                            <path d="M4.08859 4.21569L4.14645 4.14645C4.32001 3.97288 4.58944 3.9536 4.78431 4.08859L4.85355 4.14645L10 9.293L15.1464 4.14645C15.32 3.97288 15.5894 3.9536 15.7843 4.08859L15.8536 4.14645C16.0271 4.32001 16.0464 4.58944 15.9114 4.78431L15.8536 4.85355L10.707 10L15.8536 15.1464C16.0271 15.32 16.0464 15.5894 15.9114 15.7843L15.8536 15.8536C15.68 16.0271 15.4106 16.0464 15.2157 15.9114L15.1464 15.8536L10 10.707L4.85355 15.8536C4.67999 16.0271 4.41056 16.0464 4.21569 15.9114L4.14645 15.8536C3.97288 15.68 3.9536 15.4106 4.08859 15.2157L4.14645 15.1464L9.293 10L4.14645 4.85355C3.97288 4.67999 3.9536 4.41056 4.08859 4.21569L4.14645 4.14645L4.08859 4.21569Z" fill="#2A446F"/>\r\n                        </svg>\r\n                    </button>\r\n                </div>\r\n                <div class="video-modal-content">\r\n                    <div class="video-player-container">\r\n                        <video class="sweepstakes-video" \r\n                               controls\r\n                               autoplay\r\n                               muted\r\n                               preload="metadata"\r\n                               ng-src="{{$ctrl.currentVideo && $ctrl.currentVideo.videoUrl}}"\r\n                               ng-attr-poster="{{$ctrl.currentVideo && $ctrl.currentVideo.posterUrl}}"\r\n                               aria-label="{{$ctrl.currentVideo && $ctrl.currentVideo.title || \'Sweepstakes video\'}}"\r\n                               role="application">\r\n                            <source ng-src="{{$ctrl.currentVideo && $ctrl.currentVideo.videoUrl}}" type="video/mp4">\r\n                        </video>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n        </div>\r\n    </div>\r\n    <mee-rewards-highvalue-sweepstakes-faq ng-if="!$ctrl.isSweepstakeEnded"></mee-rewards-highvalue-sweepstakes-faq>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/HighValueSweepstakes/highvalue-sweepstakes.html",'<div id="oneUiSweepstakes" class="total-prize-drop-container">\r\n    <div class="feed-container">\r\n        <mee-rewards-highvalue-sweepstakes-signup ng-if="$ctrl.currentUser.isSignupOrCongratsRequest"></mee-rewards-highvalue-sweepstakes-signup>\r\n        <mee-rewards-highvalue-sweepstakes-more-entries ng-if="!$ctrl.currentUser.isSignupOrCongratsRequest"\r\n            dashboard-result="$ctrl.dashboardResult"\r\n            sweepstake-info="$ctrl.sweepstakeInfo"\r\n            sweepstake-end-date="$ctrl.sweepstakeEndDate">\r\n        </mee-rewards-highvalue-sweepstakes-more-entries>\r\n    </div>\r\n    <mee-rewards-highvalue-sweepstakes-faq></mee-rewards-highvalue-sweepstakes-faq>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Rebates/rebates.html",'<mee-rewards-user-status rebates-result="$ctrl.rebatesResult"\r\n                         slot-configuration=\'["profile", "rebatesAvailable", "rebatesPending", "rebatesLifetime"]\'\r\n                         ng-if="$ctrl.rebatesResult.isRebatesOnly">\r\n</mee-rewards-user-status>\r\n<mee-rewards-user-status rebates-result="$ctrl.rebatesResult"\r\n                         slot-configuration=\'["profile", "rebatesAvailable", "rebatesLifetime", "balance"]\'\r\n                         ng-if="!$ctrl.rebatesResult.isRebatesOnly">\r\n</mee-rewards-user-status>\r\n\r\n<mee-rewards-navigation active-id="rebates"></mee-rewards-navigation>\r\n\r\n<div id="rebatesRewards">\r\n    <div class="contentWrapper">\r\n        <div class="column-1">\r\n            <div ui-view="rebates-additional-nav">\r\n\r\n            </div>\r\n        </div>\r\n        <div class="cardWrapper column-2">\r\n            <div ui-view="rebates-main">\r\n\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Redeem/redeem-catalog-card.html",'<div id="redeemCatalog" class="page-width no-reverse-column" ng-class="{\'noMargin\' : $ctrl.noResult}">\r\n    <mee-rewards-redeem-oneclick-confirm-modal ng-if="$ctrl.isOneclickRedemptionFlight || $ctrl.isOneclickRedemptionFlightWithoutVariableRedemption"\r\n                                               ng-show="$ctrl.showOneclickModal"\r\n                                               close-fn="$ctrl.closeModal()"\r\n                                               sku="$ctrl.oneclickSku"\r\n                                               is-without-variable="$ctrl.isOneclickRedemptionFlightWithoutVariableRedemption"\r\n                                               show-oneclick-modal="$ctrl.showOneclickModal">\r\n    </mee-rewards-redeem-oneclick-confirm-modal>\r\n    <mee-rewards-redeem-catalog-subscription ng-if="$ctrl.isAutoRedeemPanelEnabled()"></mee-rewards-redeem-catalog-subscription>\r\n    <mee-rewards-redeem-recommended-affordable-card ng-if="$ctrl.showRecommendCards()"\r\n                                                    recommended-affordable-catalogs="$ctrl.recommendCardItems">\r\n    </mee-rewards-redeem-recommended-affordable-card>\r\n    <mee-card-group role="list" ng-attr-aria-label="{{$ctrl.cmsData.strings[\'redeem-rewards-cards\']}}">\r\n        <h4 ng-if="$ctrl.$rootScope.showNoResultMessage" id="rewards-redeem-noresult"\r\n            ng-class="{\'isAutoRedeemPanelMode\' : $ctrl.isAutoRedeemPanelEnabled()}">\r\n            {{$ctrl.cmsData.strings["no-record"]}}\r\n        </h4>\r\n        <mee-card ng-repeat="card in $ctrl.catalogShowcaseCardItems"\r\n                  role="listitem" \r\n                  aria-setsize="{{$ctrl.catalogShowcaseCardItems.length}}" \r\n                  aria-posinset="{{$index + 1}}"\r\n                  display-type="{{card.displayType}}"\r\n                  data-categories=\'["{{card.category}}"]\'\r\n                  data-sort-by-credits="{{card.price}}"\r\n                  data-card-id="{{card.productId}}"\r\n                  ng-class="$ctrl.showcaseClassName(card.showcase, card.category)">\r\n            <card-content>\r\n                <a target="_self"\r\n                   tabindex="0"\r\n                   class="clickable-card"\r\n                   ng-if="!card.comingSoonFlag"\r\n                   ng-attr-href="{{!$ctrl.isSetGoalMode && !$ctrl.isOneclickRedemptionFlightEnabled(card) ? card.callToAction.url : undefined}}"\r\n                   ng-click="$ctrl.isSetGoalMode || $ctrl.isOneclickRedemptionFlightEnabled(card) ? card.callToAction.callFunction() : undefined">\r\n                    <div class="text-align-center rewards-card-container" data-m=\'{{card.biContentString}}\'>\r\n                        <div class="imageContainer" ng-class="{\'x-hidden-vp1\' : card.displayType === \'single\'}">\r\n                            <span class="redeem-overlay" ng-style="{\'background-image\': \'url({{card.image.source}})\'}"></span>\r\n                        </div>\r\n                        <div class="contentContainer">\r\n                            <h4 mee-heading="heading" class="searchByName">{{card.title}}</h4>\r\n                            <div mee-paragraph="para4" ng-class="{\'margin-top-12\' : card.showcase}">{{card.subtitle}}</div>\r\n                        </div>\r\n                        <div class="actionLink" ng-if="!$ctrl.isSetGoalMode">\r\n                            <span class="redeemAction showCaseCard"\r\n                                  ng-if="card.callToAction.text"\r\n                                  id="{{card.callToAction.id}}"\r\n                                  data-bi-id="{{card.callToAction.id}}"\r\n                                  ng-class="{\'isSetGoalMode\' : $ctrl.isSetGoalMode}">\r\n                                {{card.callToAction.text}} <i class="mee-icon pull-left icon mee-icon-ChevronRightSmall"></i>\r\n                            </span>\r\n                        </div>\r\n                        <div class="actionLink" ng-if="$ctrl.isSetGoalMode">\r\n                            <span class="redeemAction showCaseCard"\r\n                                  ng-if="card.callToAction.text"\r\n                                  id="{{card.callToAction.id}}"\r\n                                  data-bi-id="{{card.callToAction.id}}"\r\n                                  ng-class="{\'isSetGoalMode\' : $ctrl.isSetGoalMode}">\r\n                                {{card.callToAction.text}} <i class="mee-icon pull-left icon mee-icon-ChevronRightSmall"></i>\r\n                            </span>\r\n                        </div>\r\n                        <mee-rewards-debug-info item="card"></mee-rewards-debug-info>\r\n                        <mee-rewards-coupon-info item="card"></mee-rewards-coupon-info>\r\n                    </div>\r\n                </a>\r\n                <div class="nonclickable-card text-align-center rewards-card-container" ng-if="card.comingSoonFlag" data-m=\'{{card.biContentString}}\'>\r\n                    <div class="imageContainer">\r\n                        <img mee-image ng-src="{{card.image.source}}" alt="{{card.image.alternateText}}" />\r\n                    </div>\r\n                    <div class="contentContainer">\r\n                        <h4 mee-heading="heading" class="searchByName">{{card.title}}</h4>\r\n                        <div mee-paragraph="para4" ng-class="{\'margin-top-12\' : card.showcase}">{{card.subtitle}}</div>\r\n                    </div>\r\n                    <mee-rewards-debug-info item="card"></mee-rewards-debug-info>\r\n                </div>\r\n            </card-content>\r\n        </mee-card>\r\n\r\n        <mee-card ng-repeat="card in $ctrl.catalogCardItems"\r\n                  role="listitem" \r\n                  aria-setsize="{{$ctrl.catalogCardItems.length}}" \r\n                  aria-posinset="{{$index + 1}}"\r\n                  display-type="{{card.displayType}}"\r\n                  data-categories=\'["{{card.category}}"]\'\r\n                  data-sort-by-credits="{{card.price}}"\r\n                  data-card-id="{{card.productId}}"\r\n                  ng-class="$ctrl.showcaseClassName(card.showcase, card.category, card.productId)">\r\n            <card-content>\r\n                <a target="_self"\r\n                   tabindex="0"\r\n                   class="clickable-card"\r\n                   ng-if="!card.comingSoonFlag"\r\n                   ng-attr-href="{{$ctrl.isSetGoalMode || card.isOneclickEligible ? undefined : card.callToAction.url}}"\r\n                   ng-click="$ctrl.isSetGoalMode || card.isOneclickEligible ? card.callToAction.callFunction() : undefined">\r\n                    <div class="text-align-center rewards-card-container" data-m=\'{{card.biContentString}}\'>\r\n                        <div class="imageContainer">\r\n                            <img mee-image ng-src="{{card.image.source}}" alt="{{card.image.alternateText}}" />\r\n                        </div>\r\n                        <div class="contentContainer">\r\n                            <h4 mee-heading="heading" class="searchByName">{{card.title}}</h4>\r\n                            <div mee-paragraph="para4" ng-class="{\'hidden\' : $ctrl.isSetGoalMode, \'padding-top-24\' : card.showcase, \'price-after-coupon\' : card.couponDiscount > 0 }">{{card.couponDiscount > 0 ? card.subtitleWithCoupon : card.subtitle}}</div>\r\n                            <div mee-paragraph="para4" class="couponDiscountRemove" ng-if="card.couponDiscount > 0" ng-class="{\'hidden\' : $ctrl.isSetGoalMode, \'padding-top-24\' : card.showcase}">{{card.subtitle}}</div>\r\n                        </div>\r\n\r\n                        <div class="actionLink" ng-if="$ctrl.isSetGoalMode">\r\n                            <span class="redeemAction isSetGoalMode"\r\n                                  ng-if="card.callToAction.text"\r\n                                  id="{{card.callToAction.id}}"\r\n                                  data-bi-id="{{card.callToAction.id}}"\r\n                                  aria-label="{{card.callToAction.ariaLabel}}">\r\n                                {{card.callToAction.text}} <i class="mee-icon pull-left icon mee-icon-ChevronRightSmall"></i>\r\n                            </span>\r\n                        </div>\r\n\r\n                        <div class="actionLink" ng-if="$ctrl.currentUser.isAnonymous || (!$ctrl.isSetGoalMode && !card.showProgressBar)">\r\n                            <span class="redeemAction"\r\n                                  ng-if="card.callToAction.text"\r\n                                  id="{{card.callToAction.id}}"\r\n                                  data-bi-id="{{card.callToAction.id}}"\r\n                                  aria-label="{{card.callToAction.ariaLabel}}">\r\n                                <img ng-if="card.isOneclickEligible" class="starIcon" ng-srcset="//rewards.bing.com/rewardscdn/images/rewards/membercenter/missions/StreakProtection/NewStars.png" ng-src="//rewards.bing.com/rewardscdn/images/flame.png" alt="oneclick star image"> {{card.callToAction.text}} <i class="mee-icon pull-left mee-icon-ChevronRightSmall"></i>\r\n                            </span>\r\n                        </div>\r\n\r\n                        <div class="progressBarWrapper" ng-if="!$ctrl.isSetGoalMode && card.showProgressBar">\r\n                            <span id="{{card.callToAction.id}}"\r\n                                  data-bi-id="{{card.callToAction.id}}">\r\n                                <progress class="c-progress"\r\n                                          role="progressbar"\r\n                                          min="0"\r\n                                          aria-valuemin="0"\r\n                                          value="{{card.progressValue}}"\r\n                                          aria-valuenow="{{card.progressValue}}"\r\n                                          max="100"\r\n                                          aria-valuemax="100"\r\n                                          aria-label="determinate progress bar">\r\n                                </progress>\r\n                            </span>\r\n                        </div>\r\n                        <mee-rewards-sale-info item="card"></mee-rewards-sale-info>\r\n                        <mee-rewards-debug-info item="card"></mee-rewards-debug-info>\r\n                        <mee-rewards-coupon-info item="card"></mee-rewards-coupon-info>\r\n                    </div>\r\n                </a>\r\n                <div class="nonclickable-card text-align-center rewards-card-container" ng-if="card.comingSoonFlag" data-m=\'{{card.biContentString}}\'>\r\n                    <div class="imageContainer">\r\n                        <img mee-image ng-src="{{card.image.source}}" alt="{{card.image.alternateText}}" />\r\n                    </div>\r\n                    <div class="contentContainer">\r\n                        <h4 mee-heading="heading" class="searchByName">{{card.title}}</h4>\r\n                        <div mee-paragraph="para4" class="comingsoon" ng-class="{\'padding-top-24\' : card.showcase}">{{card.comingSoonText}}</div>\r\n                    </div>\r\n                    <mee-rewards-sale-info item="card"></mee-rewards-sale-info>\r\n                    <mee-rewards-debug-info item="card"></mee-rewards-debug-info>\r\n                </div>\r\n            </card-content>\r\n        </mee-card>\r\n    </mee-card-group>\r\n    <mee-rewards-redeem-catalog-donate-all-nonprofits ng-if="$ctrl.showBenevity"></mee-rewards-redeem-catalog-donate-all-nonprofits>\r\n    <div data-grid="col-1" class="sizer"></div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Redeem/redeem-catalog-donate-all-nonprofits.html",'<div id="charityListComponent" class="page-width no-reverse-column" ng-class="{\'noMargin\' : $ctrl.noResult}">\r\n    <div id="benevityTitleContainer">\r\n        <h2 ng-if="$ctrl.donationCatalogItems" id="rewards-redeem-benevity-title">{{$ctrl.cmsData.strings["benevity-charities-title"]}}</h2>\r\n        <mee-rewards-redeem-donate-drop-down-list donation-catalog-items="$ctrl.donationCatalogItems"></mee-rewards-redeem-donate-drop-down-list>\r\n    </div>\r\n    <mee-card-group role="list" ng-attr-aria-label="{{$ctrl.cmsData.strings[\'donation-organizations\']}}">\r\n        <mee-card class="benevityOrgCard" \r\n                  role="listitem" \r\n                  aria-setsize="{{$ctrl.donationCatalogItems.length}}" \r\n                  aria-posinset="{{$index + 1}}"\r\n                  ng-repeat="orgCard in $ctrl.donationCatalogItems" track by $index>\r\n            <card-content>\r\n                <a class="clickable-card"\r\n                   target="_blank"\r\n                   id="{{orgCard.callToAction.id}}"\r\n                   ng-href="{{orgCard.callToAction.url}}"\r\n                   ng-attr-aria-label="{{orgCard.callToAction.ariaLabel}}">\r\n\r\n                    <div class="text-align-center rewards-card-container" data-m=\'{{orgCard.biContentString}}\'>\r\n                        <div class="imageContainer benevityImgContainer">\r\n                            <img mee-image class="benevityImage" ng-src="{{orgCard.image.source}}" alt="{{orgCard.image.alternateText}}" />\r\n                        </div>\r\n                        <div class="contentContainer">\r\n                            <h4 mee-heading="heading" class="searchByName">{{orgCard.title}}</h4>\r\n                            <div mee-paragraph="para4" ng-class="{\'hidden\' : $ctrl.isSetGoalMode, \'padding-top-24\' : orgCard.showcase}">{{orgCard.subtitle}}</div>\r\n                        </div>\r\n\r\n                        <div class="actionLink" ng-if="$ctrl.isSetGoalMode">\r\n                            <span class="redeemAction isSetGoalMode"\r\n                                  ng-if="orgCard.callToAction.text"\r\n                                  id="{{orgCard.callToAction.id}}"\r\n                                  data-bi-id="{{orgCard.callToAction.id}}"\r\n                                  aria-label="{{orgCard.callToAction.ariaLabel}}">\r\n                                {{orgCard.callToAction.text}} <i class="mee-icon pull-left icon mee-icon-ChevronRightSmall"></i>\r\n                            </span>\r\n                        </div>\r\n\r\n                        <div class="actionLink" ng-if="!$ctrl.isSetGoalMode && !orgCard.showProgressBar">\r\n                            <span class="redeemAction"\r\n                                  ng-if="orgCard.callToAction.text"\r\n                                  id="{{orgCard.callToAction.id}}"\r\n                                  data-bi-id="{{orgCard.callToAction.id}}"\r\n                                  aria-label="{{orgCard.callToAction.ariaLabel}}">\r\n                                {{orgCard.callToAction.text}} <i class="mee-icon pull-left mee-icon-ChevronRightSmall"></i>\r\n                            </span>\r\n                        </div>\r\n\r\n                        <div class="progressBarWrapper" ng-if="!$ctrl.isSetGoalMode && orgCard.showProgressBar">\r\n                            <span id="{{orgCard.callToAction.id}}"\r\n                                  data-bi-id="{{orgCard.callToAction.id}}">\r\n                                <progress class="c-progress"\r\n                                          role="progressbar"\r\n                                          min="0"\r\n                                          aria-valuemin="0"\r\n                                          value="{{orgCard.progressValue}}"\r\n                                          aria-valuenow="{{orgCard.progressValue}}"\r\n                                          max="100"\r\n                                          aria-valuemax="100"\r\n                                          aria-label="determinate progress bar">\r\n                                </progress>\r\n                            </span>\r\n                        </div>\r\n                        <mee-rewards-debug-info item="orgCard"></mee-rewards-debug-info>\r\n                    </div>\r\n                </a>\r\n            </card-content>\r\n        </mee-card>\r\n    </mee-card-group>\r\n    <div data-grid="col-1" class="sizer"></div>\r\n    <div ng-if="!$ctrl.noMoreLoading && $ctrl.donationCatalogItems" class="load_more" id="benevitySearch_mode_load_more">\r\n        <div id="benevitySpin"></div>\r\n        <div id="console_debug"></div>\r\n        <button class="page_numbers"\r\n                id="loadmore_button"\r\n                ng-click="$ctrl.getLoadMoreBenevitySearchData()">\r\n            {{$ctrl.loadMoreText}}\r\n            <i class="mee-icon pull-left icon mee-icon-ChevronRightSmall" id="benevityChev"></i>\r\n        </button>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Redeem/redeem-catalog-menu.html",'<div class="redeemNavigation margin-right-15">\r\n    <div class="sdImageContainer" ng-if="$ctrl.showSearchDonateImage">\r\n        <img mee-image ng-src="//rewards.bing.com/rewardscdn/images/rewards/SearchQueryImage.png" alt="Search donate image" class="searchDonateImage">\r\n        <div class="searchDonateImageDesc">{{$ctrl.searchDonateImageDesc}}</div>\r\n    </div>\r\n    <label for="rewards-redeem-searchbox" hidden>{{$ctrl.isSetGoalMode ? $ctrl.cmsData.strings[\'pick-a-goal\'] : $ctrl.cmsData.strings[\'nav-search\']}}</label>\r\n    <input type="search" aria-label="{{$ctrl.isSetGoalMode ? $ctrl.cmsData.strings[\'pick-a-goal\'] : $ctrl.cmsData.strings[\'nav-search\']}}" ng-attr-aria-labelledby="{{$ctrl.isSetGoalMode ? \'redeem-set-goal\' : \'\'}}" mee-text-input name="q" id="rewards-redeem-searchbox" data-bi-id="rewards-redeem-searchbox" placeholder="{{$ctrl.isSetGoalMode ? $ctrl.cmsData.strings[\'pick-a-goal\'] : $ctrl.cmsData.strings[\'nav-search\']}}" ng-change="$ctrl.searchCard()" ng-model="searchText" aria-controls="searchCatalogInfo" aria-describedby="searchValidationMessage" />\r\n    <div id="searchValidationMessage" aria-live="polite" class="x-screen-reader">{{$ctrl.searchAnnouncement}}</div>\r\n    <div id="searchCatalogInfo" aria-live="assertive" class="x-screen-reader" />\r\n    \r\n    <mee-refine-menu trigger-text="{{$ctrl.categoryNav.title}}" on-selected="$ctrl.filterCard($event, true)" state="{{$ctrl.expanded}}" ng-class="{\'category\' : !$ctrl.currentUser.isAnonymous}" class="display-block margin-top-18" id="redeem-catalog-filter" mee-aria-label="{{$ctrl.categoryNav.title}}" role="navigation">\r\n        <li ng-repeat="link in $ctrl.categoryNav.links"\r\n            refine-menu-item\r\n            mee-aria-label="{{link.text}}"\r\n            id="{{link.id}}"\r\n            data-bi-id="{{link.id}}"\r\n            icon="mee-icon pull-left icon mee-icon-{{link.icon.source}}"\r\n            alt="{{link.icon.alternateText}}"\r\n            ng-class="{\'f-active\' : link.id === $ctrl.activeCategory}" \r\n            role="menuitem">\r\n            {{link.text}}\r\n        </li>\r\n    </mee-refine-menu>\r\n\r\n    <mee-refine-menu ng-if="$ctrl.showSortMenu" trigger-text="{{$ctrl.sortNav.title}}" on-selected="$ctrl.sortCard($event)" state="{{$ctrl.expanded}}" class="display-block margin-top-18" id="redeem-catalog-sort" mee-aria-label="{{$ctrl.sortNav.title}}" role="navigation">\r\n        <li ng-repeat="link in $ctrl.sortNav.links"\r\n            refine-menu-item \r\n            mee-aria-label="{{link.text}}"\r\n            id="{{link.id}}"\r\n            data-bi-id="{{link.id}}"\r\n            icon="mee-icon pull-left icon mee-icon-{{link.icon.source}}"\r\n            alt="{{link.icon.alternateText}}"\r\n            ng-class="{\'f-active\' : link.id === $ctrl.activeSort}" \r\n            role="menuitem">\r\n            {{link.text}}\r\n        </li>\r\n    </mee-refine-menu>\r\n\r\n    <ul class="nav-links" ng-if="$ctrl.navigationLinks">\r\n        <li ng-repeat="link in $ctrl.navigationLinks">\r\n            <a mee-hyperlink\r\n               id="{{link.id}}"\r\n               ui-sref="{{link.state}}"\r\n               ng-attr-aria-label="{{link.ariaLabel}}"\r\n               data-bi-id="{{link.id}}"\r\n               ng-if="link.state">\r\n                {{link.text}}\r\n            </a>\r\n            <a mee-hyperlink\r\n               id="{{link.id}}"\r\n               ng-href="{{link.url}}"\r\n               ng-attr-aria-label="{{link.ariaLabel}}"\r\n               data-bi-id="{{link.id}}"\r\n               target="{{link.target}}"\r\n               ng-if="link.url">\r\n                {{link.text}}\r\n            </a>\r\n        </li>\r\n    </ul>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Redeem/redeem-catalog-subscription.html",'<div class="subscription">\r\n    <div class="totalEarnedPoints">\r\n        <img class="totalEarnedPointsIcon" ng-srcset="{{$ctrl.getIconUrl()}}" ng-src="{{$ctrl.getIconUrl()}}"\r\n            alt="coins image">\r\n        <div class="totalEarnedPointsContent">\r\n            <div class="totalEarnedPointsText">{{$ctrl.getLifetimeBalanceText()}}</div>\r\n            <mee-rewards-counter-animation class="totalEarnedPointsAmount" from="0" to="$ctrl.getLifetimeBalance()"\r\n                format="$ctrl.counterFormat"></mee-rewards-counter-animation>\r\n            <div class="totalEarnedPointsText">{{$ctrl.getLifetimePointsText()}}</div>\r\n        </div>\r\n    </div>\r\n    <div class="subscriptionBody">\r\n        <div ng-if="$ctrl.isAutoRedeemUser()" class="subscriptionTitle">\r\n            <img class="subscriptionTitleIcon" ng-srcset="{{$ctrl.getAutoRedeemIconUrl()}}"\r\n                ng-src="{{$ctrl.getAutoRedeemIconUrl()}}" alt="coins image">\r\n            <div class="subscriptionTitleHeader">{{$ctrl.getPanelTitleText()}}</div>\r\n            <div class="subscriptionTitleText">{{$ctrl.getSkuName()}}</div>\r\n        </div>\r\n        <div ng-if="$ctrl.isAutoRedeemUser()" class="subscriptionGoal">\r\n            <div class="progressBar">\r\n                <svg width="244" height="8">\r\n                    <rect x="0" y="0" rx="4" ry="4" width="244" height="8" class="progressBarLight" />\r\n                    <rect x="0" y="0" rx="4" ry="4" width="{{$ctrl.getLoadingBarLength()}}" height="8" class="progressBarDark" />\r\n                </svg>\r\n                <div class="emptyBalance" ng-if="$ctrl.isEnoughPoints">\r\n                    0\r\n                </div>\r\n                <div class="currentBalance"\r\n                    ng-style="{\'margin-left\':\'{{$ctrl.getCurrentBalanceShift()}}px\'}"\r\n                    ng-if="!$ctrl.isEnoughPoints">\r\n                    {{$ctrl.getCurrentBalance()}} {{$ctrl.getPtsText()}}\r\n                </div>\r\n                <div class="enoughPoints" ng-if="$ctrl.isEnoughPoints">\r\n                    {{$ctrl.getEnoughPointsText()}}\r\n                </div>\r\n                <div class="totalPrice">\r\n                    {{$ctrl.getSkuPrice()}}\r\n                </div>\r\n            </div>\r\n            <div class="subscriptionGoalTable">\r\n                <div>\r\n                    <div class="subscriptionGoalTableCellWithIcon">\r\n                        <div class="mee-refine-icon mee-icon icon mee-icon-Shop subscriptionGoalTableIcon"></div>\r\n                        <div class="subscriptionGoalTableDateTitle">{{$ctrl.getNextAutoRedeemText()}}</div>\r\n                    </div>\r\n                    <div class="subscriptionGoalTableDateValue"><b>{{$ctrl.getNextAutoRedeemDate()}}</b></div>\r\n                </div>\r\n                <div class="subscriptionGoalTableCell">\r\n                    <div class="subscriptionGoalTableCellValue">{{$ctrl.getDaysLeftText()}}</div>\r\n                    <div class="subscriptionGoalTableCellValue"><b>{{$ctrl.getDaysLeftValue()}}</b></div>\r\n                </div>\r\n                <div class="subscriptionGoalTableCell">\r\n                    <div class="subscriptionGoalTableCellValue">{{$ctrl.getPtsNeededText()}}</div>\r\n                    <div class="subscriptionGoalTableCellValue"><b>{{$ctrl.getPtsNeededValue()}}</b></div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div ng-if="!$ctrl.isAutoRedeemUser()" class="subscriptionContent">\r\n            <img class="subscriptionContentIcon" ng-srcset="{{$ctrl.getAutoRedeemIconUrl()}}"\r\n                ng-src="{{$ctrl.getAutoRedeemIconUrl()}}" alt="coins image">\r\n            <div class="subscriptionContentHeader">{{$ctrl.getOffTitleText()}}</div>\r\n            <div class="subscriptionContentSubHeader">{{$ctrl.getNoCardText()}}</div>\r\n            <div class="subscriptionContentText">\r\n                {{$ctrl.getMakePointsWorkText()}}<br>\r\n                {{$ctrl.getSetupMessageText()}}\r\n                <a class="subscriptionLink" ng-href="{{$ctrl.setupRedeemLink.url}}" data-bi-id="{{$ctrl.setupRedeemLink.ariaLabel}}" \r\n                    target="{{$ctrl.setupRedeemLink.target}}" id="{{$ctrl.setupRedeemLink.id}}">\r\n                    {{$ctrl.setupRedeemLink.text}}\r\n                </a>\r\n                {{$ctrl.getSetupMessageOrText()}}\r\n                <a class="subscriptionLink" ng-href="{{$ctrl.setupDonateLink.url}}" data-bi-id="{{$ctrl.setupDonateLink.ariaLabel}}"\r\n                    target="{{$ctrl.setupDonateLink.target}}" id="{{$ctrl.setupDonateLink.id}}">\r\n                    {{$ctrl.setupDonateLink.text}}\r\n                </a>\r\n                {{$ctrl.getSetupMessageBodyText()}}\r\n            </div>\r\n        </div>\r\n        <div class="subscriptionLinks">\r\n            <a class="subscriptionLink" ng-href="{{$ctrl.manageLink.url}}" data-bi-id="{{$ctrl.manageLink.ariaLabel}}"\r\n                target="{{$ctrl.manageLink.target}}" id="{{$ctrl.manageLink.id}}">\r\n                {{$ctrl.manageLink.text}}\r\n            </a>\r\n            <a class="subscriptionLink" ng-href="{{$ctrl.historyLink.url}}" data-bi-id="{{$ctrl.historyLink.ariaLabel}}" \r\n                target="{{$ctrl.historyLink.target}}" id="{{$ctrl.historyLink.id}}">\r\n                {{$ctrl.historyLink.text}}\r\n            </a>\r\n        </div>\r\n        <div ng-if="!$ctrl.isAutoRedeemUser()" class="subscriptionContentTextMobile">\r\n            {{$ctrl.getMakePointsWorkText()}}<br>\r\n            {{$ctrl.getSetupMessageText()}}\r\n            <div>\r\n                <a class="subscriptionLink" ng-href="{{$ctrl.setupRedeemLink.url}}" data-bi-id="{{$ctrl.setupRedeemLink.ariaLabel}}"\r\n                    target="{{$ctrl.setupRedeemLink.target}}" id="{{$ctrl.setupRedeemLink.id}}">\r\n                    {{$ctrl.setupRedeemLink.text}}\r\n                </a>\r\n                {{$ctrl.getSetupMessageOrText()}}\r\n                <a class="subscriptionLink" ng-href="{{$ctrl.setupDonateLink.url}}" data-bi-id="{{$ctrl.setupDonateLink.ariaLabel}}"\r\n                    target="{{$ctrl.setupDonateLink.target}}" id="{{$ctrl.setupDonateLink.id}}">\r\n                    {{$ctrl.setupDonateLink.text}}\r\n                </a>\r\n                {{$ctrl.getSetupMessageBodyText()}}\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Redeem/redeem-catalog.html",'<div id="oneUiRedeemCatalog" ng-class="{\'dense-dashboard\': $ctrl.isDenseLayout}">\r\n    <mee-rewards-user-warning ng-if="$ctrl.componentAvailabilityMap[\'userWarnings\']"\r\n                              dashboard-result="$ctrl.dashboardResult">\r\n    </mee-rewards-user-warning>\r\n    <mee-rewards-user-status-banner dashboard-result="$ctrl.dashboardResult"\r\n                                    slot-configuration=\'["profile", "giveBalance", "balance", "dailyPoint"]\'\r\n                                    ng-if="$ctrl.componentAvailabilityMap[\'userStatus\'] && !$ctrl.componentAvailabilityMap[\'anonymousUser\']"\r\n                                    ng-class="{\'dense-dashboard\': $ctrl.isDenseLayout}">\r\n    </mee-rewards-user-status-banner>\r\n    <mee-rewards-navigation-bar active-id="redeem" ng-if="!$ctrl.isDenseLayout && $ctrl.componentAvailabilityMap[\'userStatus\'] && !$ctrl.componentAvailabilityMap[\'anonymousUser\']" dashboard-result="$ctrl.dashboardResult"></mee-rewards-navigation-bar>\r\n    <mee-rewards-coupon-banner ng-if="$ctrl.componentAvailabilityMap[\'couponBanner\']"\r\n                               dashboard-result="$ctrl.dashboardResult">\r\n    </mee-rewards-coupon-banner>\r\n    <mee-rewards-give-with-bing-notice ng-if="$ctrl.componentAvailabilityMap[\'giveWithBingNotice\']"\r\n                                       dashboard-result="$ctrl.dashboardResult">\r\n    </mee-rewards-give-with-bing-notice>\r\n    <div class="rewardsContent">\r\n        <h2 id="redeem-set-goal" ng-if="$ctrl.isSetGoalMode">{{$ctrl.cmsData.strings[\'pick-a-goal\']}}</h2>\r\n        <div class="contentWrapper" ng-class="{\'contentWrapperSetGoalMode\' : $ctrl.isSetGoalMode}">\r\n            <div id="unavailable-sku" ng-if="$ctrl.isUnavailableSkuRedirect">{{$ctrl.unavailableSkuMessage}}</div>\r\n            <div id="anonymous-intro" ng-if="$ctrl.componentAvailabilityMap[\'anonymousUser\']">\r\n                {{$ctrl.cmsData.strings[\'anonymous-header\']}}\r\n            </div>\r\n            <a ng-if="$ctrl.componentAvailabilityMap[\'anonymousUser\'] && $ctrl.catalogSignInUrl"\r\n               id="anonymous-catalog-btn"\r\n               ng-href="{{$ctrl.catalogSignInUrl}}"\r\n               target="_self">\r\n                <span id="anonymous-catalog-btn-text">\r\n                    {{$ctrl.cmsData.strings[\'anonymous-header-btn-text\']}}\r\n                </span>\r\n                <span class="mee-icon pull-left icon mee-icon-ChevronRightSmall"></span>\r\n            </a>\r\n            <mee-rewards-redeem-catalog-menu is-set-goal-mode="$ctrl.isSetGoalMode"></mee-rewards-redeem-catalog-menu>\r\n            <mee-rewards-redeem-catalog-card is-set-goal-mode="$ctrl.isSetGoalMode"\r\n                                             is-set-autoredeem-mode="$ctrl.isSetAutoredeemMode"\r\n                                             dashboard-result="$ctrl.dashboardResult">\r\n            </mee-rewards-redeem-catalog-card>\r\n        </div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Redeem/redeem-donate-drop-down-list.html",'<div ng-if="$ctrl.$rootScope.showDropdown && $ctrl.donationCatalogItems" id="dropdownlist">\r\n    <label for="category-dropdown" class="sr-only">{{$ctrl.cmsData.strings[\'dropdown-category\']}}</label>\r\n    <select name=\'category\' class="dropdownContent" ng-change="$ctrl.onChangeCategory()" ng-model="$root.selectedCategory" id="category-dropdown">\r\n        <option value="">{{$ctrl.cmsData.strings[\'dropdown-category\']}}</option>\r\n        <option ng-repeat="category in $ctrl.dropdownCategoryLabels" value="{{category.Id}}">\r\n            {{category.Value}}\r\n        </option>\r\n    </select>\r\n\r\n    <label for="country-dropdown" class="sr-only">{{$ctrl.cmsData.strings[\'dropdown-country\']}}</label>\r\n    <select name=\'country\' class="dropdownContent" ng-change="$ctrl.onChangeCountry()" ng-model="$root.selectedCountry" id="country-dropdown">\r\n        <option value="">{{$ctrl.cmsData.strings[\'dropdown-country\']}}</option>\r\n        <option ng-repeat=\'country in  $ctrl.dropdownCountryLabels\' value="{{country.Id}}">{{country.Value}}</option>\r\n    </select>\r\n</div> \r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Redeem/redeem-oneclick-confirm-modal.html",'<div id="oneclickConfirmModal">\r\n    <div id="oneclick-modal-confirm-window" class="modal autoredeem-change-modal" ng-show="$ctrl.showCheckoutModal">\r\n        <div class="autoredeem-modal-content autoredeem-confirmed-content">\r\n            <button type="button" id="oneclick-confirm-close-cross" data-bi-id="autoredeem-modal-confirm-close-cross" class="autoredeem-close-cross" ng-click="$ctrl.close()" aria-label="Close">&times;</button>\r\n            <div class="content-wrapper" tabindex="0">\r\n                <div class="oneclick-content-logo">\r\n                    <img class="oneclick-modal-image" src="{{$ctrl.product.image.source}}" alt="@product.SelectedProduct.Name" />\r\n                    <a target="_blank"\r\n                       class="oneclick-modal-view-details-link"\r\n                       ng-href="{{$ctrl.formRedictionUrl()}}">\r\n                        {{$ctrl.cmsData.strings["oneclick-view-details-link-text"]}}\r\n                    </a>\r\n                </div>\r\n                <div class="oneclick-content">\r\n                    <h3 class="oneclick-modal-header">\r\n                        {{$ctrl.cmsData.strings["oneclick-redeem-your-reward-header"]}}\r\n                    </h3>\r\n                    <div class="oneclick-modal-option-div">\r\n                        <p class="oneclick-modal-sub-header">\r\n                            {{ $ctrl.selectedOption.name }}\r\n                        </p>\r\n                        <div class="autoredeem-confirmed-text">{{$ctrl.getProductPointsPrice()}} points</div>\r\n                        <div class="options-container">\r\n                            <button ng-repeat="product in $ctrl.products"\r\n                                    ng-click="product.isVariableRedemptionItem ? $ctrl.handleCustomOptionClick(product.productId) : $ctrl.selectOption(product)"\r\n                                    class="oneclick-option-button"\r\n                                    ng-class="{active: product === $ctrl.selectedOption}"\r\n                                    ng-disabled="$ctrl.isLoading">\r\n                                {{ product.itemDescription.itemGroupText.split(\' \')[0]}}\r\n                            </button>\r\n                        </div>\r\n                        <div ng-if="!$ctrl.haveEnoughPoints()" class="oneclick-modal-no-enough-point-text">{{$ctrl.cmsData.strings["oneclick-no-enough-points-warning-message"]}}</div>\r\n                        <div ng-if="$ctrl.isVariableItem() && !$ctrl.isWithoutVariable">\r\n                            <input type="number" id="intValue" name="intValue" min="5" max="100"\r\n                                   ng-model="$ctrl.customAmount"\r\n                                   ng-change="ctrl.onChangeAmount()"\r\n                                   title="{{$ctrl.cmsData.strings["oneclick-custom-option-text"]}}" />\r\n                            <div ng-if="$ctrl.customAmount === undefined">\r\n                                <p>{{$ctrl.cmsData.strings["oneclick-custom-option-text"]}}</p>\r\n                            </div>\r\n                        </div>\r\n                        <h3 class="oneclick-modal-sub-header">\r\n                            {{$ctrl.cmsData.strings["oneclick-redeem-account-message-text"]}}\r\n                        </h3>\r\n                        <div class="autoredeem-confirmed-text">{{$ctrl.getUserEmail()}}</div>\r\n                    </div>\r\n                    <div class="oneclick-modal-change-buttons">\r\n                        <button type="submit"\r\n                                id="autoredeem-set"\r\n                                data-bi-id="autoredeem-modal-confirm-submit"\r\n                                class="oneclick-modal-submit"\r\n                                ng-click="$ctrl.submit()"\r\n                                ng-disabled="!$ctrl.haveEnoughPoints() || $ctrl.selectedOption === null">\r\n                            <div id="oneclick-modal-spinner" ng-show="$ctrl.isLoading">\r\n                                <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><g id="loading-spinner" class="loading-spinner"><circle cx="12" cy="2.5" r="1.5" opacity=".14"></circle><circle cx="16.75" cy="3.77" r="1.5" opacity=".29"></circle><circle cx="20.23" cy="7.25" r="1.5" opacity=".43"></circle><circle cx="21.50" cy="12.00" r="1.5" opacity=".57"></circle><circle cx="20.23" cy="16.75" r="1.5" opacity=".71"></circle><circle cx="16.75" cy="20.23" r="1.5" opacity=".86"></circle><circle cx="12" cy="21.5" r="1.5"></circle></g></svg>\r\n                            </div>\r\n                            <div class="oneclick-modal-submit-text" ng-hide="$ctrl.isLoading">\r\n                                {{$ctrl.cmsData.strings["oneclick-redeem-button-text"]}}\r\n                            </div>\r\n                        </button>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <div id="oneclick-modal-confirmed-window" class="modal autoredeem-modal" ng-show="$ctrl.showConfirmedModal">\r\n        <div class="autoredeem-confirmed-background-image-block" ng-show="$ctrl.orderState === \'Shipped\'">\r\n            <img src="https://rewards.bing.com/rewardscdn/images/confetti.png" class="oneclick-confirmed-background-image"  alt="@product.SelectedProduct.Name" />\r\n        </div>\r\n        <div class="autoredeem-modal-content autoredeem-confirmed-content">\r\n            <button type="button" id="oneclick-confirmed-close-cross" data-bi-id="oneclick-modal-confirmed-close-cross" class="autoredeem-close-cross" ng-click="$ctrl.close()" aria-label="Close">&times;</button>\r\n            <div class="content-wrapper">\r\n                <div class="oneclick-content-logo">\r\n                    <img class="oneclick-modal-image" src="{{$ctrl.product.image.source}}" alt="@product.SelectedProduct.Name" />\r\n                </div>\r\n                <div class="oneclick-content">\r\n                    <h3 class="oneclick-modal-header">\r\n                        {{$ctrl.confirmedModalText.header}}\r\n                    </h3>\r\n                    <div class="autoredeem-confirmed-text oneclick-modal-view-details-link" ng-bind-html="$ctrl.confirmedModalText.body"></div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Redeem/redeem-recommended-affordable-card.html",'<div id="redeemRecommendedRewards" ng-class="{\'noMargin\' : $ctrl.noResult}">\r\n    <h2 id="redeemRecommendedRewards-heading" ng-if="!$ctrl.isRecommendedAffordableVisibleEmpty">{{$ctrl.cmsData.strings["redeem-recommneded-header"]}}</h2>\r\n    <mee-card-group role="list" ng-attr-aria-label="{{$ctrl.cmsData.strings[\'recommended-rewards-cards\']}}">\r\n        <mee-card ng-repeat="card in $ctrl.recommendedAffordableCatalogs"\r\n                  role="listitem" \r\n                  aria-setsize="{{$ctrl.recommendedAffordableCatalogs.length}}" \r\n                  aria-posinset="{{$index + 1}}"\r\n                  display-type="{{card.displayType}}"\r\n                  data-categories=\'["{{card.category}}"]\'\r\n                  data-sort-by-credits="{{card.price}}"\r\n                  data-card-id="{{card.productId}}"\r\n                  ng-class="$ctrl.showcaseClassName(card.showcase, card.category, card.productId)">\r\n            <card-content>\r\n                <a target="_self"\r\n                   tabindex="0"\r\n                   class="clickable-card"\r\n                   ng-if="!card.comingSoonFlag"\r\n                   ng-attr-href="{{card.callToAction.url}}"\r\n                   ng-click="card.callToAction.callFunction()"\r\n                   aria-label="{{card.title}}, item {{$index + 1}} of {{$ctrl.recommendedAffordableCatalogs.length}}">\r\n                    <div class="text-align-center rewards-card-container" data-m=\'{{card.biContentString}}\'>\r\n                        <div class="imageContainer">\r\n                            <img mee-image ng-src="{{card.image.source}}" alt="{{card.image.alternateText}}" />\r\n                        </div>\r\n                        <div class="contentContainer">\r\n                            <h4 mee-heading="heading" class="searchByName">{{card.title}}</h4>\r\n                            <div mee-paragraph="para4" ng-class="{\'hidden\' : $ctrl.isSetGoalMode, \'padding-top-24\' : card.showcase, \'price-after-coupon\' : card.couponDiscount > 0 }">{{card.couponDiscount > 0 ? card.subtitleWithCoupon : card.subtitle}}</div>\r\n                            <div mee-paragraph="para4" class="couponDiscountRemove" ng-if="card.couponDiscount > 0" ng-class="{\'hidden\' : $ctrl.isSetGoalMode, \'padding-top-24\' : card.showcase}">{{card.subtitle}}</div>\r\n                        </div>\r\n                        <mee-rewards-debug-info item="card"></mee-rewards-debug-info>\r\n                        <mee-rewards-coupon-info item="card"></mee-rewards-coupon-info>\r\n\r\n                        <div class="actionLink">\r\n                            <span class="redeemAction"\r\n                                  ng-if="card.callToAction.text"\r\n                                  id="{{card.callToAction.id}}"\r\n                                  data-bi-id="{{card.callToAction.id}}"\r\n                                  aria-label="{{card.callToAction.ariaLabel}}, item {{$index + 1}} of {{$ctrl.recommendedAffordableCatalogs.length}}">\r\n                                <img ng-if="card.isOneclickEligible" class="starIcon" ng-srcset="//rewards.bing.com/rewardscdn/images/rewards/membercenter/missions/StreakProtection/NewStars.png" ng-src="//rewards.bing.com/rewardscdn/images/flame.png" alt="oneclick star image"> {{card.callToAction.text}} <i class="mee-icon pull-left mee-icon-ChevronRightSmall"></i>\r\n                            </span>\r\n                        </div>\r\n                    </div>\r\n                </a>\r\n            </card-content>\r\n        </mee-card>\r\n    </mee-card-group>\r\n    <div class="lineDivider" ng-if="!$ctrl.isRecommendedAffordableVisibleEmpty"></div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/ReferAndEarn/refer-and-earn-5x-banner.html",'<div id="referAndEarn5xBanner" class="referAndEarn5xBannerContent">\r\n    <div class="fiveXImageContainer">\r\n        <div class="card-content-area">\r\n            <h2 ng-if="$ctrl.cardTitle"\r\n                class="inviteTextTitle">\r\n                {{$ctrl.cardTitle}}\r\n            </h2>\r\n            <div ng-if="$ctrl.subtitle" class="inviteTextSubtitle">{{$ctrl.subtitle}}</div>\r\n            <div ng-if="$ctrl.description" class="inviteTextDescription">{{$ctrl.description}}</div>\r\n        </div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/ReferAndEarn/refer-and-earn-entry-card.html",'<div class="referAndEarnCardContainer">\r\n    <div class="mainContent" ng-class="{\'beta\': $ctrl.isBeta}">\r\n        <div class="upper-section">\r\n            <div class="text-content">\r\n            <p class="titleNumber" ng-class="{\'pointsCard\': ($ctrl.cardId == \'total-points\' || $ctrl.cardId == \'total-points-two-layer\') && !$ctrl.isTwoLayer}" role="text" aria-label="{{$ctrl.referAndEarnSubCard.cardTitleAriaLabel}}"> {{$ctrl.referAndEarnSubCard.titleNumber | number:0}}</p>\r\n            <div class="subtitleSection">\r\n                <p class="subTitle" role="text" id="card-subtitle">{{$ctrl.referAndEarnSubCard.subtitle}}</p>\r\n                <div class="sr-only" aria-live="polite" aria-atomic="true" ng-bind="$ctrl.pendingInfoAnnouncement"></div>\r\n                <div ng-if="$ctrl.hasTooltip" class="rafTextAndIcon" ng-click="$ctrl.openTooltip($event, $ctrl.tooltipId)">\r\n                    <mee-rewards-tooltip id="$ctrl.tooltipId"\r\n                                         tooltip-id="$ctrl.tooltipId"\r\n                                         tooltip-description="$ctrl.tooltipText"\r\n                                         beak-direction="$ctrl.beakDirection"\r\n                                         cms-data="$ctrl.cmsData"\r\n                                         tooltip-aria-label="$ctrl.cmsData.strings[\'pending-points-tooltip-aria-label\']">\r\n                    </mee-rewards-tooltip>\r\n                </div>\r\n            </div>\r\n            </div>\r\n            <div class="imageContainer">\r\n                <img class="cardImage" ng-class="{\'pointsCard\': $ctrl.cardId == \'total-points\' || $ctrl.cardId == \'total-points-two-layer\' }" ng-src="{{$ctrl.referAndEarnSubCard.image}}" role="presentation">\r\n            </div>\r\n        </div>\r\n        <div class="highlightSection" ng-if="$ctrl.hasHighlight"\r\n             ng-class="{\'beta\': $ctrl.isBeta, \'friendCard\': $ctrl.cardId == \'total-friends\' || $ctrl.cardId == \'grand-friends\', \'pendingCard\': $ctrl.cardId == \'pending-points\' || $ctrl.cardId == \'pending-points-two-layer\', \'hasError\': $ctrl.referAndEarnSubCard.hasPendingError}">\r\n            <p class="highlight" role="text">\r\n                <img class="icon" ng-src="{{$ctrl.highlightIcon}}" role="presentation">\r\n                {{$ctrl.referAndEarnSubCard.highlightText}}\r\n            </p>\r\n        </div>\r\n        <div class="highlightSection" ng-if="!$ctrl.hasHighlight">\r\n        </div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/ReferAndEarn/refer-and-earn-invite-big-button.html",'<div id="referAndEarnInviteCard" class="referAndEarnBlueButtonInviteContent">\r\n    <div class="referAndEarnInviteImageContainer">\r\n        <img class="referAndEarnInviteImages" ng-srcset=\'{{$ctrl.RafInviteLeftImageUrl}}\' ng-src=\'{{$ctrl.RafInviteLeftImageUrl}}\' role="presentation">\r\n    </div>\r\n    <div class="card-content-area">\r\n        <h2 ng-if="$ctrl.cardTitle"\r\n            class="inviteTextTitle">\r\n            {{$ctrl.cardTitle}}\r\n        </h2>\r\n        <div ng-if="$ctrl.subtitle" class="inviteTextSubtitle">{{$ctrl.subtitle}}</div>\r\n        \x3c!-- Buttons --\x3e\r\n        <div ng-if="!$ctrl.currentUser.isAnonymous && $ctrl.hasPuid" class="rafInviteButtonContainer">\r\n            <div class="inputButtonsShare">\r\n                <a tabindex="0" mee-button="primary" id="refShareButton" class="inviteCloseButton" ng-keypress="$event.keyCode === 13 && $ctrl.onShareClick()" ng-click="$ctrl.onShareClick()"\r\n                   aria-label="{{ $ctrl.moreOptions }}" role="button">\r\n                    <i role="presentation" class="mee-icon mee-icon-Share buttonIcon"></i>\r\n                    {{$ctrl.moreOptions}}\r\n                </a>\r\n            </div>\r\n            <div class="inputButtons">\r\n                <div class="sr-only" aria-live="polite" ng-bind="$ctrl.copyStatus"></div>\r\n                <div class="rafTextAndIcon sptooltip" ng-keypress="$event.keyCode === 13 && $ctrl.openTooltip($event, $ctrl.tooltipId)" ng-click="$ctrl.openTooltip($event, $ctrl.tooltipId)">\r\n                    <input id="referralLinkInputBox" ng-attr-aria-label="{{$ctrl.cmsData.strings[\'share-invite-referal-link-input-text\']}}" type="text" value=\'{{$ctrl.referrerLink}}\' readonly>\r\n                    <mee-rewards-tooltip id="$ctrl.tooltipId"\r\n                                         tooltip-id="$ctrl.tooltipId"\r\n                                         tooltip-description="$ctrl.copyText"\r\n                                         beak-direction="$ctrl.beakDirection"\r\n                                         cms-data="$ctrl.cmsData">\r\n                    </mee-rewards-tooltip>\r\n                </div>\r\n                <a tabindex="0" mee-button id="refUrlCopyButton"  \r\n                   ng-keydown="\r\n                   ($event.keyCode === 13 || $event.keyCode === 32) && $event.preventDefault();\r\n                   ($event.keyCode === 13 || $event.keyCode === 32) && $event.currentTarget.click()"\r\n                   class="rafInviteSelectButton" \r\n                   ng-click="$ctrl.onCopyClick()" \r\n                   ng-if="$ctrl.clipboardService.isCopySupported()"\r\n                   ng-attr-aria-label="{{$ctrl.cmsData.strings[\'share-invite-copy-link-text\']}}" \r\n                   target="_self" role="button">\r\n                    <i role="presentation" class="mee-icon mee-icon-Copy buttonIcon" aria-hidden="true"></i>\r\n                    {{$ctrl.copyLink}}\r\n                    <mee-flyout class="copyFlyout" has-beak="true" dismissible="true" placement="top">\r\n                        <p mee-paragraph="para2" class="flyouttext"> {{$ctrl.cop