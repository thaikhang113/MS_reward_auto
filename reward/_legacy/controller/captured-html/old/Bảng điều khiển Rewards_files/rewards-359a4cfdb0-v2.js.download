ata"\r\n                    ui-sref="{{$ctrl.callToAction.url}}">\r\n        </button>\r\n        <button class="button"\r\n                ng-click="$ctrl.onClick()"\r\n                aria-label="{{$ctrl.buttonText}}">\r\n            {{$ctrl.buttonText}}\r\n        </button>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/PointClaimOverlay/pointclaim-overlay.html",'<div class="point-claim-overlay" id="point-claim-overlay">\r\n  <h2>{{ $ctrl.cmsData.strings["pointclaim-overlay-title"] }}</h2>\r\n  <p>{{ $ctrl.subtitle }}</p>\r\n  <table class="points-table">\r\n    <thead>\r\n      <tr>\r\n        <th>{{ $ctrl.cmsData.strings["pointclaim-overlay-table-activity"] }}</th>\r\n        <th>{{ $ctrl.cmsData.strings["pointclaim-overlay-table-expiry"] }}</th>\r\n        <th>{{ $ctrl.cmsData.strings["pointclaim-overlay-table-points"] }}</th>\r\n      </tr>\r\n    </thead>\r\n    <tbody>\r\n      <tr ng-repeat="category in $ctrl.pointClaimCategoryBreakdowns">\r\n        <td>{{ category.name }}</td>\r\n        <td>{{ category.expiry_text }}</td>\r\n        <td>{{ category.points }}</td>\r\n      </tr>\r\n    </tbody>\r\n  </table>\r\n \x3c!-- Mobile View Table --\x3e\r\n <div class="points-mobile-table" ng-repeat="category in $ctrl.pointClaimCategoryBreakdowns">\r\n    <table>\r\n      <tr>\r\n        <td class="points-mobile-label">{{ $ctrl.cmsData.strings["pointclaim-overlay-table-activity"] }}</td>\r\n        <td class="points-mobile-value">{{ category.name }}</td>\r\n      </tr>\r\n      <tr>\r\n        <td class="points-mobile-label">{{ $ctrl.cmsData.strings["pointclaim-overlay-table-expiry"] }}</td>\r\n        <td class="points-mobile-value">{{ category.expiry_text }}</td>\r\n      </tr>\r\n      <tr>\r\n        <td class="points-mobile-label">{{ $ctrl.cmsData.strings["pointclaim-overlay-table-points"] }}</td>\r\n        <td class="points-mobile-value">{{ category.points }}</td>\r\n      </tr>\r\n    </table>\r\n  </div>\r\n  <div class="total-points">\r\n    <span class="total-points-label">{{ $ctrl.cmsData.strings["pointclaim-overlay-total-points"] }}</span>\r\n    <span class="total-points-value">{{ $ctrl.claimablePoints }}</span>\r\n  </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/Popup/pop-up.html",'<div id="popUpModal" tabindex="-1" class="dashboardPopUpModal" ng-show="$ctrl.isModalVisible" role="alertdialog" aria-modal="true" aria-labelledby="dashboardPopUpModalTitle">\r\n    <div class="confetti-image-block" ng-show="$ctrl.isConfettiVisible">\r\n        <img ng-srcset="{{$ctrl.getConfettiSrc()}}" ng-src="{{$ctrl.getConfettiSrc()}}" class="confetti-background-image" alt="confetti image">\r\n    </div>\r\n    <div class="dashboardPopUpModalContent">\r\n        <h1 ng-if="$ctrl.contentHeader" class="dashboardPopUpModalHeader">{{$ctrl.contentHeader}}</h1>\r\n        <div class="dashboardPopUpModalImageContainer">\r\n            <img ng-class="$ctrl.imageClassName" ng-srcset=\'{{$ctrl.getStaticContent("image")}}\' ng-src=\'{{$ctrl.getStaticContent("image")}}\' alt="pop up hero image">\r\n            <span ng-class="$ctrl.closeButtonClassName" id="streak-protection-popup-close-cross" ng-click="$ctrl.hidePopUp($event)" ng-keypress="$event.keyCode === 13 && $ctrl.hidePopUp($event)" data-bi-id="rx-nav-streak-protection-popup-close-cross" role="button" tabindex="0" aria-label="Close">&times;</span>\r\n        </div>\r\n        <h2 id="dashboardPopUpModalTitle" ng-class="$ctrl.titleClassName" tabindex="-1">{{$ctrl.contentTitle}}</h2>\r\n        <p ng-class="$ctrl.descClassName" ng-bind-html=\'$ctrl.contentDescription\'></p>\r\n        <div ng-class="$ctrl.buttonContainerClassName">\r\n            <a ng-if="!$ctrl.hidePrimaryButton && $ctrl.promotionSubtype != \'programrestructure\'" ng-class="$ctrl.buttonClassName" ng-click="$ctrl.hidePopUpAndApplyFunction($event)" ng-keypress="$event.keyCode === 13 && $ctrl.hidePopUpAndApplyFunction($event)" data-bi-id="rx-nav-popup"\r\n               target="_self" id="reward_pivot_earn"\r\n               role="button" tabindex="0" aria-label="{{$ctrl.getStaticContent("link")}}">\r\n                {{$ctrl.getStaticContent("link")}}\r\n            </a>\r\n            <a ng-if="!$ctrl.hidePrimaryButton && $ctrl.promotionSubtype == \'programrestructure\'" ng-class="$ctrl.buttonClassName" data-bi-id="rx-nav-popup"\r\n               target="_self" id="reward_pivot_earn"\r\n               ng-click="$ctrl.hidePopUpAndRedirect($event)"\r\n               ng-keypress="$event.keyCode === 13 && $ctrl.hidePopUpAndRedirect($event)"\r\n               title="{{$ctrl.promotion.link}}"\r\n               role="button" tabindex="0" aria-label="{{$ctrl.promotion.link}}">\r\n                {{$ctrl.getStaticContent("link")}}\r\n            </a>\r\n            <a ng-if="$ctrl.popUpHasTwoBtn()"\r\n               class="dashboardPopUpPopUpCloseButton"\r\n               data-bi-id="rx-nav-popup-close"\r\n               ng-click="$ctrl.hidePopUp($event)"\r\n               ng-keypress="$event.keyCode === 13 && $ctrl.hidePopUp($event)"\r\n               title="{{$ctrl.promotion.link2}}"\r\n               role="button" tabindex="0" aria-label="{{$ctrl.promotion.link2}}">\r\n                {{$ctrl.getStaticContent("link2")}}\r\n            </a>\r\n        </div>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/PuzzleLevelUpProgress/puzzle-level-up-progress.html",'<div class="text-align-center rewards-card-container with-points level-up focus-tooltip"\r\n     ng-mouseover="$ctrl.showTooltip()"\r\n     ng-mouseout="$ctrl.hideTooltip()">\r\n  <p>\r\n    <mee-rewards-level-up-completion completed="$ctrl.levelUpCompleted" max="$ctrl.levelUpMax">\r\n    </mee-rewards-level-up-completion>\r\n  </p>\r\n  <div class="infoContainer">\r\n      <div class="imageContainer padding">\r\n          <img mee-image ng-src="{{$ctrl.info.icon.source}}" alt="{{$ctrl.info.icon.alternateText}}"\r\n               aria-hidden="true" />\r\n      </div>\r\n\r\n      <div class="contentContainer">\r\n          <div class="contentTitle">\r\n              <h3 class="contentRightMargin">{{$ctrl.info.title}}</h3>\r\n              <mee-rewards-tooltip ng-if="$ctrl.tooltipDescription"\r\n                                   tooltip-id="$ctrl.tooltipId"\r\n                                   tooltip-description="$ctrl.tooltipDescription"\r\n                                   beak-direction="\'down\'"\r\n                                   cms-data="$ctrl.cmsData"\r\n                                   ng-class="levelTooltip">\r\n              </mee-rewards-tooltip>\r\n          </div>          \r\n          <p mee-paragraph="para4" class="c-meta-text">{{$ctrl.info.subtitle}}</p>\r\n\r\n          <div class="actionLink" ng-if="$ctrl.info.callToAction">\r\n              <a mee-call-to-action="lightweight"\r\n                 id="{{$ctrl.info.callToAction.id}}"\r\n                 ng-href="{{$ctrl.info.callToAction.url}}">\r\n                  {{$ctrl.cmsData.strings[$ctrl.info.callToAction.text]}}\r\n              </a>\r\n          </div>\r\n      </div>\r\n  </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/RafBanner/raf-top-banner.html",'<div id="raf-top-banner-container" ng-if="($ctrl.isValid)">\r\n    <div data-grid="container pad-12x" id="raf-top-banner">\r\n        <img class="icon" ng-srcset="{{$ctrl.iconUrl}}" ng-src="{{$ctrl.iconUrl}}" role="presentation" ng-style="$ctrl.getIconStyle()">\r\n        <span>{{$ctrl.title}}</span>\r\n        <button id="sendinvite-button" ng-if="$ctrl.showBannerButton"\r\n                ng-keypress="$event.keyCode === 13 && $ctrl.onClick()"\r\n                ng-click="$ctrl.onClick()"\r\n                aria-label="{{$ctrl.buttonText}}">\r\n            {{$ctrl.buttonText}}\r\n        </button>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/SaleInfo/sale-info.html",'<div class="sale-info" ng-if="$ctrl.showSaleInfo">\r\n    <p mee-paragraph="para4">{{$ctrl.text}}</p>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/SapphireCaptcha/sapphire-captcha.html",'<div class="sapphire-captcha-container">\r\n\r\n    \x3c!-- DESKTOP: QR Code Verification --\x3e\r\n    <div class="qr-code" ng-show="!$ctrl.isMobile">\r\n        <div class="step-one">{{$ctrl.cmsStrings.qrCodeFlowStep1}}</div>\r\n\r\n        \x3c!-- Desktop Instructional Block --\x3e\r\n        <div class="captcha-instructions">\r\n            <div class="instructions-text">\r\n                <p class="no-app">💡{{$ctrl.cmsStrings.dontHaveTheBingApp}}</p>\r\n                <ul>\r\n                    <li>{{$ctrl.cmsStrings.downloadTheBingAppQrCode}}</li>\r\n                    <li>{{$ctrl.cmsStrings.signInToVerifyQrCode}}</li>\r\n                </ul>\r\n            </div>\r\n        </div>\r\n\r\n        <div id="step-two" ng-class="{ \'verified\': $ctrl.isCaptchaVerified, \'step-two\': !$ctrl.isCaptchaVerified }"\r\n            ng-bind-html="$ctrl.qrVerificationText">\r\n        </div>\r\n\r\n        <div class="wrapper" tabindex="0" aria-live="polite" aria-atomic="true">\r\n            \x3c!-- QR Code Container --\x3e\r\n            <div class="qr-container" ng-class="{ \'qr-verified\': $ctrl.isCaptchaVerified }">\r\n                \x3c!-- QR Code Image --\x3e\r\n                <img id="qrCodeImage"\r\n                     ng-class="{\r\n                         \'blurred\': $ctrl.isRefreshChallengeDetailsSuccess,\r\n                         \'refreshing\': $ctrl.isRefreshingChallengeDetails\r\n                     }"\r\n                     ng-src="data:image/png;base64,{{ $ctrl.sapphireCaptchaQrCode }}"\r\n                     alt="{{ $ctrl.cmsStrings.qrCodeAltText }}" />\r\n\r\n                \x3c!-- Bing App Logo --\x3e\r\n                <div id="bingLogo" aria-hidden="true">\r\n                    <img ng-src="{{ $ctrl.areaConfig.bingAppLogoUrl }}"\r\n                         alt=""\r\n                         role="presentation" />\r\n                </div>\r\n\r\n                \x3c!-- Loading Spinner Overlay (centered on QR code) --\x3e\r\n                <div class="qr-loading-overlay"\r\n                     ng-show="$ctrl.isRefreshingChallengeDetails"\r\n                     role="status"\r\n                     aria-live="polite"\r\n                     aria-label="Loading new challenge">\r\n                    <div class="spinner-icon"></div>\r\n                    <span class="sr-only">{{$ctrl.cmsStrings.refreshing}}</span>\r\n                </div>\r\n\r\n                \x3c!-- Verification Success Overlay --\x3e\r\n                <div class="qr-verified-overlay"\r\n                     ng-show="$ctrl.isCaptchaVerified"\r\n                     aria-hidden="true">\r\n                    <div class="verified-checkmark">✓</div>\r\n                </div>\r\n            </div>\r\n\r\n            \x3c!-- Refresh Action --\x3e\r\n            <div class="refresh-button"\r\n                 type="button"\r\n                 ng-if="$ctrl.isRefreshChallengeDetailsSuccess && !$ctrl.isRefreshingChallengeDetails"\r\n                 ng-click="$ctrl.onRefreshClick()"\r\n                 ng-keydown="$ctrl.handleKeyDown($event)"\r\n                 role="button"\r\n                 tabindex="0"\r\n                 title="{{ $ctrl.cmsStrings.refreshVerification }}"\r\n                 aria-label="{{ $ctrl.cmsStrings.refreshVerification }}">\r\n                <svg class="refresh-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">\r\n                    <path d="M4 4V9H4.58152M4.58152 9C5.24618 7.35652 6.43101 5.9663 7.96114 5.02513C9.49127 4.08395 11.2865 3.63727 13.0729 3.74103C14.8593 3.84479 16.5776 4.49404 18.0072 5.59966C19.4367 6.70529 20.5069 8.21361 21.0729 9.94969M4.58152 9H9M20 20V15H19.4185M19.4185 15C18.7538 16.6435 17.569 18.0337 16.0389 18.9749C14.5087 19.9161 12.7135 20.3627 10.9271 20.259C9.14067 20.1552 7.42241 19.506 5.99284 18.4003C4.56328 17.2947 3.49312 15.7864 2.92712 14.0503M19.4185 15H15"\r\n                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />\r\n                </svg>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    \x3c!-- MOBILE: Tap-to-Verify Button --\x3e\r\n    <div class="next-button-container" ng-show="$ctrl.isMobile">\r\n        <div class="step-one" ng-show="$ctrl.isBingSapphireApp" ng-bind-html="$ctrl.tapButtonText"></div>\r\n\r\n        \x3c!-- Mobile Instructional Block (shown only when NOT deep link) --\x3e\r\n        <div class="captcha-instructions" \r\n             ng-if="!$ctrl.isBingSapphireApp">\r\n            <div class="instructions-text">\r\n                <div class="step-one" ng-bind-html="$ctrl.tapButtonText"></div>\r\n                <p class="no-app">💡{{$ctrl.cmsStrings.dontHaveTheBingApp}}</p>\r\n                <ul>\r\n                    <li>{{$ctrl.cmsStrings.downloadTheBingAppButton}}</li>\r\n                    <li>{{$ctrl.cmsStrings.signInToVerifyButton}}</li>\r\n                </ul>\r\n            </div>\r\n        </div>\r\n\r\n        <div class="next-button-wrapper">\r\n            \x3c!-- Mobile Verification Button --\x3e\r\n            <a class="next-button"\r\n               ng-show="!$ctrl.isBingSapphireApp"\r\n               ng-href="{{ $ctrl.trustedCaptchaUrl }}"\r\n               target="_blank"\r\n               role="button"\r\n               tabindex="0"\r\n               ng-class="{\r\n                   \'disabled\': $ctrl.isRefreshChallengeDetailsSuccess,\r\n                   \'verified\': $ctrl.isCaptchaVerified,\r\n                   \'countdown-disabled\': $ctrl.isCountdownActive,\r\n                   \'loading\': $ctrl.isRefreshingChallengeDetails\r\n               }"\r\n               aria-disabled="{{ $ctrl.isButtonBeDisabled() }}"\r\n               ng-click="$ctrl.handleCaptchaClick($event)">\r\n               \r\n               \x3c!-- Loading State --\x3e\r\n               <div class="button-spinner" \r\n                    ng-show="$ctrl.isRefreshingChallengeDetails"\r\n                    role="status" \r\n                    aria-hidden="true">\r\n                   <div class="spinner-icon"></div>\r\n               </div>\r\n               \r\n               \x3c!-- Button Content --\x3e\r\n               <span ng-show="!$ctrl.isRefreshingChallengeDetails" \r\n                     ng-bind-html="$ctrl.ctaButtonText"></span>\r\n               <span ng-show="$ctrl.isRefreshingChallengeDetails"\r\n                     class="loading-text">{{$ctrl.cmsStrings.refreshing}}</span>\r\n            </a>\r\n\r\n            \x3c!-- Mobile refresh button --\x3e\r\n            <a class="next-button"\r\n               ng-show="$ctrl.isBingSapphireApp"\r\n               ng-href="{{ $ctrl.trustedCaptchaUrl }}"\r\n               role="button"\r\n               ng-class="{\r\n                   \'disabled\': $ctrl.isRefreshChallengeDetailsSuccess,\r\n                   \'verified\': $ctrl.isCaptchaVerified,\r\n                   \'countdown-disabled\': $ctrl.isCountdownActive,\r\n                   \'loading\': $ctrl.isRefreshingChallengeDetails\r\n               }"\r\n               aria-disabled="{{ $ctrl.isButtonDisabled() }}"\r\n               ng-click="$ctrl.handleCaptchaClick($event)">\r\n               \r\n               \x3c!-- Loading Spinner inside button --\x3e\r\n               <div class="button-spinner" \r\n                    ng-show="$ctrl.isRefreshingChallengeDetails"\r\n                    role="status" \r\n                    aria-hidden="true">\r\n                   <div class="spinner-icon"></div>\r\n               </div>\r\n               \r\n               \x3c!-- Button Text --\x3e\r\n               <span ng-show="!$ctrl.isRefreshingChallengeDetails" \r\n                     ng-bind-html="$ctrl.ctaButtonText"></span>\r\n               <span ng-show="$ctrl.isRefreshingChallengeDetails"\r\n                     class="loading-text">{{$ctrl.cmsStrings.refreshing}}</span>\r\n            </a>\r\n\r\n            \x3c!-- Refresh Button for Mobile --\x3e\r\n            <div class="refresh-button-next"\r\n                    type="button"\r\n                    ng-if="$ctrl.isRefreshChallengeDetailsSuccess && !$ctrl.isRefreshingChallengeDetails"\r\n                    ng-click="$ctrl.onRefreshClick()"\r\n                    ng-keydown="$ctrl.handleKeyDown($event)"\r\n                    role="button"\r\n                    tabindex="0"\r\n                    title="{{ $ctrl.cmsStrings.refreshVerification }}"\r\n                    aria-label="{{ $ctrl.cmsStrings.refreshVerification }}">\r\n                <svg class="refresh-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">\r\n                    <path d="M4 4V9H4.58152M4.58152 9C5.24618 7.35652 6.43101 5.9663 7.96114 5.02513C9.49127 4.08395 11.2865 3.63727 13.0729 3.74103C14.8593 3.84479 16.5776 4.49404 18.0072 5.59966C19.4367 6.70529 20.5069 8.21361 21.0729 9.94969M4.58152 9H9M20 20V15H19.4185M19.4185 15C18.7538 16.6435 17.569 18.0337 16.0389 18.9749C14.5087 19.9161 12.7135 20.3627 10.9271 20.259C9.14067 20.1552 7.42241 19.506 5.99284 18.4003C4.56328 17.2947 3.49312 15.7864 2.92712 14.0503M19.4185 15H15"\r\n                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />\r\n                </svg>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    \x3c!-- Error State --\x3e\r\n    <div class="error" ng-if="$ctrl.isRefreshChallengeDetailsSuccess">\r\n        <div class="error-refreshing-chg-details"\r\n             role="alert"\r\n             aria-live="assertive"\r\n             aria-atomic="true"\r\n             tabindex="0">\r\n            <span class="error-message">\r\n                {{ $ctrl.cmsStrings.somethingWentWrong }}\r\n            </span>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/SearchOnBingSevenDaysProgress/search-on-bing-seven-days-progress.html",'<div class="text-align-center rewards-card-container with-points level-up">\r\n  <p>\r\n    <mee-rewards-level-up-completion completed="$ctrl.levelUpCompleted" max="$ctrl.levelUpMax" progress="$ctrl.showProgress", hvaFlight="$ctrl.hvaFlight">\r\n    </mee-rewards-level-up-completion>\r\n  </p>\r\n  <div class="infoContainer">\r\n    <div class="imageContainer padding">\r\n      <img mee-image ng-src="{{$ctrl.info.icon.source}}" alt="{{$ctrl.info.icon.alternateText}}"\r\n        aria-hidden="true" />\r\n    </div>\r\n  \r\n    <div class="contentContainer">\r\n        <h3>{{$ctrl.info.title}}</h3>\r\n        <p mee-paragraph="para4" class="c-meta-text margin-bottom-15">{{$ctrl.info.subtitle}}</p>\r\n\r\n        <div class="actionLink" ng-if="$ctrl.info.callToAction">\r\n            <a mee-call-to-action="lightweight"\r\n               class="cwunder"\r\n               id="{{$ctrl.info.callToAction.id}}"\r\n               ng-href="{{$ctrl.info.callToAction.url}}"\r\n               aria-label="{{$ctrl.info.callToAction.text}} about {{$ctrl.info.title}}">\r\n                {{$ctrl.info.callToAction.text}}\r\n            </a>\r\n        </div>\r\n        <span class="level-up-footer" ng-class="{\'green-text\': $ctrl.showCompletedText}" ng-if="$ctrl.footerText">\r\n            {{$ctrl.footerText}}\r\n        </span>\r\n    </div>\r\n  </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/Social/fb-share.html",'<a mee-no-ref\r\n   id="fb-share-button"\r\n   data-bi-id="fb-share-button"\r\n   ng-click="$ctrl.onClick()"\r\n   class="share-plugin"\r\n   role="button"\r\n   aria-label="{{$ctrl.model.modalOptions.buttonText}}"\r\n   tabindex="0">\r\n    <mee-safe-image aria-hidden="true" src="$ctrl.cmsData.strings[\'social-fb-button-logo\']"\r\n                     alt="{{$ctrl.model.modalOptions.buttonText}}">\r\n        <span></span>\r\n    </mee-safe-image>\r\n    <span>{{$ctrl.model.modalOptions.buttonText}}</span>\r\n</a>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/Social/messenger-share.html",'<a mee-no-ref\r\n   id="messenger-share-button"\r\n   data-bi-id="messenger-share-button"\r\n   ng-click="$ctrl.onClick()"\r\n   tabindex="0"\r\n   alt="{{$ctrl.model.modalOptions.buttonText}}"\r\n   class="share-plugin">\r\n    <mee-safe-image aria-hidden="true" src="$ctrl.cmsData.strings[\'social-messenger-button-logo\']"\r\n                    alt="{{$ctrl.model.modalOptions.buttonText}}">\r\n        <span></span>\r\n    </mee-safe-image>\r\n    <span>{{$ctrl.model.modalOptions.buttonText}}</span>\r\n</a>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/Social/twitter-share.html",'<a mee-no-ref\r\n   id="tw-share-button"\r\n   data-bi-id="tw-share-button"\r\n   ng-click="$ctrl.onClick()"\r\n   tabindex="0">\r\n    <i class="mee-icon pull-left icon mee-icon-TwitterLogo"></i>\r\n    {{$ctrl.model.modalOptions.buttonText}}\r\n</a>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/StarBonusWeeklyBanner/star-bonus-weekly-banner.html",'<div ng-if="$ctrl.isValid" ng-show="$ctrl.show" class="star-bonus-weekly-banner" data-bi-id="{{$ctrl.biId}}">\r\n    <span class="sparkle sparkle-1"></span>\r\n    <span class="sparkle sparkle-2"></span>\r\n    <span class="sparkle sparkle-3"></span>\r\n    <picture id="{{item.dynamicImage === \'true\' ? \'dynamic-img\' : \'\'}}" class="{{item.customBannerPromo ? \'custom-bg\' : \'\'}}">\r\n        <i class="mee-icon pull-left icon mee-icon-Cancel"\r\n           tabindex="0"\r\n           ng-attr-aria-label="{{$ctrl.cmsData.strings[\'promo-close\']}}"\r\n           role="button"\r\n           ng-click="$ctrl.clickPromotionFunc($event, true)"\r\n           ng-keydown="$ctrl.clickPromotionFunc($event, true)" />\r\n    </picture>\r\n    <div class="hero-text">\r\n        <h2 mee-heading="heading" ng-style="$ctrl.getStyleObject($ctrl.titleStyle)">{{$ctrl.title}}</h2>\r\n        <p mee-heading="subheading">{{$ctrl.description }}</p>\r\n        <a ng-href="{{$ctrl.destination}}" tabindex="-1"\r\n           ng-click="$ctrl.clickPromotionFunc($event, false)"\r\n           ng-keydown="$ctrl.clickPromotionFunc($event, false)">\r\n            <button class="cta-button">{{ $ctrl.buttonText }}</button>\r\n        </a>\r\n    </div>\r\n    <div class="weekly-progress-status">\r\n        <mee-rewards-star-bonus-weekly-progress weekly-banner-promotion="$ctrl.weeklyBannerPromotion"></mee-rewards-star-bonus-weekly-progress>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/StarBonusWeeklyProgress/star-bonus-weekly-progress.html",'<div class="starbonus-progress-card">\r\n    <p>\r\n        <div class="starbonus-progress-header">\r\n            <h3 class="starbonus-progress-title">{{ $ctrl.title }}</h3>\r\n            <p class="starbonus-progress-desc">{{ $ctrl.description }}</p>\r\n        </div>\r\n    </p>\r\n    <div id="starBonusProgressBar">\r\n        <div class="progress-container">\r\n            <div class="progress-bar">\r\n                <div class="progress-fill" ng-style="{\'width\': \'{{$ctrl.progressPercentage}}\'}">  </div>\r\n            </div>\r\n            <div class="progress-dot" ng-style="{\'left\': \'{{$ctrl.progressPercentage}}\'}">\r\n                <div class="tooltip">{{$ctrl.current}}</div>\r\n            </div>\r\n            <div class="scale">\r\n                <span ng-repeat="limit in $ctrl.starBonusConfig">{{limit}}</span>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/StatusIndicator/status-indicator.html",'<div id="hvaModalStatusIndicator">\r\n  <div class="status-indicator" ng-class="$ctrl.indicatorStyles" title="{{$ctrl.indicatorTitle}}">\r\n    <svg class="completed-icon" xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 