562 2.17418Z" fill="black"/>\r\n    </svg>\r\n    {{ $ctrl.indicatorText }}\r\n  </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/Toggle/toggle.html",'<div id="ModeOn"\r\n     role="button"\r\n     aria-label="{{$ctrl.ariaLabel}} {{$ctrl.toggleText}}"\r\n     tabindex="0"\r\n     ng-class="$ctrl.toggleClassName()"\r\n     ng-click="$ctrl.toggleOnClick()"\r\n     ng-keyup="$ctrl.toggleOnKeyEnter($event)"\r\n     title="{{$ctrl.toggleText}}">\r\n    <p class="title">{{$ctrl.toggleText}}</p>\r\n    <div class="roundedButton"></div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/Tooltip/tooltip.html",'<div id="tooltipContainer">\r\n    <div id="{{$ctrl.tooltipId}}"\r\n         class="rewardsTooltips beak"\r\n         ng-class="$ctrl.getBeakDirectionClassName()"\r\n         ng-click="$ctrl.onTooltipContainerClick()">\r\n        <h3 ng-if="$ctrl.tooltipTitle"\r\n            mee-heading="heading"\r\n            class="x-type-center margin-bottom-10">\r\n            {{$ctrl.tooltipTitle}}\r\n        </h3>\r\n        <p ng-if="$ctrl.tooltipDescription"\r\n           id="{{$ctrl.tooltipId}}-body"\r\n           mee-paragraph="para4"\r\n           class="x-type-center"\r\n           ng-bind-html="$ctrl.tooltipDescription">\r\n        </p>\r\n    </div>\r\n    <button id="{{$ctrl.tooltipId}}" mee-action-trigger data-glyph={{$ctrl.getTooltipIcon()}} ng-click="$ctrl.onTooltipButtonClick()" aria-label="{{$ctrl.tooltipAriaLabel || $ctrl.getPlainTextDescription($ctrl.tooltipDescription)}}"></button>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/UserStatus/earning-report-pointsbreakdown.html",'<div id="userPointsBreakdown" data-grid="col-12" tabindex="-1" class="earningReport text-align-center"\r\n    ng-class="{\'new-levels-feature\': $ctrl.isNewLevelsFeatureAvailable}">\r\n\r\n    <div class="center">\r\n        <div data-grid="8" id="earningreport-level-heading">\r\n            <h1 mee-heading="heading" ng-if="$ctrl.isNewLevelsFeatureAvailable">{{$ctrl.pageTitle}}</h1>\r\n            <h2 mee-heading="heading" ng-if="$ctrl.isNewLevelsFeatureAvailable" class="levelName">{{$ctrl.headingTitle}}</h2>\r\n            <h2 mee-heading="heading" ng-if="!$ctrl.isNewLevelsFeatureAvailable">{{$ctrl.cmsData.strings["earningreport-level-heading"]}}</h2>\r\n            <p ng-if="!$ctrl.pointsSummary.isLevelTaskComplete && !$ctrl.isNewLevelsFeatureAvailable" ng-bind-html="$ctrl.pointsSummary.levelProgressText" class="pointsDetail c-subheading-3"></p>\r\n            <mee-progress-determinate data-grid="6"\r\n                                        progress-value="$ctrl.pointsSummary.nextLevelProgressPercentage"\r\n                                        aria-hidden="true"\r\n                                        ng-if="!$ctrl.pointsSummary.isLevelTaskComplete && !$ctrl.isNewLevelsFeatureAvailable">\r\n            </mee-progress-determinate>\r\n            <p mee-caption="caption1" class="c-meta-text">\r\n                <mee-rewards-counter-animation from="$ctrl.previousPointsToNextLevel"\r\n                                                to="$ctrl.pointsSummary.remainingPointsToNextLevel"\r\n                                                format="$ctrl.pointsSummary.nextLevelTask">\r\n                </mee-rewards-counter-animation>\r\n            </p>\r\n            <mee-progress-determinate data-grid="6"\r\n                                        progress-value="$ctrl.pointsSummary.nextLevelProgressPercentage"\r\n                                        aria-hidden="true"\r\n                                        ng-if="$ctrl.isNewLevelsFeatureAvailable"\r\n                                        ng-class="{completed: $ctrl.pointsSummary.isLevelTaskComplete}">\r\n            </mee-progress-determinate>\r\n            <p ng-if="$ctrl.isNewLevelsFeatureAvailable">\r\n                <mee-rewards-level-progress user-status="$ctrl.userStatus" href="/levelbenefits">\r\n                </mee-rewards-level-progress>\r\n            </p>\r\n        </div>\r\n\r\n        <div mee-auto-focus ng-if="!$ctrl.isNewLevelsFeatureAvailable">\r\n            <h2 mee-heading="heading" id ="earningreport-pointsbreakdown-heading" class="margin-top-48">{{$ctrl.cmsData.strings["earningreport-pointsbreakdown-heading"]}}</h2>\r\n            <div class="cardContainer">\r\n                <div class="pointsBreakdownCard" ng-repeat="item in $ctrl.pointsCounters">\r\n                    <div class="border">\r\n                        <div class="circle">\r\n                            <mee-rewards-circle-progress\r\n                                size="item.size"\r\n                                icon-color="item.iconColor"\r\n                                progress="item.progress"\r\n                                progress-max="item.progressMax"\r\n                                font-icon="item.fontIcon"\r\n                                tool-tip="item.toolTip">\r\n                            </mee-rewards-circle-progress>\r\n                        </div>\r\n\r\n                        <div class="pointsDetail">\r\n                            <mee-rewards-user-points-details\r\n                                points-detail="item"\r\n                                cms-data="$ctrl.cmsData">\r\n                            </mee-rewards-user-points-details>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <div id="earningreport-level-up-progress" ng-if="$ctrl.isNewLevelsFeatureAvailable">\r\n            <h2 mee-heading="heading" id="earningreport-pointsbreakdown-level-up-progress-heading" class="margin-top-48">{{$ctrl.levelUpActivitiesProgressTitle}}</h2>\r\n            <p mee-caption="caption1" class="c-meta-text">{{$ctrl.levelUpActivitiesProgressHint}}</p>\r\n            <mee-card-group \r\n                ng-class="{\r\n                    \'mobileViewMode\': $ctrl.areaConfig.isMobileViewModeEnabled, \r\n                    \'new-levels-feature\': $ctrl.isNewLevelsFeatureAvailable, \r\n                    \'justify-center\': true, \r\n                    \'ncols-4\':  $ctrl.getNcolsClass() == \'ncols-4\',\r\n                    \'ncols-3\':  $ctrl.getNcolsClass() == \'ncols-3\',\r\n                    \'ncols-2\': $ctrl.getNcolsClass() == \'ncols-2\'\r\n                }">\r\n                <mee-card>\r\n                    <card-content>\r\n                        <mee-rewards-bing-search-level-up-progress userstatus="$ctrl.userStatus"></mee-rewards-bing-search-level-up-progress>\r\n                    </card-content>\r\n                </mee-card>\r\n                <mee-card ng-if="$ctrl.hva_dailystreaks_mobile_display">\r\n                    <card-content>\r\n                        <mee-rewards-bing-app-seven-days-check-in-progress userstatus="$ctrl.userStatus"></mee-rewards-bing-app-seven-days-check-in-progress>\r\n                    </card-content>\r\n                </mee-card>\r\n                <mee-card ng-if="$ctrl.hva_dailystreaks_bing_display">\r\n                    <card-content>\r\n                        <mee-rewards-search-on-bing-seven-days-progress userstatus="$ctrl.userStatus"></mee-rewards-search-on-bing-seven-days-progress>\r\n                    </card-content>\r\n                </mee-card>\r\n                <mee-card ng-if="$ctrl.hva_puzzle_display">\r\n                    <card-content>\r\n                        <mee-rewards-puzzle-level-up-progress userstatus="$ctrl.userStatus"></mee-rewards-puzzle-level-up-progress>\r\n                    </card-content>\r\n                </mee-card>\r\n                <mee-card ng-if="$ctrl.hva_dailyset_display">\r\n                    <card-content>\r\n                        <mee-rewards-daily-set-streak-level-up-progress userstatus="$ctrl.userStatus"></mee-rewards-daily-set-streak-level-up-progress>\r\n                    </card-content>\r\n                </mee-card>\r\n                <mee-card ng-if="$ctrl.hva_gamepass_display">\r\n                    <card-content>\r\n                        <mee-rewards-xbox-premium-level-up-progress userstatus="$ctrl.userStatus"></mee-rewards-xbox-premium-level-up-progress>\r\n                    </card-content>\r\n                </mee-card>\r\n            </mee-card-group>\r\n        </div>\r\n\r\n        <div id="bingSearchDailyPoints" ng-if="$ctrl.isNewLevelsFeatureAvailable">\r\n            <h2 mee-heading="heading" id="earningreport-pointsbreakdown-bing-search-heading" class="margin-top-48">{{$ctrl.cmsData.strings["points-breakdown-bing-daily-title"]}}</h2>\r\n            <mee-rewards-level-progress-bar user-status="$ctrl.userStatus"></mee-rewards-level-progress-bar>\r\n        </div>\r\n\r\n        <div id="lastMonthBonuses" ng-if="$ctrl.isNewLevelsFeatureAvailable">\r\n            <h2 mee-heading="heading" id="earningreport-pointsbreakdown-last-month-bonuses-heading" class="margin-top-48 margin-bottom-18">{{$ctrl.cmsData.strings["points-breakdown-last-month-bonuses-title"]}}</h2>\r\n            <p mee-caption="caption1" class="c-meta-text" ng-if="$ctrl.cmsData.strings[\'bonus-delay-message\']">{{$ctrl.cmsData.strings["bonus-delay-message"]}}</p>\r\n            <mee-card-group ng-class="{\'mobileViewMode\' : $ctrl.areaConfig.isMobileViewModeEnabled, \'new-levels-feature\': $ctrl.isNewLevelsFeatureAvailable}" class="ncols-3">\r\n                <mee-card>\r\n                    <card-content>\r\n                        <mee-rewards-default-search-bonus-progress user-status="$ctrl.userStatus"></mee-rewards-default-search-bonus-progress>\r\n                    </card-content>\r\n                </mee-card>\r\n                <mee-card>\r\n                    <card-content>\r\n                        <mee-rewards-monthly-level-bonus-progress user-status="$ctrl.userStatus"></mee-rewards-monthly-level-bonus-progress>\r\n                    </card-content>\r\n                </mee-card>\r\n                <mee-card>\r\n                    <card-content>\r\n                        <mee-rewards-bing-star-bonus-progress user-status="$ctrl.userStatus"></mee-rewards-bing-star-bonus-progress>\r\n                    </card-content>\r\n                </mee-card>\r\n            </mee-card-group>        \r\n        </div>\r\n\r\n        <div id="earningreport-open-redeem-page" ng-if="$ctrl.showOpenRedeemPage()">\r\n            <h2 mee-heading="heading" id="earningreport-pointsbreakdown-open-redeem-page-heading" class="margin-top-48">{{$ctrl.cmsData.strings["earningreport-open-redeem-page-heading"]}}</h2>\r\n            <a mee-call-to-action="lightweight"\r\n               ng-href=\'{{$ctrl.cmsData.links["open-redeem-page"].url}}\'\r\n               id=\'{{$ctrl.cmsData.links["open-redeem-page"].id}}\'\r\n               data-bi-id=\'{{$ctrl.cmsData.links["open-redeem-page"].id}}\'>\r\n                {{$ctrl.cmsData.links["open-redeem-page"].text}}\r\n            </a>\r\n        </div>\r\n\r\n        <div class="cardContainer" ng-if=\'$ctrl.areaConfig.flights["otherWaysToEarn"]\'>\r\n            <h2 mee-heading="heading" class="margin-top-48">{{$ctrl.cmsData.strings["earningreport-other-way-heading"]}}</h2>\r\n            <div class="margin-right-22 pointsBreakdownCard" ng-repeat="card in $ctrl.pointsBreakdownCards">\r\n                <img mee-image ng-src="{{card.icon.source}}" alt="{{card.icon.alternateText}}" aria-hidden="true" class="x-hidden-vp1" />\r\n                <h4 mee-heading="heading" class="margin-top-12">{{card.title}}</h4>\r\n                <p mee-paragraph="para4" class="margin-bottom-10 description c-meta-text earnSection" ng-bind-html="card.subtitle"></p>\r\n                <a mee-call-to-action="lightweight"\r\n                   id="{{card.callToAction.id}}"\r\n                   data-bi-id="{{card.callToAction.id}}"\r\n                   ng-href="{{card.callToAction.url}}"\r\n                   target="{{$ctrl.linkTarget()}}">\r\n                   {{card.callToAction.text}}\r\n                </a>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <div class="benefits-help" ng-if="$ctrl.isNewLevelsFeatureAvailable">\r\n        <div ng-if="benefit.helpText" class="benefits-help-item" ng-repeat="benefit in $ctrl.benefitsPromotion.benefits">\r\n            <p ng-bind-html="$ctrl.cmsData.strings[benefit.helpText] || benefit.helpText"></p>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/UserStatus/user-points-breakdown.html",'<div id="userPointsBreakdown" data-grid="col-12" role="dialog" aria-labelledby="title" aria-modal="true" tabindex="-1">\r\n    <div>\r\n        <div class="center" data-grid="8">\r\n            <h1 mee-heading="heading1" id="title">\r\n                <strong>\r\n                    <mee-rewards-counter-animation from="0" to="$ctrl.pointsSummary.availablePoints"></mee-rewards-counter-animation>\r\n                </strong>\r\n            </h1>            \r\n            <p mee-caption="caption1" class="c-meta-text availablePoints">{{$ctrl.cmsData.strings["available-points"]}}</p>\r\n            <p ng-if="!$ctrl.pointsSummary.isLevelTaskComplete" ng-bind-html="$ctrl.pointsSummary.levelProgressText" class="pointsDetail c-subheading-3"></p>\r\n            <mee-progress-determinate data-grid="6"\r\n                                      progress-value="$ctrl.pointsSummary.nextLevelProgressPercentage"\r\n                                      mee-aria-label="determinate progress bar"\r\n                                      ng-if="!$ctrl.pointsSummary.isLevelTaskComplete">\r\n            </mee-progress-determinate>\r\n            <p mee-caption="caption1" class="c-meta-text">\r\n                <mee-rewards-counter-animation from="$ctrl.previousPointsToNextLevel"\r\n                                               to="$ctrl.pointsSummary.remainingPointsToNextLevel"\r\n                                               format="$ctrl.pointsSummary.nextLevelTask">\r\n                </mee-rewards-counter-animation>\r\n            </p>\r\n        </div>\r\n\r\n        <div mee-auto-focus>\r\n            <div data-grid="col-6" class="margin-bottom-18" ng-repeat="item in $ctrl.pointsCounters" role="presentation">\r\n                <div class="pointsCountersContainer" role="presentation">\r\n                    <div data-grid="col-3" class="margin-right-22" role="presentation">\r\n                        <mee-rewards-circle-progress \r\n                            size="item.size"\r\n                            icon-color="item.iconColor"\r\n                            progress="item.progress"\r\n                            progress-max="item.progressMax"\r\n                            font-icon="item.fontIcon"\r\n                            ng-class="{\'shopAndEarn\' : item.isShopAndEarn }"\r\n                            tool-tip="item.toolTip">\r\n                        </mee-rewards-circle-progress>\r\n                    </div>\r\n\r\n                    <div data-grid="col-7" class="pointsDetail" role="presentation">\r\n                        <mee-rewards-user-points-details                                                     \r\n                            points-detail="item"\r\n                            cms-data="$ctrl.cmsData">\r\n                        </mee-rewards-user-points-details>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Shared/UserStatus/user-points-details.html",'<div class="content">\r\n    <div class="body-outer">\r\n        <div class="body-inner">\r\n            <div class="title-detail">\r\n                <p>\r\n                    <a mee-hyperlink\r\n                       ng-href="{{$ctrl.pointsDetail.destinationUrl}}"\r\n                       target="{{$ctrl.target}}"\r\n                       ng-if="$ctrl.pointsDetail.destinationUrl"\r\