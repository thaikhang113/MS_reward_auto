div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/Shared/Animation/animation.html",'<picture class="rewards-animation-container">\r\n    <img mee-image\r\n         class="rewardsBodymovin"\r\n         ng-if="!$ctrl.isAnimation"\r\n         ng-src="{{$ctrl.data.source}}"\r\n         alt="{{$ctrl.data.alternateText}}"\r\n         data-mee-onerror\r\n         aria-hidden="true"\r\n         data-error-callback="$ctrl.handleError()" />\r\n    <div ng-if="$ctrl.isAnimation" class="rewardsBodymovin"></div>\r\n</picture>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/Shared/CheckMark/check-mark.html",'<div class="icon-container" ng-if="$ctrl.complete">\r\n    <span class="icon-wrapper" ng-repeat="item in $ctrl.complete track by $index">\r\n        <span class="mee-icon mee-icon-StatusCircleOuter" ng-if="!item"></span>\r\n        <span class="mee-icon mee-icon-StatusCircleOuter checkmark" ng-if="item">\r\n            <i class="mee-icon mee-icon-StatusCircleCheckmark"></i>\r\n        </span>\r\n    </span>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/Shared/LegalTextBox/legal-text-box.html",'<div id="legalTextBox" tabindex="-1" data-grid="col-12" role="alertdialog" aria-labelledby="title">\r\n    <div>\r\n        <div class="center" data-grid="8">\r\n            <div class="imageContainer" ng-if="!$ctrl.isCustomPopup">\r\n                <mee-rewards-animation data="$ctrl.icon" ng-if="$ctrl.icon.source" />\r\n            </div>\r\n            <div class="imageContainer" ng-if="$ctrl.isCustomPopup">\r\n                <img mee-image class="custom-img" ng-srcset="{{$ctrl.icon.source}}" ng-src="{{$ctrl.icon.source}}" alt="warning image">\r\n            </div>\r\n            <div class="contentContainer">\r\n                <h3 class="{{$ctrl.isCustomPopup ? \'custom-title\' : \'\'}}" mee-heading="heading">{{$ctrl.selectedPromotion.title}}</h3>\r\n                <p ng-if="!$ctrl.isCustomPopup" mee-heading="subheading4">{{$ctrl.selectedPromotion.description}}</p>\r\n            </div>\r\n            <div class="actionLink">\r\n                <a mee-call-to-action="lightweight"\r\n                   href="#"\r\n                   data-bi-id="{{$ctrl.biId}}"\r\n                   ng-if="$ctrl.callToAction.text"\r\n                   ng-click="$ctrl.onClickLink($event)">\r\n                    {{$ctrl.callToAction.text}}\r\n                </a>\r\n            </div>\r\n            <div class="{{$ctrl.isCustomPopup ? \'legalTextContainer margin-top-15\' : \'legalTextContainer margin-top-32\'}}">\r\n                <p id="legalText" mee-heading="subheading4" ng-bind-html="$ctrl.selectedPromotion.legalText"></p>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/Shared/Points/points.html",'<div class="points clearfix">\r\n    <div ng-if="!$ctrl.locked && !$ctrl.isExclusiveLockedItem">\r\n        <img class="image-icon {{$ctrl.iconName}}" ng-if="$ctrl.iconImage" ng-src="{{$ctrl.iconImage}}" alt="{{$ctrl.cmsData.strings[\'plus-points\']}}" aria-label="{{$ctrl.iconAriaLabel}}" role="img" />\r\n        <span class="mee-icon mee-icon-{{$ctrl.iconName}}" ng-if="!$ctrl.iconImage && $ctrl.iconName" aria-label="{{$ctrl.iconAriaLabel}}" role="img"></span>\r\n        <span mee-heading="heading" ng-if="$ctrl.pointsString" class="pointsString">{{$ctrl.pointsString}}</span>\r\n    </div>\r\n    <div ng-if="!$ctrl.locked && $ctrl.isExclusiveLockedItem">\r\n        <img class="image-icon {{$ctrl.iconName}}" ng-if="$ctrl.iconImage" ng-src="{{$ctrl.iconImage}}" alt="{{$ctrl.cmsData.strings[\'plus-points\']}}" aria-label="{{$ctrl.iconAriaLabel}}" role="img" />\r\n        <span class="mee-icon mee-icon-{{$ctrl.iconName}} exclusiveLockedPts" ng-if="!$ctrl.iconImage && $ctrl.iconName" aria-label="{{$ctrl.iconAriaLabel}}" role="img"></span>\r\n        <span mee-heading="heading" ng-if="$ctrl.pointsString" class="pointsString">{{$ctrl.pointsString}}</span>\r\n    </div>\r\n    <div ng-if="$ctrl.locked" class="points-locked">\r\n        <span class="mee-icon icon mee-icon-Lock" aria-label="{{$ctrl.iconAriaLabel}}" role="img"></span>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/Shared/Slide/slide.html",'<div class="rewards-slide">\r\n    <section class="rewards-slide-content" ng-transclude></section>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Family/RequestPoint/steps/request-point-cancel.html",'<div id="request-point" class="text-align-center" tabindex="-1">\r\n    <h4 mee-heading="heading4" class="messageHeading">{{$ctrl.cmsData.strings["rp-cancel-point-title"]}}</h4>\r\n    <p mee-paragraph="para4" class="text-align-left margin-bottom-36">{{$ctrl.cmsData.strings["rp-cancel-point-desc"]}}</p>\r\n    <div class="dialog-content">\r\n        <mee-progress-view watch-operation="cancelPointsRequest">\r\n            <inert-view>\r\n            </inert-view>\r\n            <inprogress-view>\r\n                <div data-grid="col-12" class="margin-top-5">\r\n                    <mee-progress-ants-mwf kind="local large" class="margin-horizontal-auto"></mee-progress-ants-mwf>\r\n                </div>\r\n            </inprogress-view>\r\n            <failed-view>\r\n            </failed-view>\r\n            <finished-view>\r\n            </finished-view>\r\n        </mee-progress-view>\r\n        <div data-grid="col-12" class="actionLink">\r\n            <mee-inline-error error-id="requestpoint.cancel"></mee-inline-error>\r\n            <button mee-button="primary"\r\n                    id="nextButton"\r\n                    mee-auto-focus\r\n                    mee-progress-disabled="cancelPointsRequest"\r\n                    ng-click="$ctrl.executeClick()">\r\n                {{$ctrl.errorOccured() ? $ctrl.cmsData.strings["done"] : $ctrl.cmsData.strings["rp-yes-button"]}}\r\n            </button>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Family/RequestPoint/steps/request-point-celebrate.html",'<div id="request-point" class="text-align-center" tabindex="-1">\r\n    <h4 mee-heading="heading4" class="mainHeading">{{$ctrl.title}}</h4>\r\n    <div class="dialog-content">\r\n        <div data-grid="col-12" class="confirmationContainer">\r\n            <div data-grid="col-12" class="margin-bottom-36 margin-right-15 celebration">\r\n                <mee-persona size="persona1" picture-aria-label="{{$ctrl.currentUser.displayName}}">\r\n                    <persona-image>\r\n                        <mee-safe-image img-class="round" src="$ctrl.currentUser.profileImageUrl"></mee-safe-image>\r\n                    </persona-image>\r\n                </mee-persona>\r\n                <mee-rewards-animation data="$ctrl.animation" />\r\n            </div>\r\n            <div class="contentContainer">\r\n                <p mee-paragraph="para4">{{$ctrl.cmsData.strings["rp-celebration-message"]}} </p>\r\n            </div>\r\n        </div>\r\n        <div data-grid="col-12" class="actionLink">\r\n            <div class="c-group">\r\n                <button mee-button="primary"\r\n                        id="nextButton"\r\n                        mee-auto-focus\r\n                        ng-click="$ctrl.dismissModal()">\r\n                    {{$ctrl.cmsData.strings["done"]}}\r\n                </button>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Family/RequestPoint/steps/request-point-confirm.html",'<div id="request-point" class="text-align-center" tabindex="-1">\r\n    <h4 mee-heading="heading4" class="mainHeading">{{$ctrl.title}}</h4>\r\n    <div class="dialog-content">\r\n        <div ng-if="$ctrl.familyMembers" class="familyGroup">\r\n            <div ng-repeat="member in $ctrl.familyMembers" class="familyMember">\r\n                <div class="width-control">\r\n                    <mee-persona size="persona1" picture-aria-label="{{member.displayName}}">\r\n                        <persona-image>\r\n                            <mee-safe-image img-class="round" src="member.profileImageUrl"></mee-safe-image>\r\n                        </persona-image>\r\n                    </mee-persona>\r\n                </div>\r\n                <div class="contentContainer x-hidden-vp1" ng-if="$ctrl.familyMembers.length < 5">\r\n                    <p mee-paragraph="para4">{{member.firstName}}</p>\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div class="askPointsContainer">\r\n            <p mee-paragraph="para4" class="margin-bottom-4">{{$ctrl.cmsData.strings["rp-total-available-points"]}}</p>\r\n            <h4 mee-heading="heading4">\r\n                {{$ctrl.totalAvailablePoints | toLocalString}}\r\n            </h4>\r\n        </div>\r\n        <div class="askPointsContainer">\r\n            <p mee-paragraph="para4" class="margin-bottom-4">{{$ctrl.cmsData.strings["rp-ask-for"]}}</p>\r\n            <h4 mee-heading="heading4">\r\n                <mee-rewards-counter-animation from="0" to="$ctrl.requestedPoints" />\r\n            </h4>\r\n        </div>\r\n        <mee-progress-view watch-operation="requestPoints">\r\n            <inert-view>\r\n            </inert-view>\r\n            <inprogress-view>\r\n                <div data-grid="col-12" class="margin-top-5">\r\n                    <mee-progress-ants-mwf kind="local large" class="margin-horizontal-auto"></mee-progress-ants-mwf>\r\n                </div>\r\n            </inprogress-view>\r\n            <failed-view>\r\n            </failed-view>\r\n            <finished-view>\r\n            </finished-view>\r\n        </mee-progress-view>\r\n        <div data-grid="col-12" class="actionLink">\r\n            <mee-inline-error error-id="requestpoint.save"></mee-inline-error>\r\n            <div class="c-group">\r\n                <button ng-if="!$ctrl.errorOccured()"\r\n              