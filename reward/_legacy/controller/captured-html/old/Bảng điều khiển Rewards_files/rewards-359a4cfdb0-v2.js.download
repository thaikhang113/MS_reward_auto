\n    </div>\r\n    <div class="actionLink">\r\n        <a mee-button="primary" class="closeButton" ng-click="$ctrl.close($event)" href="" aria-label="{{$ctrl.buttonText}}">\r\n            {{$ctrl.buttonText}}\r\n        </a>\r\n    </div>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/Promotion/promotion.html",'<div class="promotional-container" mee-rewardable data-bi-id="{{biId}}" data-bi-area="{{biArea}}">\r\n    <a ng-href="{{item.callToAction.url}}">\r\n        <mee-hero-item id="promo-item"\r\n                       horz="left"\r\n                       vert="center"\r\n                       context="accessory"\r\n                       theme="light"\r\n                       ng-if="$ctrl.promotion"\r\n                       ng-show="$ctrl.show"\r\n                       tabindex="{{$ctrl.show ? 0 : -1}}"\r\n                       aria-label="{{item.extBannerTitle ? item.extBannerTitle : item.title}}, {{item.extBannerDescription ? item.extBannerDescription : item.subtitle}}">\r\n            <background-picture>\r\n                <picture id="{{item.dynamicImage === \'true\' ? \'dynamic-img\' : \'\'}}" class="{{item.customBannerPromo ? \'custom-bg\' : \'\'}}">\r\n                    <i class="mee-icon pull-left icon mee-icon-Cancel" tabindex="0"\r\n                       ng-if=\'($ctrl.promotion.attributes["hide_close"] && $ctrl.promotion.attributes["hide_close"].toLowerCase()) !== "true"\'\r\n                       ng-attr-aria-label="{{$ctrl.cmsData.strings[\'promo-close\']}}"\r\n                       role="button"\r\n                       ng-click="$ctrl.closePromotionFunc($event)"\r\n                       ng-keydown="$ctrl.closePromotionFunc($event)" />\r\n\r\n                    <div class="x-visible-vp1 x-visible-vp2 x-hidden-vp3 x-hidden-vp4 x-hidden-vp5">\r\n                        \x3c!--Renders on generic and dynamically uploaded images--\x3e\r\n                        <mee-rewards-animation data="item.backgroundMobileImage" auto-play="true"></mee-rewards-animation>\r\n                    </div>\r\n                    <div class="x-hidden-vp1 x-hidden-vp2 x-visible-vp3 x-visible-vp4 x-hidden-vp5">\r\n                        <mee-rewards-animation ng-if="item.dynamicImage !== \'true\'" data="item.backgroundTabletImage" auto-play="true"></mee-rewards-animation>\r\n                        \x3c!--Renders only on dynamically uploaded images--\x3e\r\n                        <img ng-if="item.dynamicImage === \'true\'" class="dynamic-img-desktop-tablet" ng-src="{{item.imageUrl}}" alt="{{item.subtitle}}" />\r\n                    </div>\r\n                    <div class="x-hidden-vp1 x-hidden-vp2 x-hidden-vp3 x-hidden-vp4 x-visible-vp5">\r\n                        <mee-rewards-animation ng-if="item.dynamicImage !== \'true\'" data="item.backgroundImage" auto-play="true"></mee-rewards-animation>\r\n                        \x3c!--Renders only on dynamically uploaded images--\x3e\r\n                        <img ng-if="item.dynamicImage === \'true\'" class="dynamic-img-desktop-tablet" ng-src="{{item.imageUrl}}" alt="{{item.subtitle}}" />\r\n                    </div>\r\n                </picture>\r\n            </background-picture>\r\n            <action-area>\r\n                <h2 mee-heading="heading" ng-style="$ctrl.getStyleObject(item.titleStyle)">{{item.extBannerTitle ? item.extBannerTitle : item.title}}</h2>\r\n                <h6 mee-heading="heading6" ng-style="$ctrl.getStyleObject(item.titleStyle)" class="padding-top-8" ng-if="$ctrl.isComplianceBanner()">{{item.subheader}}</h6>\r\n                <p ng-if="item.dynamicImage !== \'true\'" mee-heading="subheading" ng-style="$ctrl.getStyleObject(item.descriptionStyle)">{{item.extBannerDescription ? item.extBannerDescription : item.subtitle}}</p>\r\n                \x3c!--Renders only on dynamically uploaded images--\x3e\r\n                <p ng-if="item.dynamicImage === \'true\'" id="dynamic-img-description">{{item.extBannerDescription ? item.extBannerDescription : item.subtitle}}</p>\r\n                <div ng-if="item.hasCta" class="actionLink">\r\n                    <span class="callToAction-override">{{item.callToAction.text}}</span>\r\n                </div>\r\n            </action-area>\r\n        </mee-hero-item>\r\n        <mee-rewards-debug-info item="item"></mee-rewards-debug-info>\r\n    </a>\r\n</div>'),e.put("/Areas/Rewards/ScriptsOneUI/Components/Dashboard/Promotion/promotional-item.html",'<div class="promotional-container" mee-rewardable data-bi-id="{{biId}}" data-bi-area="{{biArea}}">\r\n    <a ng-href="{{item.callToAction.url}}">\r\n        <mee-hero-item id="promo-item"\r\n                       horz="left"\r\n                       vert="center"\r\n                       context="accessory"\r\n                       theme="light"\r\n                       ng-if="$ctrl.promotion"\r\n                       aria-label="{{item.extBannerTitle ? item.extBannerTitle : item.title}}, {{item.extBannerDescription ? item.extBannerDescription : item.subtitle}}">\r\n\r\n            <background-picture>\r\n                <picture id="{{item.dynamicImage === \'true\' ? \'dynamic-img\' : \'\'}}" class="{{item.customBannerPromo ? \'custom-bg\' : \'\'}}">\r\n                    <i class="mee-icon pull-left icon mee-icon-Cancel"\r\n                       tabindex="0"\r\n                       ng-if=\'($ctrl.promotion.attributes["hide_close"] && $ctrl.promotion.attributes["hide_close"].toLowerCase()) !== "true"\'\r\n                       ng-attr-aria-label="{{$ctrl.cmsData.strings[\'promo-close\']}}"\r\n                       role="button"\r\n                       ng-click="$ctrl.closePromotionFunc($event)"\r\n                       ng-keydown="$ctrl.closePromotionFunc($event)" />\r\n\r\n                    <div class="x-visible-vp1 x-visible-vp2 x-hidden-vp3 x-hidden-vp4 x-hidden-vp5">\r\n                        \x3c!--Renders on generic and dynamically uploaded images--\x3e\r\n                      